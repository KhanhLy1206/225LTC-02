@model WebApplication1.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng Ký Khách Hàng - SmartParking";
}

<div class="auth-wrapper">
    <div class="glass-card auth-card-wide animate-fade-in-up">
        <div class="text-center mb-4">
            <div class="fs-1 text-secondary mb-2"><i class="fa-solid fa-user-plus"></i></div>
            <h3 class="auth-title text-gradient mb-1">ĐĂNG KÝ KHÁCH HÀNG</h3>
            <p class="text-muted small">Tạo tài khoản để đặt chỗ và điều khiển barie đỗ xe thông minh</p>
        </div>

        <form method="post" asp-controller="Account" asp-action="Register" id="registerForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>

            <div class="row g-3">
                <!-- Cột trái: Thông tin cá nhân -->
                <div class="col-md-6 border-end border-secondary border-opacity-10 pe-md-4">
                    <h5 class="text-secondary mb-3 small text-uppercase fw-bold">
                        <i class="fa-solid fa-address-card me-2"></i>Thông tin cá nhân
                    </h5>

                    <div class="mb-3">
                        <label class="auth-label" asp-for="TenDangNhap">Tên đăng nhập</label>
                        <div class="auth-input-group">
                            <input asp-for="TenDangNhap" type="text" class="form-control" placeholder="Tên đăng nhập..." autocomplete="username" />
                            <i class="fa-solid fa-user-gear input-icon"></i>
                        </div>
                        <span asp-validation-for="TenDangNhap" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label class="auth-label" asp-for="HoTen">Họ và Tên</label>
                        <div class="auth-input-group">
                            <input asp-for="HoTen" type="text" class="form-control" placeholder="Nguyễn Văn A..." />
                            <i class="fa-solid fa-user input-icon"></i>
                        </div>
                        <span asp-validation-for="HoTen" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label class="auth-label" asp-for="SDT">Số điện thoại</label>
                        <div class="auth-input-group">
                            <input asp-for="SDT" type="tel" class="form-control" placeholder="0901234567..." />
                            <i class="fa-solid fa-phone input-icon"></i>
                        </div>
                        <span asp-validation-for="SDT" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Email + nút gửi OTP -->
                    <div class="mb-3">
                        <label class="auth-label" asp-for="Email">Địa chỉ Gmail <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input asp-for="Email" type="email" class="form-control" id="emailInput"
                                   placeholder="example@gmail.com..." autocomplete="email" />
                            <button type="button" class="btn btn-outline-secondary" id="btnGuiOtp"
                                    style="border-radius:0 10px 10px 0;font-size:.85rem;white-space:nowrap">
                                <i class="fa-solid fa-paper-plane me-1"></i>Gửi OTP
                            </button>
                        </div>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        <div id="otpMsg" class="small mt-1"></div>
                    </div>

                    <!-- Ô nhập OTP (ẩn ban đầu) -->
                    <div class="mb-3" id="otpBox" style="display:none">
                        <label class="auth-label">Mã OTP (6 chữ số)</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="otpInput"
                                   placeholder="Nhập mã OTP..." maxlength="6"
                                   style="letter-spacing:6px;font-size:1.1rem;font-weight:700;text-align:center" />
                            <button type="button" class="btn btn-success" id="btnXacThucOtp"
                                    style="border-radius:0 10px 10px 0;font-size:.85rem">
                                <i class="fa-solid fa-check me-1"></i>Xác thực
                            </button>
                        </div>
                        <div id="otpXacThucMsg" class="small mt-1"></div>
                    </div>

                    <!-- Badge xác thực thành công -->
                    <div id="emailVerified" style="display:none" class="mb-2">
                        <span class="badge bg-success px-3 py-2">
                            <i class="fa-solid fa-circle-check me-1"></i>Email đã xác thực
                        </span>
                    </div>
                </div>

                <!-- Cột phải: Bảo mật -->
                <div class="col-md-6 ps-md-4">
                    <h5 class="text-secondary mb-3 small text-uppercase fw-bold">
                        <i class="fa-solid fa-shield-halved me-2"></i>Bảo mật tài khoản
                    </h5>

                    <div class="mb-3">
                        <label class="auth-label" asp-for="MatKhau">Mật khẩu</label>
                        <div class="auth-input-group">
                            <input asp-for="MatKhau" type="password" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                            <i class="fa-solid fa-lock input-icon"></i>
                            <button type="button" class="btn-eye-toggle toggle-pass-btn" data-target="MatKhau" tabindex="-1">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="MatKhau" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label class="auth-label" asp-for="XacNhanMatKhau">Xác nhận mật khẩu</label>
                        <div class="auth-input-group">
                            <input asp-for="XacNhanMatKhau" type="password" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                            <i class="fa-solid fa-lock input-icon"></i>
                            <button type="button" class="btn-eye-toggle toggle-pass-btn" data-target="XacNhanMatKhau" tabindex="-1">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="XacNhanMatKhau" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-check my-4 small">
                        <input class="form-check-input" type="checkbox" id="termsCheck" required />
                        <label class="form-check-label text-muted" for="termsCheck">
                            Tôi đồng ý với <a href="#" class="text-secondary text-decoration-none">Điều khoản sử dụng</a>
                        </label>
                    </div>

                    <div class="row g-2 align-items-center">
                        <div class="col-md-8">
                            <button type="submit" class="btn btn-primary-custom w-100 py-3" id="btnDangKy" disabled>
                                TẠO TÀI KHOẢN <i class="fa-solid fa-user-plus ms-1"></i>
                            </button>
                        </div>
                        <div class="col-md-4 text-center text-md-end">
                            <a asp-controller="Account" asp-action="Login" class="text-muted text-decoration-none small">
                                Đã có tài khoản? <span class="text-secondary fw-semibold">Đăng nhập</span>
                            </a>
                        </div>
                    </div>

                    <div class="mt-3 p-3 rounded" style="background:rgba(79,70,229,.08);font-size:.8rem;color:#6b7280">
                        <i class="fa-solid fa-circle-info me-1 text-primary"></i>
                        Mã OTP sẽ được gửi về Gmail của bạn. Vui lòng kiểm tra cả thư mục <strong>Spam</strong> nếu không thấy.
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
let emailDaXacThuc = false;

// Gửi OTP
document.getElementById('btnGuiOtp').addEventListener('click', async function() {
    const email = document.getElementById('emailInput').value.trim();
    if (!email || !email.includes('@@')) {
        document.getElementById('otpMsg').innerHTML = '<span class="text-danger">Vui lòng nhập email hợp lệ.</span>';
        return;
    }
    this.disabled = true;
    this.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-1"></i>Đang gửi...';
    document.getElementById('otpMsg').innerHTML = '';

    const res = await fetch('/Account/GuiOtp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, loai: 'Khách hàng' })
    });
    const data = await res.json();

    if (data.success) {
        document.getElementById('otpMsg').innerHTML = '<span class="text-success"><i class="fa-solid fa-check me-1"></i>' + data.message + '</span>';
        document.getElementById('otpBox').style.display = 'block';
        let s = 60;
        const btn = this;
        const t = setInterval(() => {
            s--;
            btn.innerHTML = '<i class="fa-solid fa-clock me-1"></i>Gửi lại (' + s + 's)';
            if (s <= 0) {
                clearInterval(t);
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-paper-plane me-1"></i>Gửi lại OTP';
            }
        }, 1000);
    } else {
        document.getElementById('otpMsg').innerHTML = '<span class="text-danger">' + data.message + '</span>';
        this.disabled = false;
        this.innerHTML = '<i class="fa-solid fa-paper-plane me-1"></i>Gửi OTP';
    }
});

// Xác thực OTP
document.getElementById('btnXacThucOtp').addEventListener('click', async function() {
    const email = document.getElementById('emailInput').value.trim();
    const otp   = document.getElementById('otpInput').value.trim();
    if (otp.length !== 6) {
        document.getElementById('otpXacThucMsg').innerHTML = '<span class="text-danger">Mã OTP gồm 6 chữ số.</span>';
        return;
    }
    this.disabled = true;
    this.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

    const res = await fetch('/Account/XacThucOtp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, otp: otp })
    });
    const data = await res.json();

    if (data.success) {
        emailDaXacThuc = true;
        document.getElementById('otpXacThucMsg').innerHTML = '<span class="text-success"><i class="fa-solid fa-check me-1"></i>Xác thực thành công!</span>';
        document.getElementById('otpBox').style.display = 'none';
        document.getElementById('emailVerified').style.display = 'block';
        document.getElementById('emailInput').readOnly = true;
        document.getElementById('btnGuiOtp').style.display = 'none';
        document.getElementById('btnDangKy').disabled = false;
    } else {
        document.getElementById('otpXacThucMsg').innerHTML = '<span class="text-danger">' + data.message + '</span>';
        this.disabled = false;
        this.innerHTML = '<i class="fa-solid fa-check me-1"></i>Xác thực';
    }
});

// Chặn submit nếu chưa xác thực email
document.getElementById('registerForm').addEventListener('submit', function(e) {
    if (!emailDaXacThuc) {
        e.preventDefault();
        document.getElementById('otpMsg').innerHTML = '<span class="text-danger">Vui lòng xác thực email trước khi đăng ký.</span>';
    }
});

// Toggle mật khẩu
document.querySelectorAll('.toggle-pass-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
        const name = this.dataset.target;
        const inp = document.querySelector('[name="' + name + '"]');
        inp.type = inp.type === 'password' ? 'text' : 'password';
        this.querySelector('i').classList.toggle('fa-eye');
        this.querySelector('i').classList.toggle('fa-eye-slash');
    });
});
</script>
}
