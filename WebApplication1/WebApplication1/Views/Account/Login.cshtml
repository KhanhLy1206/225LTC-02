@model WebApplication1.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng Nhập Hệ Thống - SmartParking";
}

<div class="auth-wrapper">
    <div class="glass-card auth-card animate-fade-in-up">
        <!-- Logo and Title -->
        <div class="text-center mb-4">
            <div class="fs-1 text-secondary mb-2">
                <i class="fa-solid fa-square-parking"></i>
            </div>
            <h3 class="auth-title text-gradient mb-1">ĐĂNG NHẬP</h3>
            <p class="text-muted small">Nhập tài khoản hoặc email để truy cập bãi đỗ xe</p>
        </div>

        @if (TempData["RegisterSuccess"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show text-center small mb-3" role="alert" style="border: 1px solid var(--border-color);">
                <i class="fa-solid fa-circle-check me-1"></i> @TempData["RegisterSuccess"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form method="post" asp-controller="Account" asp-action="Login" id="loginForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>

            <!-- Username/Email Field -->
            <div class="mb-3">
                <label class="auth-label" asp-for="TenDangNhapHoacEmail">Tên đăng nhập hoặc Email</label>
                <div class="auth-input-group">
                    <input asp-for="TenDangNhapHoacEmail" type="text" class="form-control" placeholder="username hoặc email..." autocomplete="username" />
                    <i class="fa-solid fa-user input-icon"></i>
                </div>
                <span asp-validation-for="TenDangNhapHoacEmail" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Password Field -->
            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="auth-label mb-0" asp-for="MatKhau">Mật khẩu</label>
                </div>
                <div class="auth-input-group">
                    <input asp-for="MatKhau" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                    <i class="fa-solid fa-lock input-icon"></i>
                    <button type="button" class="btn-eye-toggle" id="togglePassword" tabindex="-1">
                        <i class="fa-solid fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="MatKhau" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Remember me & Forgot password -->
            <div class="d-flex justify-content-between align-items-center mb-4 small">
                <div class="form-check">
                    <input class="form-check-input border-secondary" type="checkbox" asp-for="RememberMe" />
                    <label class="form-check-label text-muted" asp-for="RememberMe">
                        Ghi nhớ đăng nhập
                    </label>
                </div>
                <a href="#" class="text-secondary text-decoration-none" id="forgotPasswordLink">Quên mật khẩu?</a>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="btn btn-primary-custom w-100 py-3 mb-3">
                ĐĂNG NHẬP <i class="fa-solid fa-right-to-bracket ms-1"></i>
            </button>
        </form>

        <!-- Register Redirections -->
        <hr class="border-secondary opacity-25 my-4">
        
        <div class="text-center small">
            <span class="text-muted">Bạn chưa có tài khoản?</span>
            <div class="d-flex justify-content-center gap-3 mt-2">
                <a asp-controller="Account" asp-action="Register" class="text-secondary text-decoration-none fw-semibold">
                    <i class="fa-solid fa-user-plus me-1"></i> Đăng ký Khách hàng
                </a>
                <span class="text-muted">|</span>
                <a asp-controller="Account" asp-action="RegisterOwner" class="text-gradient fw-semibold">
                    <i class="fa-solid fa-building-user me-1"></i> Hợp tác Chủ bãi
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Hiệu ứng Toggle ẩn/hiện mật khẩu
            $('#togglePassword').click(function() {
                const passInput = $('#MatKhau');
                const type = passInput.attr('type') === 'password' ? 'text' : 'password';
                passInput.attr('type', type);
                
                // Đổi icon con mắt
                $(this).find('i').toggleClass('fa-eye fa-eye-slash');
            });

            // Demo click quên mật khẩu
            $('#forgotPasswordLink').click(function(e) {
                e.preventDefault();
                alert('Tính năng khôi phục mật khẩu sẽ gửi email xác thực đến địa chỉ của bạn. (Liên kết API backend sẽ được cấu hình sau)');
            });
        });
    </script>
}
