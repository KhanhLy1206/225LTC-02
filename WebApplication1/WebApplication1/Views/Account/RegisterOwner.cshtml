@{
    ViewData["Title"] = "Đăng Ký Chủ Bãi Xe - SmartParking";
}

<div class="auth-wrapper">
    <div class="glass-card auth-card-wide animate-fade-in-up">
        <!-- Logo and Title -->
        <div class="text-center mb-4">
            <div class="fs-1 text-gradient mb-2">
                <i class="fa-solid fa-building-user"></i>
            </div>
            <h3 class="auth-title text-gradient mb-1">HỢP TÁC CHỦ BÃI XE</h3>
            <p class="text-muted small">Đăng ký thông tin bãi đỗ xe của bạn để tích hợp vào hệ thống SPMS</p>
        </div>

        <form method="post" action="/Account/RegisterOwner" id="registerOwnerForm" enctype="multipart/form-data">
            <div class="row g-3">
                <!-- Column 1: Owner and Lot Info -->
                <div class="col-md-6 border-end border-secondary border-opacity-10 pe-md-4">
                    <h5 class="text-secondary mb-3 small text-uppercase fw-bold tracking-wider"><i class="fa-solid fa-briefcase me-2"></i>Thông tin đối tác</h5>
                    
                    <!-- Parking Lot Name -->
                    <div class="mb-3">
                        <label class="auth-label" for="lotNameInput">Tên bãi đỗ xe</label>
                        <div class="auth-input-group">
                            <input type="text" class="form-control" id="lotNameInput" name="TenBaiXe" placeholder="Bãi Xe Thông Minh Quang Trung..." required />
                            <i class="fa-solid fa-square-parking input-icon"></i>
                        </div>
                    </div>

                    <!-- Contact Phone -->
                    <div class="mb-3">
                        <label class="auth-label" for="ownerPhoneInput">Số điện thoại liên hệ</label>
                        <div class="auth-input-group">
                            <input type="tel" class="form-control" id="ownerPhoneInput" name="SoDienThoai" placeholder="0912xxxxxx..." required pattern="[0-9]{10}" />
                            <i class="fa-solid fa-phone input-icon"></i>
                        </div>
                    </div>

                    <!-- Contact Email + OTP -->
                    <div class="mb-3">
                        <label class="auth-label" for="ownerEmailInput">Gmail <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="email" class="form-control" id="ownerEmailInput" name="Email"
                                   placeholder="owner@gmail.com..." required />
                            <button type="button" class="btn btn-outline-secondary" id="btnGuiOtpOwner"
                                    style="border-radius:0 10px 10px 0;font-size:.85rem;white-space:nowrap">
                                <i class="fa-solid fa-paper-plane me-1"></i>Gửi OTP
                            </button>
                        </div>
                        <div id="otpOwnerMsg" class="small mt-1"></div>
                    </div>

                    <!-- Ô nhập OTP -->
                    <div class="mb-3" id="otpOwnerBox" style="display:none">
                        <label class="auth-label">Mã OTP (6 chữ số)</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="otpOwnerInput"
                                   placeholder="Nhập mã OTP..." maxlength="6"
                                   style="letter-spacing:6px;font-size:1.1rem;font-weight:700;text-align:center" />
                            <button type="button" class="btn btn-success" id="btnXacThucOtpOwner"
                                    style="border-radius:0 10px 10px 0;font-size:.85rem">
                                <i class="fa-solid fa-check me-1"></i>Xác thực
                            </button>
                        </div>
                        <div id="otpOwnerXacThucMsg" class="small mt-1"></div>
                    </div>

                    <div id="ownerEmailVerified" style="display:none" class="mb-2">
                        <span class="badge bg-success px-3 py-2">
                            <i class="fa-solid fa-circle-check me-1"></i>Gmail đã xác thực
                        </span>
                    </div>

                    <!-- Business License Upload -->
                    <div class="mb-3">
                        <label class="auth-label" for="licenseUploadInput">Giấy phép kinh doanh (Hình ảnh/PDF)</label>
                        <div class="auth-input-group">
                            <input type="file" class="form-control" id="licenseUploadInput" name="GiayPhepKinhDoanh" required accept="image/*,application/pdf" />
                            <i class="fa-solid fa-file-invoice input-icon"></i>
                        </div>
                    </div>
                </div>

                <!-- Column 2: Lot Location -->
                <div class="col-md-6 ps-md-4">
                    <h5 class="text-secondary mb-3 small text-uppercase fw-bold tracking-wider"><i class="fa-solid fa-map-location-dot me-2"></i>Địa chỉ bãi đỗ xe</h5>
                    
                    <!-- Administrative Location Dropdowns -->
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="auth-label">Tỉnh / Thành</label>
                            <div class="auth-input-group">
                                <select class="form-select" id="ownerProvinceSelect" name="MaTinh" required>
                                    <option value="">Chọn tỉnh/thành...</option>
                                    @if (ViewBag.TinhThanhs != null)
                                    {
                                        foreach (var t in (IEnumerable<WebApplication1.Models.Entities.TinhThanh>)ViewBag.TinhThanhs)
                                        {
                                            <option value="@t.MaTinh">@t.TenTinh</option>
                                        }
                                    }
                                </select>
                                <i class="fa-solid fa-city input-icon"></i>
                            </div>
                        </div>

                        <div class="col-6">
                            <label class="auth-label">Quận / Huyện</label>
                            <div class="auth-input-group">
                                <select class="form-select" id="ownerDistrictSelect" name="MaHuyen" required disabled>
                                    <option value="" selected>Chọn...</option>
                                </select>
                                <i class="fa-solid fa-map input-icon"></i>
                            </div>
                        </div>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="auth-label">Xã / Phường</label>
                            <div class="auth-input-group">
                                <select class="form-select" id="ownerWardSelect" name="MaXa" required disabled>
                                    <option value="" selected>Chọn...</option>
                                </select>
                                <i class="fa-solid fa-street-view input-icon"></i>
                            </div>
                        </div>

                        <div class="col-6">
                            <label class="auth-label" for="ownerStreetInput">Địa chỉ chi tiết</label>
                            <div class="auth-input-group">
                                <input type="text" class="form-control" id="ownerStreetInput" name="DiaChiChiTiet" placeholder="Số 100, Đường..." required />
                                <i class="fa-solid fa-house input-icon"></i>
                            </div>
                        </div>
                    </div>

                    <!-- Description/Details -->
                    <div class="mb-3">
                        <label class="auth-label" for="descriptionInput">Mô tả bãi đỗ xe (Số chỗ đỗ, loại xe...)</label>
                        <textarea class="form-control bg-dark border-secondary text-white" id="descriptionInput" name="MoTa" rows="3" placeholder="Bãi đỗ gồm 50 chỗ ô tô, có hệ thống che mưa..." style="border-radius:10px;"></textarea>
                    </div>
                </div>
            </div>

            <!-- Submit Buttons -->
            <div class="row g-2 align-items-center mt-4">
                <div class="col-md-8">
                    <button type="submit" class="btn btn-primary-custom w-100 py-3" id="btnDangKyOwner" disabled>
                        GỬI ĐƠN ĐĂNG KÝ HỢP TÁC <i class="fa-solid fa-paper-plane ms-1"></i>
                    </button>
                </div>
                <div class="col-md-4 text-center text-md-end">
                    <a asp-controller="Account" asp-action="Login" class="text-muted text-decoration-none small">
                        Đã có tài khoản? <span class="text-secondary fw-semibold">Đăng nhập</span>
                    </a>
                </div>
            </div>
            <div class="mt-3 p-3 rounded" style="background:rgba(79,70,229,.08);font-size:.8rem;color:#6b7280">
                <i class="fa-solid fa-circle-info me-1 text-primary"></i>
                Sau khi gửi đơn, Admin sẽ xét duyệt và gửi thông báo về Gmail của bạn trong 1-3 ngày làm việc.
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
let ownerEmailDaXacThuc = false;

document.getElementById('btnGuiOtpOwner').addEventListener('click', async function() {
    const email = document.getElementById('ownerEmailInput').value.trim();
    if (!email || email.indexOf('@@') < 0) {
        document.getElementById('otpOwnerMsg').innerHTML = '<span class="text-danger">Vui lòng nhập Gmail hợp lệ.</span>';
        return;
    }
    this.disabled = true;
    this.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-1"></i>Đang gửi...';

    const res = await fetch('/Account/GuiOtp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, loai: 'Chu bai xe' })
    });
    const data = await res.json();

    if (data.success) {
        document.getElementById('otpOwnerMsg').innerHTML = '<span class="text-success"><i class="fa-solid fa-check me-1"></i>' + data.message + '</span>';
        document.getElementById('otpOwnerBox').style.display = 'block';
        let s = 60;
        const btn = this;
        const t = setInterval(function() {
            s--;
            btn.innerHTML = '<i class="fa-solid fa-clock me-1"></i>Gui lai (' + s + 's)';
            if (s <= 0) { clearInterval(t); btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-paper-plane me-1"></i>Gui lai OTP'; }
        }, 1000);
    } else {
        document.getElementById('otpOwnerMsg').innerHTML = '<span class="text-danger">' + data.message + '</span>';
        this.disabled = false;
        this.innerHTML = '<i class="fa-solid fa-paper-plane me-1"></i>Gui OTP';
    }
});

document.getElementById('btnXacThucOtpOwner').addEventListener('click', async function() {
    const email = document.getElementById('ownerEmailInput').value.trim();
    const otp   = document.getElementById('otpOwnerInput').value.trim();
    if (otp.length !== 6) {
        document.getElementById('otpOwnerXacThucMsg').innerHTML = '<span class="text-danger">Ma OTP gom 6 chu so.</span>';
        return;
    }
    this.disabled = true;
    this.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

    const res = await fetch('/Account/XacThucOtp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, otp: otp })
    });
    const data = await res.json();

    if (data.success) {
        ownerEmailDaXacThuc = true;
        document.getElementById('otpOwnerXacThucMsg').innerHTML = '<span class="text-success"><i class="fa-solid fa-check me-1"></i>Xac thuc thanh cong!</span>';
        document.getElementById('otpOwnerBox').style.display = 'none';
        document.getElementById('ownerEmailVerified').style.display = 'block';
        document.getElementById('ownerEmailInput').readOnly = true;
        document.getElementById('btnGuiOtpOwner').style.display = 'none';
        document.getElementById('btnDangKyOwner').disabled = false;
    } else {
        document.getElementById('otpOwnerXacThucMsg').innerHTML = '<span class="text-danger">' + data.message + '</span>';
        this.disabled = false;
        this.innerHTML = '<i class="fa-solid fa-check me-1"></i>Xac thuc';
    }
});

document.getElementById('registerOwnerForm').addEventListener('submit', function(e) {
    if (!ownerEmailDaXacThuc) {
        e.preventDefault();
        document.getElementById('otpOwnerMsg').innerHTML = '<span class="text-danger">Vui long xac thuc Gmail truoc khi gui don.</span>';
    }
});

document.getElementById('ownerProvinceSelect').addEventListener('change', async function() {
    const maTinh = this.value;
    const distSel = document.getElementById('ownerDistrictSelect');
    const wardSel = document.getElementById('ownerWardSelect');
    distSel.innerHTML = '<option value="">Chon...</option>';
    distSel.disabled = true;
    wardSel.innerHTML = '<option value="">Chon...</option>';
    wardSel.disabled = true;
    if (!maTinh) return;
    const res = await fetch('/Account/GetDistricts?provinceId=' + maTinh);
    const data = await res.json();
    data.forEach(function(d) { distSel.innerHTML += '<option value="' + d.id + '">' + d.name + '</option>'; });
    distSel.disabled = false;
});

document.getElementById('ownerDistrictSelect').addEventListener('change', async function() {
    const maHuyen = this.value;
    const wardSel = document.getElementById('ownerWardSelect');
    wardSel.innerHTML = '<option value="">Chon...</option>';
    wardSel.disabled = true;
    if (!maHuyen) return;
    const res = await fetch('/Account/GetWards?districtId=' + maHuyen);
    const data = await res.json();
    data.forEach(function(w) { wardSel.innerHTML += '<option value="' + w.id + '">' + w.name + '</option>'; });
    wardSel.disabled = false;
});
</script>
}
