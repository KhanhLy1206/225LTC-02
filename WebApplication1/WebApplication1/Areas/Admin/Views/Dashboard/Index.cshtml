@model WebApplication1.Areas.Admin.Models.DashboardViewModel
@{
    ViewData["Title"] = "Tổng Quan";
    var phanTramDay = Model.TongChoDo > 0
        ? (int)((double)Model.ChoDangDung / Model.TongChoDo * 100) : 0;
}

<!-- STAT CARDS -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card bg-white">
            <div class="stat-icon" style="background:#ede9fe;color:#7c3aed"><i class="fa-solid fa-users"></i></div>
            <div>
                <div class="stat-value">@Model.TongKhachHang.ToString("N0")</div>
                <div class="stat-label">Tổng Khách Hàng</div>
                <div class="stat-change text-muted">+ @Model.TongChuBai chủ bãi xe</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card bg-white">
            <div class="stat-icon" style="background:#dbeafe;color:#2563eb"><i class="fa-solid fa-warehouse"></i></div>
            <div>
                <div class="stat-value">@Model.TongBaiHoatDong</div>
                <div class="stat-label">Bãi Đỗ Xe Hoạt Động</div>
                <div class="stat-change text-warning">@Model.DonChoduyet.Count đơn chờ duyệt</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card bg-white">
            <div class="stat-icon" style="background:#dcfce7;color:#16a34a"><i class="fa-solid fa-money-bill-wave"></i></div>
            <div>
                <div class="stat-value">@((Model.DoanhThuThang / 1_000_000).ToString("F1"))M</div>
                <div class="stat-label">Doanh Thu Tháng (VNĐ)</div>
                <div class="stat-change text-success">Hoa hồng: @((Model.HoaHongThang / 1_000).ToString("N0"))K</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card bg-white">
            <div class="stat-icon" style="background:#fee2e2;color:#dc2626"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <div>
                <div class="stat-value">@Model.TongKhieuNaiCho</div>
                <div class="stat-label">Khiếu Nại Chờ Xử Lý</div>
                <div class="stat-change">
                    @if (Model.TongKhieuNaiCho > 0)
                    {
                        <span class="text-danger"><i class="fa-solid fa-circle-exclamation"></i> Cần xử lý</span>
                    }
                    else
                    {
                        <span class="text-success"><i class="fa-solid fa-check"></i> Không có</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- Đơn đăng ký chờ duyệt -->
    <div class="col-xl-8">
        <div class="card card-admin">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fa-solid fa-clock-rotate-left me-2 text-warning"></i>Đơn Đăng Ký Bãi Xe Chờ Duyệt</span>
                <a href="/Admin/BaiDoXe" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.DonChoduyet.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fa-solid fa-check-circle fa-2x mb-2 text-success opacity-50"></i>
                        <p class="mb-0">Không có đơn nào chờ duyệt</p>
                    </div>
                }
                else
                {
                    <table class="table admin-table mb-0">
                        <thead>
                            <tr>
                                <th>Tên Chủ Bãi</th>
                                <th>Tên Bãi</th>
                                <th>Địa Chỉ</th>
                                <th>Ngày Gửi</th>
                                <th>Thao Tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var don in Model.DonChoduyet)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@don.TenChuBai</div>
                                        <small class="text-muted">@don.Email</small>
                                    </td>
                                    <td>@don.TenBai</td>
                                    <td><small>@don.DiaChiChiTiet, @don.XaPhuong?.TenXa</small></td>
                                    <td>@don.NgayGui.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <form method="post" action="/Admin/BaiDoXe/DuyetDon" class="d-inline">
                                            <input type="hidden" name="id" value="@don.ID" />
                                            <button class="btn btn-sm btn-success me-1"><i class="fa-solid fa-check"></i> Duyệt</button>
                                        </form>
                                        <a href="/Admin/BaiDoXe" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-xmark"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Hoạt động gần đây -->
    <div class="col-xl-4">
        <div class="card card-admin h-100">
            <div class="card-header"><i class="fa-solid fa-bolt me-2 text-warning"></i>Đặt Chỗ Gần Đây</div>
            <div class="card-body p-0">
                @if (!Model.HoatDongGanDay.Any())
                {
                    <div class="text-center py-4 text-muted">Chưa có dữ liệu</div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var dc in Model.HoatDongGanDay)
                        {
                            <li class="list-group-item px-4 py-3">
                                <div class="d-flex gap-3 align-items-start">
                                    <div class="stat-icon flex-shrink-0" style="width:36px;height:36px;background:#dbeafe;color:#2563eb;border-radius:8px;font-size:.85rem">
                                        <i class="fa-solid fa-car"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold" style="font-size:.85rem">@dc.KhachHang.HoTen</div>
                                        <div class="text-muted" style="font-size:.78rem">@dc.BienSoXe — @dc.TrangThai</div>
                                        <div class="text-muted" style="font-size:.75rem">@dc.NgayDat.ToString("dd/MM HH:mm")</div>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

<!-- Thống kê nhanh -->
<div class="row g-3">
    <div class="col-md-4">
        <div class="card card-admin">
            <div class="card-header"><i class="fa-solid fa-car me-2 text-primary"></i>Lượt Đỗ Xe Hôm Nay</div>
            <div class="card-body text-center py-4">
                <div style="font-size:2.5rem;font-weight:700;color:#4f46e5">@Model.LuotDoHomNay</div>
                <div class="text-muted">lượt đặt chỗ</div>
                <div class="mt-3 d-flex justify-content-around text-center">
                    <div><div class="fw-bold text-primary">@Model.DangDoHienTai</div><small class="text-muted">Đang đỗ</small></div>
                    <div><div class="fw-bold text-warning">@Model.DaDatCho</div><small class="text-muted">Đã đặt</small></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-admin">
            <div class="card-header"><i class="fa-solid fa-circle-check me-2 text-success"></i>Tỷ Lệ Lấp Đầy Bãi</div>
            <div class="card-body text-center py-4">
                <div style="font-size:2.5rem;font-weight:700;color:#16a34a">@phanTramDay%</div>
                <div class="text-muted">trung bình toàn hệ thống</div>
                <div class="progress mt-3" style="height:8px;border-radius:4px">
                    <div class="progress-bar bg-success" style="width:@phanTramDay%"></div>
                </div>
                <small class="text-muted mt-2 d-block">@Model.ChoDangDung / @Model.TongChoDo chỗ đang sử dụng</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-admin">
            <div class="card-header"><i class="fa-solid fa-percent me-2 text-warning"></i>Hoa Hồng Thu Được</div>
            <div class="card-body text-center py-4">
                <div style="font-size:2.5rem;font-weight:700;color:#d97706">@((Model.HoaHongThang / 1_000).ToString("N0"))K</div>
                <div class="text-muted">VNĐ tháng @DateTime.Now.Month/@DateTime.Now.Year</div>
                <div class="mt-3 d-flex justify-content-around text-center">
                    <div><div class="fw-bold">@Model.TongBaiHoatDong bãi</div><small class="text-muted">Đang hoạt động</small></div>
                    <div><div class="fw-bold text-success">@Model.TongGiaoDich</div><small class="text-muted">Giao dịch</small></div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    int TongGiaoDich => Model.HoatDongGanDay.Count;
}