@{
    Layout = "~/Areas/Customer/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "Quản Lý Phương Tiện";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0 text-gradient"><i class="fa-solid fa-car me-2"></i>Danh Sách Phương Tiện Của Bạn</h4>
    <button class="btn btn-primary-custom" data-bs-toggle="modal" data-bs-target="#addVehicleModal">
        <i class="fa-solid fa-plus me-1"></i>Thêm Xe Mới
    </button>
</div>

<!-- Vehicles List Grid -->
<div class="row g-4" id="vehiclesGrid">
    <!-- Vehicle 1 -->
    <div class="col-md-6 vehicle-card-item">
        <div class="glass-card border-primary position-relative">
            <span class="badge bg-primary position-absolute top-0 end-0 m-3">MẶC ĐỊNH MỞ BARIE</span>
            <div class="d-flex align-items-center gap-4">
                <div class="rounded-circle bg-dark border border-secondary d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; font-size: 2.2rem; color: var(--primary);">
                    <i class="fa-solid fa-car"></i>
                </div>
                <div>
                    <h5 class="fw-bold text-white mb-1">Audi E-Tron GT</h5>
                    <span class="text-muted small d-block mb-1">Loại xe: **Ô tô 4-7 chỗ**</span>
                    <span class="text-muted small d-block mb-2">Sở hữu: **Cá nhân**</span>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge bg-dark font-monospace text-secondary fs-6 py-1 px-3 border border-secondary border-opacity-25">51F - 999.99</span>
                        <span class="text-muted small">Màu: Đen nhám</span>
                    </div>
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top border-secondary border-opacity-10">
                <button class="btn btn-sm btn-outline-secondary py-1 px-3">Sửa</button>
                <button class="btn btn-sm btn-outline-danger py-1 px-3 btn-delete-vehicle">Xóa</button>
            </div>
        </div>
    </div>

    <!-- Vehicle 2 -->
    <div class="col-md-6 vehicle-card-item">
        <div class="glass-card position-relative">
            <div class="d-flex align-items-center gap-4">
                <div class="rounded-circle bg-dark border border-secondary d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; font-size: 2.2rem; color: var(--secondary);">
                    <i class="fa-solid fa-motorcycle"></i>
                </div>
                <div>
                    <h5 class="fw-bold text-white mb-1">Honda SH 150i</h5>
                    <span class="text-muted small d-block mb-1">Loại xe: **Xe máy**</span>
                    <span class="text-muted small d-block mb-2">Sở hữu: **Cá nhân**</span>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge bg-dark font-monospace text-secondary fs-6 py-1 px-3 border border-secondary border-opacity-25">29A - 123.45</span>
                        <span class="text-muted small">Màu: Trắng</span>
                    </div>
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top border-secondary border-opacity-10">
                <button class="btn btn-sm btn-outline-primary py-1 px-3 btn-set-default">Đặt mặc định</button>
                <button class="btn btn-sm btn-outline-secondary py-1 px-3">Sửa</button>
                <button class="btn btn-sm btn-outline-danger py-1 px-3 btn-delete-vehicle">Xóa</button>
            </div>
        </div>
    </div>
</div>

<!-- Add Vehicle Modal -->
<div class="modal fade" id="addVehicleModal" tabindex="-1" aria-labelledby="addVehicleModalLabel" aria-hidden="true" style="backdrop-filter: blur(5px);">
    <div class="modal-dialog modal-dialog-centered text-white">
        <div class="modal-content bg-dark border-secondary p-3 shadow-2xl" style="border-radius:16px;">
            <div class="modal-header border-secondary border-opacity-10">
                <h5 class="modal-title fw-bold text-gradient" id="addVehicleModalLabel">Đăng Ký Phương Tiện Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addVehicleForm">
                    <!-- Plate Number -->
                    <div class="mb-3">
                        <label class="auth-label" for="newPlateInput">Biển Số Xe</label>
                        <div class="auth-input-group">
                            <input type="text" class="form-control" id="newPlateInput" placeholder="VD: 51H-123.45..." required pattern="^[0-9]{2}[A-Z]{1,2}-[0-9]{3,5}(\.[0-9]{2})?$" title="Biển số đúng định dạng Việt Nam, VD: 51F-123.45 hoặc 51F1-123.45" />
                            <i class="fa-solid fa-id-card input-icon"></i>
                        </div>
                    </div>

                    <!-- Vehicle Type -->
                    <div class="mb-3">
                        <label class="auth-label">Loại Phương Tiện</label>
                        <div class="auth-input-group">
                            <select class="form-select" id="newTypeSelect" required>
                                <option value="car" selected>Ô tô 4-7 chỗ</option>
                                <option value="truck">Ô tô tải / Bán tải</option>
                                <option value="moto">Xe máy / Mô tô</option>
                            </select>
                            <i class="fa-solid fa-list input-icon"></i>
                        </div>
                    </div>

                    <!-- Model/Name -->
                    <div class="mb-3">
                        <label class="auth-label" for="newNameInput">Hãng xe / Tên xe</label>
                        <div class="auth-input-group">
                            <input type="text" class="form-control" id="newNameInput" placeholder="VD: VinFast VF8, Mazda 3..." required />
                            <i class="fa-solid fa-car-side input-icon"></i>
                        </div>
                    </div>

                    <!-- Color -->
                    <div class="mb-3">
                        <label class="auth-label" for="newColorInput">Màu xe</label>
                        <div class="auth-input-group">
                            <input type="text" class="form-control" id="newColorInput" placeholder="VD: Đỏ, Trắng, Xanh lá..." required />
                            <i class="fa-solid fa-palette input-icon"></i>
                        </div>
                    </div>

                    <!-- Ownership Type -->
                    <div class="mb-3">
                        <label class="auth-label">Hình thức sở hữu</label>
                        <div class="auth-input-group">
                            <select class="form-select" id="newOwnershipSelect" required>
                                <option value="Cá nhân" selected>Cá nhân</option>
                                <option value="Doanh nghiệp">Doanh nghiệp</option>
                            </select>
                            <i class="fa-solid fa-building-user input-icon"></i>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary-custom w-100 py-3 mt-2">
                        ĐĂNG KÝ PHƯƠNG TIỆN <i class="fa-solid fa-square-plus ms-1"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Đăng ký xe mới bằng jQuery
            $('#addVehicleForm').submit(function(e) {
                e.preventDefault();

                const plate = $('#newPlateInput').val().toUpperCase();
                const type = $('#newTypeSelect').val();
                const typeText = $('#newTypeSelect option:selected').text();
                const name = $('#newNameInput').val();
                const color = $('#newColorInput').val();
                const ownership = $('#newOwnershipSelect').val();

                const icon = (type === 'moto') ? 'fa-motorcycle' : 'fa-car';
                const colorTheme = (type === 'moto') ? 'var(--secondary)' : 'var(--primary)';

                const cardHTML = `
                    <div class="col-md-6 vehicle-card-item">
                        <div class="glass-card position-relative">
                            <div class="d-flex align-items-center gap-4">
                                <div class="rounded-circle bg-dark border border-secondary d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; font-size: 2.2rem; color: ${colorTheme};">
                                    <i class="fa-solid ${icon}"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold text-white mb-1">${name}</h5>
                                    <span class="text-muted small d-block mb-1">Loại xe: **${typeText}**</span>
                                    <span class="text-muted small d-block mb-2">Sở hữu: **${ownership}**</span>
                                    <div class="d-flex gap-2 align-items-center">
                                        <span class="badge bg-dark font-monospace text-secondary fs-6 py-1 px-3 border border-secondary border-opacity-25">${plate}</span>
                                        <span class="text-muted small">Màu: ${color}</span>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top border-secondary border-opacity-10">
                                <button class="btn btn-sm btn-outline-primary py-1 px-3 btn-set-default">Đặt mặc định</button>
                                <button class="btn btn-sm btn-outline-secondary py-1 px-3">Sửa</button>
                                <button class="btn btn-sm btn-outline-danger py-1 px-3 btn-delete-vehicle">Xóa</button>
                            </div>
                        </div>
                    </div>
                `;

                $('#vehiclesGrid').append(cardHTML);
                bootstrap.Modal.getInstance(document.getElementById('addVehicleModal')).hide();
                $('#addVehicleForm')[0].reset();
                alert(`Đăng ký xe ${name} (${plate}) thành công!`);
            });

            // Đặt xe làm mặc định mở barie
            $(document).on('click', '.btn-set-default', function() {
                $('.vehicle-card-item .badge.bg-primary').remove();
                $('.vehicle-card-item .glass-card').removeClass('border-primary');
                
                const $card = $(this).closest('.glass-card');
                $card.addClass('border-primary');
                $card.append('<span class="badge bg-primary position-absolute top-0 end-0 m-3">MẶC ĐỊNH MỞ BARIE</span>');
                $(this).remove();
                
                alert('Đã thiết lập xe này làm phương tiện mở khóa mặc định!');
            });

            // Xóa xe khỏi danh sách
            $(document).on('click', '.btn-delete-vehicle', function() {
                if (confirm('Bạn có chắc chắn muốn xóa xe này khỏi tài khoản của mình không?')) {
                    $(this).closest('.vehicle-card-item').remove();
                    alert('Đã xóa phương tiện!');
                }
            });
        });
    </script>
}
