@using WebApplication1.Models.Entities
@{
    Layout = "~/Areas/Customer/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "Trò Chuyện Với Chủ Bãi";
    var chatSessions = ViewBag.ChatSessions as List<PhienChat> ?? new List<PhienChat>();
    var activeSession = ViewBag.ActiveSession as PhienChat;
    var messages = ViewBag.Messages as List<TinNhan> ?? new List<TinNhan>();
    var userAccountId = (int)(ViewBag.UserAccountId ?? 0);
}

@{
    string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "CB";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return (parts[parts.Length - 2][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper();
        }
        return name.Substring(0, Math.Min(2, name.Length)).ToUpper();
    }
}

<div class="glass-card p-0 overflow-hidden" style="height: calc(100vh - 200px); min-height: 500px; display: flex; flex-direction: column;">
    <div class="d-flex flex-column flex-md-row h-100 w-100">
        <!-- Chat Partners Sidebar -->
        <div class="d-flex flex-column bg-dark bg-opacity-20 border-end border-secondary border-opacity-10" style="width: 320px; flex-shrink: 0; height: 100%;">
            <div class="p-3 border-bottom border-secondary border-opacity-10">
                <div class="auth-input-group mb-0">
                    <input type="text" class="form-control" placeholder="Tìm kiếm liên hệ..." style="padding: 10px 15px 10px 40px;" id="contactSearch" />
                    <i class="fa-solid fa-magnifying-glass input-icon" style="left: 15px;"></i>
                </div>
            </div>

            <!-- Contacts list -->
            <div class="flex-grow-1 overflow-y-auto" style="min-height: 0;" id="contactsList">
                @if (!chatSessions.Any())
                {
                    <div class="text-center text-muted p-4 small">
                        Bạn chưa có cuộc trò chuyện nào. Hãy tìm bãi xe và nhấn biểu tượng tin nhắn để bắt đầu.
                    </div>
                }
                else
                {
                    @foreach (var session in chatSessions)
                    {
                        var partnerName = session.ChuBaiXe.TenChuBai;
                        var initials = GetInitials(partnerName);
                        var lastMsg = session.TinNhans.OrderByDescending(m => m.NgayGui).FirstOrDefault();
                        var lastMsgText = lastMsg != null ? lastMsg.NoiDung : "Chưa có tin nhắn.";
                        var lastMsgTime = lastMsg != null ? lastMsg.NgayGui.ToString("HH:mm") : "";
                        
                        bool isActive = activeSession != null && activeSession.ID == session.ID;
                        
                        <div class="d-flex align-items-center gap-3 p-3 border-bottom border-secondary border-opacity-5 contact-item @(isActive ? "active-chat-contact" : "")" 
                             style="cursor: pointer; @(isActive ? "background: rgba(6,182,212,0.1); border-left: 3px solid var(--secondary);" : "")"
                             onclick="window.location.href='/Customer/Home/Chat?activeChatId=@session.ID'"
                             data-name="@partnerName.ToLower()">
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; font-weight:700; flex-shrink: 0;">
                                @initials
                            </div>
                            <div class="flex-grow-1 min-w-0">
                                <div class="d-flex justify-content-between">
                                    <strong class="text-white text-truncate small">@partnerName</strong>
                                    <span class="text-muted" style="font-size: 0.7rem;">@lastMsgTime</span>
                                </div>
                                <p class="text-muted small mb-0 text-truncate last-msg-snippet">@lastMsgText</p>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Active Chat Window -->
        <div class="d-flex flex-column flex-grow-1 h-100" style="min-width: 0;">
            @if (activeSession == null)
            {
                <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted p-5">
                    <i class="fa-solid fa-comments mb-3" style="font-size: 4rem; color: rgba(255, 255, 255, 0.1);"></i>
                    <h5 class="text-white">Không có cuộc hội thoại nào hoạt động</h5>
                    <p class="small text-center">Hãy bắt đầu nhắn tin với chủ bãi từ trang tìm kiếm bãi đỗ xe.</p>
                </div>
            }
            else
            {
                <!-- Active Header -->
                <div class="p-3 border-bottom border-secondary border-opacity-10 d-flex justify-content-between align-items-center bg-dark bg-opacity-10" style="flex-shrink: 0;">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; font-weight:700; flex-shrink: 0;">
                            @GetInitials(activeSession.ChuBaiXe.TenChuBai)
                        </div>
                        <div>
                            <strong class="text-white d-block" style="font-size: 0.95rem;">@activeSession.ChuBaiXe.TenChuBai</strong>
                            <span class="text-success small" style="font-size: 0.8rem;"><i class="fa-solid fa-circle text-success me-1" style="font-size: 0.6rem;"></i>Trực tuyến</span>
                        </div>
                    </div>
                    <div>
                        @if (!string.IsNullOrEmpty(activeSession.ChuBaiXe.SDT))
                        {
                            <a href="tel:@activeSession.ChuBaiXe.SDT" class="btn btn-secondary-custom btn-sm" title="Gọi điện thoại"><i class="fa-solid fa-phone"></i></a>
                        }
                    </div>
                </div>

                <!-- Messages Stream Area -->
                <div class="flex-grow-1 overflow-y-auto p-3 bg-dark bg-opacity-5" id="chatMessageArea" style="min-height: 0;">
                    @foreach (var msg in messages)
                    {
                        bool isMe = msg.IDTaiKhoanGui == userAccountId;
                        if (isMe)
                        {
                            <!-- Message Right -->
                            <div class="d-flex align-items-end justify-content-end gap-2 mb-3">
                                <div class="bg-primary text-white rounded p-3" style="max-width: 70%; border-radius: 15px 15px 0 15px !important; box-shadow: 0 4px 10px var(--primary-glow);">
                                    <p class="mb-0 small">@msg.NoiDung</p>
                                    <span class="text-white-50 d-block text-end mt-1" style="font-size: 0.65rem;">@msg.NgayGui.ToString("HH:mm")</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- Message Left -->
                            <div class="d-flex align-items-end gap-2 mb-3">
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-weight:700; font-size: 0.75rem; flex-shrink: 0;">
                                    @GetInitials(activeSession.ChuBaiXe.TenChuBai)
                                </div>
                                <div class="bg-dark text-white rounded p-3" style="max-width: 70%; border-radius: 15px 15px 15px 0 !important; border: 1px solid var(--border-color);">
                                    <p class="mb-0 small">@msg.NoiDung</p>
                                    <span class="text-muted d-block text-end mt-1" style="font-size: 0.65rem;">@msg.NgayGui.ToString("HH:mm")</span>
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- Typing Indicator -->
                <div class="px-3 py-2 bg-dark bg-opacity-5 d-none" id="typingIndicator" style="flex-shrink: 0;">
                    <span class="text-muted small"><i class="fa-solid fa-ellipsis fa-fade me-1"></i> Đang nhập phản hồi...</span>
                </div>

                <!-- Input area -->
                <div class="p-3 border-top border-secondary border-opacity-10 bg-dark bg-opacity-10" style="flex-shrink: 0;">
                    <form id="chatSubmitForm" class="d-flex gap-2 mb-0">
                        <input type="text" class="form-control bg-dark text-white border-secondary" id="chatMessageInput" placeholder="Nhập tin nhắn..." required autocomplete="off" />
                        <button type="submit" class="btn btn-primary-custom px-4" style="flex-shrink: 0;">
                            Gửi <i class="fa-solid fa-paper-plane ms-1"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        $(document).ready(function() {
            const $chatArea = $('#chatMessageArea');
            if ($chatArea.length) {
                $chatArea.scrollTop($chatArea[0].scrollHeight);
            }

            const activeSessionId = @(activeSession?.ID ?? 0);
            const userAccountId = @userAccountId;
            const partnerInitials = '@(activeSession != null ? GetInitials(activeSession.ChuBaiXe.TenChuBai) : "")';

            // Filter contacts sidebar search
            $('#contactSearch').on('input', function() {
                const term = $(this).val().trim().toLowerCase();
                $('.contact-item').each(function() {
                    const name = $(this).data('name') || '';
                    if (name.includes(term)) {
                        $(this).removeClass('d-none');
                    } else {
                        $(this).addClass('d-none');
                    }
                });
            });

            function escapeHtml(text) {
                return text
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            // Establish SignalR connection
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub")
                .withAutomaticReconnect()
                .build();

            // Receive message from SignalR
            connection.on("ReceiveMessage", function(msg) {
                if (!msg || !activeSessionId) return;

                // Check if message already exists in UI
                if ($chatArea.find(`[data-msg-id="${msg.id}"]`).length > 0) return;

                const isMe = msg.senderId === userAccountId;
                let msgHTML = '';

                if (isMe) {
                    msgHTML = `
                        <div class="d-flex align-items-end justify-content-end gap-2 mb-3" data-msg-id="${msg.id}">
                            <div class="bg-primary text-white rounded p-3" style="max-width: 70%; border-radius: 15px 15px 0 15px !important; box-shadow: 0 4px 10px var(--primary-glow);">
                                <p class="mb-0 small">${escapeHtml(msg.content)}</p>
                                <span class="text-white-50 d-block text-end mt-1" style="font-size: 0.65rem;">${msg.time}</span>
                            </div>
                        </div>
                    `;
                } else {
                    msgHTML = `
                        <div class="d-flex align-items-end gap-2 mb-3" data-msg-id="${msg.id}">
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-weight:700; font-size: 0.75rem; flex-shrink: 0;">
                                ${partnerInitials}
                            </div>
                            <div class="bg-dark text-white rounded p-3" style="max-width: 70%; border-radius: 15px 15px 15px 0 !important; border: 1px solid var(--border-color);">
                                <p class="mb-0 small">${escapeHtml(msg.content)}</p>
                                <span class="text-muted d-block text-end mt-1" style="font-size: 0.65rem;">${msg.time}</span>
                            </div>
                        </div>
                    `;
                }

                $chatArea.append(msgHTML);
                $chatArea.scrollTop($chatArea[0].scrollHeight);

                // Update last message in sidebar
                $('.active-chat-contact .last-msg-snippet').text(msg.content);
                $('.active-chat-contact .text-muted').first().text(msg.time);
            });

            // Start SignalR connection
            connection.start().then(function() {
                if (activeSessionId > 0) {
                    connection.invoke("JoinSession", activeSessionId).catch(function(err) {
                        console.error("JoinSession error: ", err.toString());
                    });
                }
            }).catch(function(err) {
                console.error("SignalR connection error: ", err.toString());
            });

            // Send message
            $('#chatSubmitForm').submit(function(e) {
                e.preventDefault();
                const msgInput = $('#chatMessageInput');
                const content = msgInput.val().trim();
                if (!content || !activeSessionId) return;

                $.ajax({
                    url: '/Customer/Home/SendChatMessage',
                    type: 'POST',
                    data: {
                        sessionId: activeSessionId,
                        content: content
                    },
                    success: function(res) {
                        if (res.success) {
                            msgInput.val('');
                            // The message will be appended via the SignalR broadcast (ReceiveMessage)
                        } else {
                            alert(res.message || "Gửi tin nhắn thất bại.");
                        }
                    },
                    error: function() {
                        alert("Không thể gửi tin nhắn. Vui lòng kiểm tra lại kết nối.");
                    }
                });
            });
        });
    </script>
}
