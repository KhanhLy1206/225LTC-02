@using WebApplication1.Models.Entities
@{
    Layout = "~/Areas/Customer/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "Bảng Điều Khiển Khách Hàng";
    var activeBookings = ViewBag.ActiveBookings as List<DatCho> ?? new List<DatCho>();
    var activeVehicles = ViewBag.ActiveVehicles as List<Xe> ?? new List<Xe>();
    var recentBookings = ViewBag.RecentBookings as List<DatCho> ?? new List<DatCho>();
}

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="glass-card p-3 h-100">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted small text-uppercase">Số Dư Ví</span>
                    <h3 class="fw-bold mt-1 mb-0">@ViewBag.WalletBalance</h3>
                </div>
                <div class="fs-2 text-success"><i class="fa-solid fa-wallet"></i></div>
            </div>
            <a href="#" class="small text-secondary text-decoration-none mt-2 d-block" id="topupBtn"><i class="fa-solid fa-plus-circle me-1"></i>Nạp thêm tiền</a>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="glass-card p-3 h-100">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted small text-uppercase">Lượt Đỗ Xe</span>
                    <h3 class="fw-bold mt-1 mb-0">@ViewBag.TotalBookings</h3>
                </div>
                <div class="fs-2 text-primary"><i class="fa-solid fa-car-side"></i></div>
            </div>
            <span class="small text-muted mt-2 d-block"><i class="fa-solid fa-arrow-trend-up text-success me-1"></i>Tổng số đơn đã đặt</span>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="glass-card p-3 h-100">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted small text-uppercase">Phương Tiện</span>
                    <h3 class="fw-bold mt-1 mb-0">@ViewBag.TotalVehicles Xe</h3>
                </div>
                <div class="fs-2 text-warning"><i class="fa-solid fa-id-card-clip"></i></div>
            </div>
            <a href="/Customer/Home/Vehicles" class="small text-secondary text-decoration-none mt-2 d-block"><i class="fa-solid fa-gear me-1"></i>Quản lý xe</a>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="glass-card p-3 h-100">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted small text-uppercase">Yêu Cầu Hỗ Trợ</span>
                    <h3 class="fw-bold mt-1 mb-0">@ViewBag.TotalComplaints</h3>
                </div>
                <div class="fs-2 text-danger"><i class="fa-solid fa-circle-question"></i></div>
            </div>
            <a href="/Customer/Home/Complaints" class="small text-secondary text-decoration-none mt-2 d-block"><i class="fa-solid fa-envelope-open-text me-1"></i>Xem khiếu nại</a>
        </div>
    </div>
</div>

<!-- Active Bookings Summary & Quick Vehicle Card -->
<div class="row g-4 mb-4">
    <!-- Active Bookings Summary List -->
    <div class="col-lg-7">
        <div class="glass-card h-100 border-primary">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0 text-gradient"><i class="fa-solid fa-key me-2 text-warning"></i>Đơn Đặt Chỗ Đang Hoạt Động (@activeBookings.Count)</h5>
                <a href="/Customer/Home/Bookings" class="btn btn-outline-secondary btn-sm py-1 px-3" style="border-radius:8px;">
                    Xem Tất Cả <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>

            <p class="text-muted small">Nhấp vào nút điều khiển để hạ/dựng barie từ xa trong thời gian đỗ:</p>

            <div class="d-flex flex-column gap-3">
                @if (activeBookings.Count == 0)
                {
                    <div class="p-3 text-center text-muted small bg-dark bg-opacity-20 rounded border border-secondary border-opacity-10">
                        <i class="fa-solid fa-info-circle me-1"></i> Không có đơn đặt chỗ nào đang hoạt động.
                    </div>
                }
                else
                {
                    @foreach (var b in activeBookings)
                    {
                        <div class="p-3 bg-dark bg-opacity-40 rounded border border-secondary border-opacity-10 d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <div>
                                <strong class="d-block text-white">@(b.ChoDauXe?.KhuVuc?.BaiXe?.TenBai ?? "Bãi xe") (Chỗ @(b.ChoDauXe?.TenChoDau ?? "Chưa rõ"))</strong>
                                <span class="text-muted small"><i class="fa-solid fa-clock me-1"></i>@b.TgianBatDau.ToString("dd/MM HH:mm") - @b.TgianKetThuc.ToString("HH:mm")</span>
                                <span class="badge bg-secondary-glow text-secondary font-monospace ms-2" style="font-size:0.75rem;">@b.BienSoXe</span>
                            </div>
                            <a href="/Customer/Home/Bookings" class="btn btn-primary btn-sm py-2 px-3" style="border-radius:8px; font-weight: 500;">
                                <i class="fa-solid fa-unlock me-1"></i> Điều Khiển Barie
                            </a>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Quick Vehicle Card -->
    <div class="col-lg-5">
        <div class="glass-card h-100">
            <h5 class="fw-bold mb-3"><i class="fa-solid fa-car me-2 text-secondary"></i>Phương Tiện Đăng Ký</h5>
            <p class="text-muted small">Các phương tiện đã liên kết vào tài khoản:</p>
            
            <div class="d-flex flex-column gap-3">
                @if (activeVehicles.Count == 0)
                {
                    <div class="p-3 text-center text-muted small bg-dark bg-opacity-20 rounded border border-secondary border-opacity-10">
                        <i class="fa-solid fa-info-circle me-1"></i> Chưa đăng ký phương tiện nào. <a href="/Customer/Home/Vehicles" class="text-secondary text-decoration-none fw-bold ms-1">Thêm ngay</a>
                    </div>
                }
                else
                {
                    @for (int i = 0; i < activeVehicles.Count; i++)
                    {
                        var vehicle = activeVehicles[i];
                        bool isDefault = (i == 0); // Mock first one as default
                        <div class="d-flex align-items-center justify-content-between bg-dark p-3 rounded border border-secondary border-opacity-10 @(isDefault ? "" : "opacity-75")">
                            <div class="d-flex align-items-center gap-3">
                                <div class="fs-2 text-secondary">
                                    @if (vehicle.LoaiXe?.TenLoaiXe?.Contains("máy") == true)
                                    {
                                        <i class="fa-solid fa-motorcycle"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-car"></i>
                                    }
                                </div>
                                <div>
                                    <strong class="d-block text-white">@vehicle.TenXe</strong>
                                    <span class="text-muted small">@vehicle.LoaiXe?.TenLoaiXe</span>
                                </div>
                            </div>
                            <span class="badge @(isDefault ? "bg-primary" : "bg-secondary text-dark") font-monospace">@vehicle.BienSoXe</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Recent Booking History Table -->
<div class="glass-card mb-4">
    <h5 class="fw-bold mb-3"><i class="fa-solid fa-clock-rotate-left me-2 text-secondary"></i>Lịch Sử Đỗ Xe Gần Đây</h5>
    
    <div class="table-responsive">
        <table class="table table-dark table-hover table-borderless align-middle mb-0" style="background: transparent;">
            <thead>
                <tr class="text-muted border-bottom border-secondary border-opacity-10">
                    <th scope="col" class="pb-3">Mã đơn</th>
                    <th scope="col" class="pb-3">Bãi Đỗ Xe</th>
                    <th scope="col" class="pb-3">Chỗ đỗ</th>
                    <th scope="col" class="pb-3">Thời gian</th>
                    <th scope="col" class="pb-3">Tổng Tiền</th>
                    <th scope="col" class="pb-3">Trạng Thái</th>
                </tr>
            </thead>
            <tbody>
                @if (recentBookings.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Bạn chưa thực hiện bất kỳ giao dịch đặt chỗ nào.</td>
                    </tr>
                }
                else
                {
                    @foreach (var b in recentBookings)
                    {
                        <tr class="border-bottom border-secondary border-opacity-5">
                            <td class="font-monospace text-secondary py-3">#SP-@b.ID</td>
                            <td>@(b.ChoDauXe?.KhuVuc?.BaiXe?.TenBai ?? "Bãi xe")</td>
                            <td>@(b.ChoDauXe?.KhuVuc?.TenKhuVuc ?? "Khu") - @(b.ChoDauXe?.TenChoDau ?? "Chỗ")</td>
                            <td class="small text-muted">@b.TgianBatDau.ToString("dd/MM/yyyy HH:mm") - @b.TgianKetThuc.ToString("HH:mm")</td>
                            <td>@b.TienCoc.ToString("N0")đ</td>
                            <td>
                                @if (b.TrangThai == "Hoàn thành" || b.TrangThai == "Đã hoàn thành")
                                {
                                    <span class="badge bg-success bg-opacity-20 text-success">Đã Hoàn Thành</span>
                                    <button class="btn btn-sm btn-outline-warning ms-2 btn-review-trigger" data-id="@b.ID" data-lot="@(b.ChoDauXe?.KhuVuc?.BaiXe?.TenBai ?? "Bãi xe")" style="font-size:0.75rem; padding: 2px 6px;"><i class="fa-solid fa-star me-1"></i>Đánh giá</button>
                                }
                                else if (b.TrangThai == "Đã đặt")
                                {
                                    <span class="badge bg-info bg-opacity-20 text-info">Sắp Diễn Ra</span>
                                }
                                else if (b.TrangThai == "Đang đỗ")
                                {
                                    <span class="badge bg-warning bg-opacity-20 text-warning">Đang Đỗ</span>
                                }
                                else if (b.TrangThai == "Đã hủy")
                                {
                                    <span class="badge bg-danger bg-opacity-20 text-danger">Đã Hủy</span>
                                }
                                else if (b.TrangThai == "Chờ thanh toán")
                                {
                                    <span class="badge bg-warning bg-opacity-20 text-warning">Chờ Thanh Toán</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-20 text-white">@b.TrangThai</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Rating Modal -->
<div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true" style="backdrop-filter: blur(5px);">
    <div class="modal-dialog modal-dialog-centered text-white">
        <div class="modal-content bg-dark border-secondary p-3 shadow-2xl" style="border-radius:16px;">
            <div class="modal-header border-secondary border-opacity-10">
                <h5 class="modal-title fw-bold text-gradient" id="reviewModalLabel">Đánh Giá Bãi Đỗ Xe</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small">Cảm ơn bạn đã đỗ xe! Đánh giá của bạn sẽ giúp chủ bãi xe cải thiện dịch vụ tốt hơn.</p>
                <h6 class="fw-bold mb-3" id="reviewLotName">Tên bãi đỗ</h6>
                
                <form id="reviewSubmitForm">
                    <input type="hidden" id="reviewBookingId" />
                    <!-- Rating Star Select -->
                    <div class="mb-3 text-center">
                        <label class="auth-label mb-2 d-block">Điểm đánh giá (Sao)</label>
                        <div class="d-inline-flex gap-2 fs-3 text-warning" id="starContainer">
                            <i class="fa-solid fa-star star-btn cursor-pointer" data-val="1"></i>
                            <i class="fa-solid fa-star star-btn cursor-pointer" data-val="2"></i>
                            <i class="fa-solid fa-star star-btn cursor-pointer" data-val="3"></i>
                            <i class="fa-solid fa-star star-btn cursor-pointer" data-val="4"></i>
                            <i class="fa-solid fa-star star-btn cursor-pointer" data-val="5"></i>
                        </div>
                        <input type="hidden" id="reviewRatingVal" value="5" required />
                    </div>

                    <!-- Comment area -->
                    <div class="mb-4">
                        <label class="auth-label" for="reviewComment">Nội dung bình luận</label>
                        <textarea class="form-control bg-dark border-secondary text-white" id="reviewComment" rows="3" placeholder="Nhập cảm nhận của bạn về chất lượng bãi đỗ..." required style="border-radius:10px;"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary-custom w-100 py-3">
                        GỬI ĐÁNH GIÁ <i class="fa-solid fa-paper-plane ms-1"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#topupBtn').click(function(e) {
                e.preventDefault();
                alert('Tính năng liên kết Ví / Nạp tiền qua Cổng thanh toán VNPAY/MoMo sẽ được cấu hình sau ở Controller.');
            });

            // --- Xử lý đánh giá bãi đỗ ---
            let selectedStars = 5;
            $(document).on('click', '.star-btn', function() {
                selectedStars = parseInt($(this).data('val'));
                $('#reviewRatingVal').val(selectedStars);
                
                $('.star-btn').each(function(index) {
                    if (index < selectedStars) {
                        $(this).removeClass('fa-regular').addClass('fa-solid');
                    } else {
                        $(this).removeClass('fa-solid').addClass('fa-regular');
                    }
                });
            });

            let activeTriggerBtn = null;
            $(document).on('click', '.btn-review-trigger', function() {
                activeTriggerBtn = $(this);
                const lotName = $(this).data('lot');
                const bookingId = $(this).data('id');

                $('#reviewLotName').text(lotName);
                $('#reviewBookingId').val(bookingId);
                $('#reviewComment').val('');
                
                selectedStars = 5;
                $('#reviewRatingVal').val(5);
                $('.star-btn').removeClass('fa-regular').addClass('fa-solid');

                const myModal = new bootstrap.Modal(document.getElementById('reviewModal'));
                myModal.show();
            });

            $('#reviewSubmitForm').submit(function(e) {
                e.preventDefault();
                const bookingId = $('#reviewBookingId').val();
                const stars = $('#reviewRatingVal').val();
                const comment = $('#reviewComment').val();

                $.ajax({
                    url: '/Customer/Home/SubmitReview',
                    type: 'POST',
                    data: {
                        bookingId: bookingId,
                        rating: stars,
                        comment: comment
                    },
                    success: function(response) {
                        if (response.success) {
                            alert(`Gửi đánh giá thành công cho đơn hàng #${bookingId}!`);
                            bootstrap.Modal.getInstance(document.getElementById('reviewModal')).hide();
                            if (activeTriggerBtn) {
                                activeTriggerBtn.remove();
                            }
                        } else {
                            alert(response.message || 'Lỗi khi gửi đánh giá.');
                        }
                    },
                    error: function() {
                        alert('Đã xảy ra lỗi khi gửi yêu cầu lên máy chủ.');
                    }
                });
            });
        });
    </script>
}
