</div>

<!-- Active Bookings Summary & Quick Vehicle Card -->
<div class="row g-4 mb-4">
    <!-- Active Bookings Summary List -->
    <div class="col-lg-7">
        <div class="glass-card h-100 border-primary">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0 text-gradient"><i class="fa-solid fa-key me-2 text-warning"></i>Đơn Đặt Chỗ Đang Hoạt Động (2)</h5>
                <a href="/Customer/Home/Bookings" class="btn btn-outline-secondary btn-sm py-1 px-3" style="border-radius:8px;">
                    Xem Tất Cả <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>

            <p class="text-muted small">Bạn đang có nhiều đơn đỗ xe hoạt động cùng lúc. Nhấp vào nút điều khiển để hạ/dựng barie từ xa:</p>

            <div class="d-flex flex-column gap-3">
                <!-- Booking 1 -->
                <div class="p-3 bg-dark bg-opacity-40 rounded border border-secondary border-opacity-10 d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <div>
                        <strong class="d-block text-white">Bãi đỗ Xe Công Nghệ Quang Trung (Chỗ A-03)</strong>
                        <span class="text-muted small"><i class="fa-solid fa-clock me-1"></i>Hôm nay, 19:00 - 23:00</span>
                        <span class="badge bg-secondary-glow text-secondary font-monospace ms-2" style="font-size:0.75rem;">51F - 999.99</span>
                    </div>
                    <a href="/Customer/Home/Bookings" class="btn btn-primary btn-sm py-2 px-3" style="border-radius:8px; font-weight: 500;">
                        <i class="fa-solid fa-unlock me-1"></i> Điều Khiển Barie
                    </a>
                </div>

                <!-- Booking 2 -->
                <div class="p-3 bg-dark bg-opacity-40 rounded border border-secondary border-opacity-10 d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <div>
                        <strong class="d-block text-white">Bãi đỗ Xe Thông Minh Quận 1 (Chỗ B-12)</strong>
                        <span class="text-muted small"><i class="fa-solid fa-clock me-1"></i>Hôm nay, 18:00 - 22:00</span>
                        <span class="badge bg-secondary-glow text-secondary font-monospace ms-2" style="font-size:0.75rem;">29A - 123.45</span>
                    </div>
                    <a href="/Customer/Home/Bookings" class="btn btn-primary btn-sm py-2 px-3" style="border-radius:8px; font-weight: 500;">
                        <i class="fa-solid fa-unlock me-1"></i> Điều Khiển Barie
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Vehicle Card -->
    <div class="col-lg-5">
        <div class="glass-card h-100">
            <h5 class="fw-bold mb-3"><i class="fa-solid fa-car me-2 text-secondary"></i>Phương Tiện Hoạt Động</h5>
            <p class="text-muted small">Xe mặc định dùng để mở barie khi ra vào bãi đỗ:</p>
            
            <div class="d-flex align-items-center justify-content-between bg-dark p-3 rounded mb-3 border border-secondary border-opacity-10">
                <div class="d-flex align-items-center gap-3">
                    <div class="fs-2 text-secondary"><i class="fa-solid fa-car"></i></div>
                    <div>
                        <strong class="d-block text-white">Audi E-Tron GT</strong>
                        <span class="text-muted small">Xe Ô tô con</span>
                    </div>
                </div>
                <span class="badge bg-primary font-monospace">51F - 999.99</span>
            </div>

            <div class="d-flex align-items-center justify-content-between bg-dark p-3 rounded border border-secondary border-opacity-10 opacity-75">
                <div class="d-flex align-items-center gap-3">
                    <div class="fs-2 text-muted"><i class="fa-solid fa-motorcycle"></i></div>
                    <div>
                        <strong class="d-block text-muted">Honda SH 150i</strong>
                        <span class="text-muted small">Xe Máy</span>
                    </div>
                </div>
                <span class="badge bg-secondary font-monospace text-dark">29A - 123.45</span>
            </div>
        </div>
    </div>
</div>

<!-- Recent Booking History Table -->
<div class="glass-card mb-4">
    <h5 class="fw-bold mb-3"><i class="fa-solid fa-clock-rotate-left me-2 text-secondary"></i>Lịch Sử Đỗ Xe Gần Đây</h5>
    
    <div class="table-responsive">
        <table class="table table-dark table-hover table-borderless align-middle mb-0" style="background: transparent;">
            <thead>
                <tr class="text-muted border-bottom border-secondary border-opacity-10">
                    <th scope="col" class="pb-3">Mã đơn</th>
                    <th scope="col" class="pb-3">Bãi Đỗ Xe</th>
                    <th scope="col" class="pb-3">Chỗ đỗ</th>
                    <th scope="col" class="pb-3">Thời gian</th>
                    <th scope="col" class="pb-3">Tổng Tiền</th>
                    <th scope="col" class="pb-3">Trạng Thái</th>
                </tr>
            </thead>
            <tbody>
                <tr class="border-bottom border-secondary border-opacity-5">
                    <td class="font-monospace text-secondary py-3">#SP-4491</td>
                    <td>Bãi Xe Thông Minh Quận 1</td>
                    <td>Khu B - B-12</td>
                    <td class="small text-muted">Hôm qua, 14:00 - 16:00</td>
                    <td>40,000đ</td>
                    <td>
                        <span class="badge bg-success bg-opacity-20 text-success">Đã Hoàn Thành</span>
                        <button class="btn btn-sm btn-outline-warning ms-2 btn-review-trigger" data-id="SP-4491" data-lot="Bãi Xe Thông Minh Quận 1" style="font-size:0.75rem; padding: 2px 6px;"><i class="fa-solid fa-star me-1"></i>Đánh giá</button>
                    </td>
                </tr>
                <tr class="border-bottom border-secondary border-opacity-5">
                    <td class="font-monospace text-secondary py-3">#SP-4310</td>
                    <td>Bãi đỗ Xe Công Nghệ Quang Trung</td>
                    <td>Khu A - A-03</td>
                    <td class="small text-muted">20/05/2026, 08:00 - 11:30</td>
                    <td>70,000đ</td>
                    <td>
                        <span class="badge bg-success bg-opacity-20 text-success">Đã Hoàn Thành</span>
                        <button class="btn btn-sm btn-outline-warning ms-2 btn-review-trigger" data-id="SP-4310" data-lot="Bãi đỗ Xe Công Nghệ Quang Trung" style="font-size:0.75rem; padding: 2px 6px;"><i class="fa-solid fa-star me-1"></i>Đánh giá</button>
                    </td>
                </tr>
                <tr class="border-bottom border-secondary border-opacity-5">
                    <td class="font-monospace text-secondary py-3">#SP-4209</td>
                    <td>Bãi Xe Tòa Nhà Landmark 81</td>
                    <td>Tầng B2 - C-09</td>
                    <td class="small text-muted">15/05/2026, 18:00 - 21:00</td>
                    <td>90,000đ</td>
                    <td>
                        <span class="badge bg-success bg-opacity-20 text-success">Đã Hoàn Thành</span>
                        <button class="btn btn-sm btn-outline-warning ms-2 btn-review-trigger" data-id="SP-4209" data-lot="Bãi Xe Tòa Nhà Landmark 81" style="font-size:0.75rem; padding: 2px 6px;"><i class="fa-solid fa-star me-1"></i>Đánh giá</button>
                    </td>
                </tr>
                <tr>
                    <td class="font-monospace text-secondary py-3">#SP-4190</td>
                    <td>Bãi Đỗ Xe Quận 10</td>
                    <td>Khu C - C-02</td>
                    <td class="small text-muted">12/05/2026, 10:00 - 12:00</td>
                    <td>30,000đ</td>
                    <td><span class="badge bg-danger bg-opacity-20 text-danger">Đã Hủy</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Rating Modal -->
<div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true" style="backdrop-filter: blur(5px);">
    <div class="modal-dialog modal-dialog-centered text-white">
        <div class="modal-content bg-dark border-secondary p-3 shadow-2xl" style="border-radius:16px;">
            <div class="modal-header border-secondary border-opacity-10">
                <h5 class="modal-title fw-bold text-gradient" id="reviewModalLabel">Đánh Giá Bãi Đỗ Xe</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small">Cảm ơn bạn đã đỗ xe! Đánh giá của bạn sẽ giúp chủ bãi xe cải thiện dịch vụ tốt hơn.</p>
                <h6 class="fw-bold mb-3" id="reviewLotName">Tên bãi đỗ</h6>
                
                <form id="reviewSubmitForm">
                    <input type="hidden" id="reviewBookingId" />
                    <!-- Rating Star Select -->
                    <div class="mb-3 text-center">
                        <label class="auth-label mb-2 d-block">Điểm đánh giá (Sao)</label>
                        <div class="d-inline-flex gap-2 fs-3 text-warning" id="starContainer">
                            <i class="fa-solid fa-star star-btn cursor-pointer" data-val="1"></i>
                            <i class="fa-solid fa-star star-btn cursor-pointer" data-val="2"></i>
                            <i class="fa-solid fa-star star-btn cursor-pointer" data-val="3"></i>
                            <i class="fa-solid fa-star star-btn cursor-pointer" data-val="4"></i>
                            <i class="fa-solid fa-star star-btn cursor-pointer" data-val="5"></i>
                        </div>
                        <input type="hidden" id="reviewRatingVal" value="5" required />
                    </div>

                    <!-- Comment area -->
                    <div class="mb-4">
                        <label class="auth-label" for="reviewComment">Nội dung bình luận</label>
                        <textarea class="form-control bg-dark border-secondary text-white" id="reviewComment" rows="3" placeholder="Nhập cảm nhận của bạn về chất lượng bãi đỗ..." required style="border-radius:10px;"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary-custom w-100 py-3">
                        GỬI ĐÁNH GIÁ <i class="fa-solid fa-paper-plane ms-1"></i>
                      </button>
                  </form>
              </div>
          </div>
      </div>
  </div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#topupBtn').click(function(e) {
                e.preventDefault();
                alert('Tính năng liên kết Ví / Nạp tiền qua Cổng thanh toán VNPAY/MoMo sẽ được cấu hình sau ở Controller.');
            });

            // --- Xử lý đánh giá bãi đỗ ---
            let selectedStars = 5;
            $(document).on('click', '.star-btn', function() {
                selectedStars = parseInt($(this).data('val'));
                $('#reviewRatingVal').val(selectedStars);
                
                $('.star-btn').each(function(index) {
                    if (index < selectedStars) {
                        $(this).removeClass('fa-regular').addClass('fa-solid');
                    } else {
                        $(this).removeClass('fa-solid').addClass('fa-regular');
                    }
                });
            });

            let activeTriggerBtn = null;
            $(document).on('click', '.btn-review-trigger', function() {
                activeTriggerBtn = $(this);
                const lotName = $(this).data('lot');
                const bookingId = $(this).data('id');

                $('#reviewLotName').text(lotName);
                $('#reviewBookingId').val(bookingId);
                $('#reviewComment').val('');
                
                selectedStars = 5;
                $('#reviewRatingVal').val(5);
                $('.star-btn').removeClass('fa-regular').addClass('fa-solid');

                const myModal = new bootstrap.Modal(document.getElementById('reviewModal'));
                myModal.show();
            });

            $('#reviewSubmitForm').submit(function(e) {
                e.preventDefault();
                const bookingId = $('#reviewBookingId').val();
                const stars = $('#reviewRatingVal').val();
                const comment = $('#reviewComment').val();

                alert(`Gửi đánh giá thành công cho đơn hàng #${bookingId}!\n- Điểm số: ${stars} sao\n- Nội dung: ${comment}\n\nThông tin đã được đồng bộ với bảng DanhGiaBinhLuan.`);
                
                bootstrap.Modal.getInstance(document.getElementById('reviewModal')).hide();
                
                if (activeTriggerBtn) {
                    activeTriggerBtn.remove();
                }
            });
        });
    </script>
}
