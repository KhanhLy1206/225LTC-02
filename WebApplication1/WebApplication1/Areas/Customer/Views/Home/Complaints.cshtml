@{
    Layout = "~/Areas/Customer/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "Khiếu Nại & Hỗ Trợ";
}

<div class="row g-4">
    <!-- Complaint Form -->
    <div class="col-lg-5">
        <div class="glass-card h-100">
            <h5 class="fw-bold mb-3 text-gradient"><i class="fa-solid fa-pen-to-square text-secondary me-2"></i>Gửi Khiếu Nại Mới</h5>
            <p class="text-muted small">Nếu bạn gặp sự cố kỹ thuật hoặc tranh chấp tài chính liên quan đến đơn đỗ xe, hãy gửi khiếu nại. Ban quản trị hệ thống sẽ xử lý và phản hồi trong 24 giờ.</p>
            
            <form id="complaintForm" enctype="multipart/form-data">
                <!-- Select Booking -->
                <div class="mb-3">
                    <label class="auth-label">Chọn Đơn Đỗ Xe Gặp Sự Cố</label>
                    <select class="form-select bg-dark text-white border-secondary" id="complaintBookingId" required>
                        <option value="" selected>-- Chọn đơn đặt chỗ --</option>
                        <option value="#SP-4491">#SP-4491 - Bãi Xe Quận 1 (40,000đ)</option>
                        <option value="#SP-4310">#SP-4310 - Bãi Xe Quang Trung (70,000đ)</option>
                        <option value="#SP-4209">#SP-4209 - Landmark 81 (90,000đ)</option>
                    </select>
                </div>

                <!-- Category -->
                <div class="mb-3">
                    <label class="auth-label">Loại Sự Cố</label>
                    <select class="form-select bg-dark text-white border-secondary" id="complaintCategory" required>
                        <option value="Lỗi thiết bị Barie">Lỗi không tự điều khiển mở/đóng được Barie</option>
                        <option value="Sai lệch chi phí">Sai lệch tiền tài khoản khấu trừ</option>
                        <option value="Thái độ chủ bãi">Tranh chấp / Thái độ với chủ bãi xe</option>
                        <option value="Khác">Lý do khác...</option>
                    </select>
                </div>

                <!-- Description -->
                <div class="mb-3">
                    <label class="auth-label" for="complaintContent">Chi tiết sự cố</label>
                    <textarea class="form-control bg-dark border-secondary text-white" id="complaintContent" rows="4" placeholder="Mô tả cụ thể thời gian, vị trí chỗ đỗ và diễn biến sự cố để admin xử lý nhanh nhất..." required style="border-radius:10px;"></textarea>
                </div>

                <!-- File Attachment -->
                <div class="mb-4">
                    <label class="auth-label" for="proofFile">Hình ảnh/Tài liệu minh chứng (Nếu có)</label>
                    <input type="file" class="form-control bg-dark text-white border-secondary" id="proofFile" accept="image/*" style="border-radius:10px;" />
                </div>

                <button type="submit" class="btn btn-primary-custom w-100 py-3">
                    GỬI ĐƠN KHIẾU NẠI <i class="fa-solid fa-paper-plane ms-1"></i>
                </button>
            </form>
        </div>
    </div>

    <!-- Complaint History -->
    <div class="col-lg-7">
        <div class="glass-card h-100">
            <h5 class="fw-bold mb-3"><i class="fa-solid fa-history text-secondary me-2"></i>Lịch Sử Khiếu Nại Của Bạn</h5>
            <p class="text-muted small">Theo dõi tiến độ giải quyết các khiếu nại đã gửi:</p>

            <div class="table-responsive">
                <table class="table table-dark table-hover table-borderless align-middle" style="background: transparent;">
                    <thead>
                        <tr class="text-muted border-bottom border-secondary border-opacity-10">
                            <th scope="col" class="pb-3">Mã khiếu nại</th>
                            <th scope="col" class="pb-3">Mã đơn</th>
                            <th scope="col" class="pb-3">Loại sự cố</th>
                            <th scope="col" class="pb-3">Ngày gửi</th>
                            <th scope="col" class="pb-3">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody id="complaintsTableBody">
                        <tr class="border-bottom border-secondary border-opacity-5">
                            <td class="font-monospace text-secondary py-3">#KN-1022</td>
                            <td class="font-monospace">#SP-4209</td>
                            <td class="small">Lỗi thiết bị Barie</td>
                            <td class="small text-muted">15/05/2026</td>
                            <td><span class="badge bg-success bg-opacity-20 text-success">Đã giải quyết</span></td>
                        </tr>
                        <!-- Details of resolved complaints -->
                        <tr class="bg-dark bg-opacity-20">
                            <td colspan="5" class="p-3 text-muted small" style="border-radius:8px;">
                                <div class="mb-1"><strong>Nội dung:</strong> Tôi đến chỗ đỗ đúng giờ nhưng barie bị kẹt, chủ bãi xe đã mở tay. Đơn vẫn tính tiền bình thường nhưng tôi mất 15 phút chờ đợi.</div>
                                <div><i class="fa-solid fa-reply text-secondary me-1"></i><strong>Admin phản hồi:</strong> Đã xác nhận sự cố kỹ thuật của bãi đỗ vào thời điểm đó. Hệ thống đã hoàn lại 50% tiền cọc (45,000đ) vào ví của bạn làm bồi thường.</div>
                            </td>
                        </tr>

                        <tr class="border-bottom border-secondary border-opacity-5">
                            <td class="font-monospace text-secondary py-3">#KN-1051</td>
                            <td class="font-monospace">#SP-4491</td>
                            <td class="small">Sai lệch chi phí</td>
                            <td class="small text-muted">Hôm qua</td>
                            <td><span class="badge bg-warning bg-opacity-20 text-warning">Chờ xử lý</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Xử lý gửi khiếu nại qua jquery
            $('#complaintForm').submit(function(e) {
                e.preventDefault();

                const bookingId = $('#complaintBookingId').val();
                const category = $('#complaintCategory').val();
                const content = $('#complaintContent').val();
                
                const complaintId = "#KN-" + Math.floor(1000 + Math.random() * 9000);
                const today = new Date().toLocaleDateString('vi-VN');

                const newRowHTML = `
                    <tr class="border-bottom border-secondary border-opacity-5">
                        <td class="font-monospace text-secondary py-3">${complaintId}</td>
                        <td class="font-monospace">${bookingId}</td>
                        <td class="small">${category}</td>
                        <td class="small text-muted">${today}</td>
                        <td><span class="badge bg-warning bg-opacity-20 text-warning">Chờ xử lý</span></td>
                    </tr>
                `;

                // Thêm hàng mới vào đầu bảng
                $('#complaintsTableBody').prepend(newRowHTML);

                // Reset form
                $('#complaintForm')[0].reset();

                alert(`Gửi khiếu nại thành công!\nMã khiếu nại: ${complaintId}\nBan quản trị hệ thống đã tiếp nhận sự cố.`);
            });
        });
    </script>
}
