@using WebApplication1.Models.Entities
@{
    Layout = "~/Areas/Customer/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "Tìm Kiếm & Đặt Chỗ Đỗ Xe";
    var parkingLots = ViewBag.ParkingLots; // dynamic or cast
    var vehicles = ViewBag.Vehicles as List<Xe> ?? new List<Xe>();
}
<style>
/* Style for Visual Spot Grid */
.spot-grid-visual {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 12px;
    margin-bottom: 20px;
    max-height: 250px;
    overflow-y: auto;
    padding: 5px;
}

.spot-card-visual {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    padding: 10px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
}

.spot-card-visual:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.1);
}

.spot-card-visual.selected {
    border-color: #06b6d4 !important;
    background: rgba(6, 182, 212, 0.2) !important;
    box-shadow: 0 0 10px rgba(6, 182, 212, 0.4);
}

/* Spot states */
.spot-card-visual.state-trong {
    border-left: 4px solid #10b981; /* Green */
}
.spot-card-visual.state-trong .status-dot {
    background: #10b981;
}

.spot-card-visual.state-dangdo {
    border-left: 4px solid #f59e0b; /* Orange */
    cursor: not-allowed;
    opacity: 0.65;
}
.spot-card-visual.state-dangdo .status-dot {
    background: #f59e0b;
}

.spot-card-visual.state-dadat {
    border-left: 4px solid #3b82f6; /* Blue */
    cursor: not-allowed;
    opacity: 0.65;
}
.spot-card-visual.state-dadat .status-dot {
    background: #3b82f6;
}

.spot-card-visual.state-baotri {
    border-left: 4px solid #ef4444; /* Red */
    cursor: not-allowed;
    opacity: 0.5;
}
.spot-card-visual.state-baotri .status-dot {
    background: #ef4444;
}

.status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
    margin-right: 5px;
}
</style>

<!-- Search Filter Box -->
<div class="glass-card mb-4">
    <h5 class="fw-bold mb-3"><i class="fa-solid fa-magnifying-glass text-secondary me-2"></i>Bộ Lọc Tìm Kiếm Bãi Xe</h5>
    <form id="searchForm">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="auth-label">Từ khóa tìm kiếm (Tên bãi, địa chỉ...)</label>
                <input type="text" class="form-control bg-dark text-white border-secondary" id="searchKeyword" placeholder="Nhập tên bãi hoặc địa chỉ cần tìm..." style="border-radius:10px;" />
            </div>
            <div class="col-md-4">
                <label class="auth-label">Loại Xe Hỗ Trợ</label>
                <select class="form-select bg-dark text-white border-secondary" id="searchVehicleType" style="border-radius:10px;">
                    <option value="all" selected>Tất cả phương tiện</option>
                    <option value="oto">Có hỗ trợ Ô tô</option>
                    <option value="xemay">Có hỗ trợ Xe máy</option>
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary-custom w-100 py-2">
                    Lọc Kết Quả <i class="fa-solid fa-filter ms-1"></i>
                </button>
            </div>
        </div>
    </form>
</div>

<!-- Parking Lot Lists -->
<div class="row g-4" id="parkingLotContainer">
    @if (parkingLots == null)
    {
        <div class="col-12 text-center text-muted py-5">Đang tải danh sách bãi đỗ xe...</div>
    }
    else
    {
        foreach (var item in parkingLots)
        {
            var lot = (BaiXe)item.GetType().GetProperty("Lot").GetValue(item, null);
            var carPrice = (decimal)item.GetType().GetProperty("CarPrice").GetValue(item, null);
            var motoPrice = (decimal)item.GetType().GetProperty("MotoPrice").GetValue(item, null);
            var spotsLeft = (int)item.GetType().GetProperty("SpotsLeft").GetValue(item, null);

            string lotType = "both";
            if (carPrice > 0 && motoPrice == 0) lotType = "oto";
            else if (carPrice == 0 && motoPrice > 0) lotType = "xemay";

            string imgUrl = !string.IsNullOrEmpty(lot.HinhAnh) ? lot.HinhAnh : "https://images.unsplash.com/photo-1573348722427-f1d6819fdf98?auto=format&fit=crop&w=500&q=80";

            <div class="col-md-6 col-xxl-4 parking-card-item" data-name="@lot.TenBai.ToLower()" data-address="@lot.DiaChiChiTiet.ToLower()" data-type="@lotType">
                <div class="glass-card h-100 d-flex flex-column">
                    <div class="position-relative mb-3">
                        @if (spotsLeft > 0)
                        {
                            <span class="badge bg-success position-absolute top-0 start-0 m-2">Còn: @spotsLeft chỗ trống</span>
                        }
                        else
                        {
                            <span class="badge bg-danger position-absolute top-0 start-0 m-2">Hết chỗ</span>
                        }
                        <img src="@imgUrl" alt="@lot.TenBai" class="img-fluid rounded w-100" style="height: 180px; object-fit: cover; border: 1px solid var(--border-color);" />
                    </div>

                    <h5 class="fw-bold mb-1">@lot.TenBai</h5>
                    <p class="text-muted small mb-2"><i class="fa-solid fa-location-dot me-1"></i>@lot.DiaChiChiTiet</p>
                    
                    <div class="d-flex gap-2 mb-3 flex-wrap">
                        @if (carPrice > 0)
                        {
                            <span class="badge bg-dark border border-secondary text-muted"><i class="fa-solid fa-car text-primary me-1"></i>@carPrice.ToString("N0")đ/h</span>
                        }
                        @if (motoPrice > 0)
                        {
                            <span class="badge bg-dark border border-secondary text-muted"><i class="fa-solid fa-motorcycle text-warning me-1"></i>@motoPrice.ToString("N0")đ/h</span>
                        }
                        <span class="ms-auto text-warning small"><i class="fa-solid fa-star me-1"></i>4.8 (Thỏa thuận)</span>
                    </div>

                    <div class="mt-auto">
                        @if (spotsLeft > 0)
                        {
                            <div class="d-flex gap-2">
                                <button class="btn btn-secondary-custom flex-grow-1 btn-book-trigger" 
                                        data-id="@lot.ID"
                                        data-name="@lot.TenBai"
                                        data-address="@lot.DiaChiChiTiet"
                                        data-car-price="@((int)carPrice)"
                                        data-moto-price="@((int)motoPrice)">
                                    Chi Tiết & Đặt Chỗ <i class="fa-solid fa-arrow-right ms-1"></i>
                                </button>
                                <a href="/Customer/Home/Chat?ownerId=@lot.IDChuBai" class="btn btn-outline-secondary d-flex align-items-center justify-content-center px-3" title="Nhắn tin với chủ bãi" style="border-radius: 10px;">
                                    <i class="fa-solid fa-comments"></i>
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex gap-2">
                                <button class="btn btn-secondary flex-grow-1" disabled>
                                    Bãi Xe Đầy Chỗ <i class="fa-solid fa-ban ms-1"></i>
                                </button>
                                <a href="/Customer/Home/Chat?ownerId=@lot.IDChuBai" class="btn btn-outline-secondary d-flex align-items-center justify-content-center px-3" title="Nhắn tin với chủ bãi" style="border-radius: 10px;">
                                    <i class="fa-solid fa-comments"></i>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Booking Modal -->
<div class="modal fade" id="bookingModal" tabindex="-1" aria-labelledby="bookingModalLabel" aria-hidden="true" style="backdrop-filter: blur(5px);">
    <div class="modal-dialog modal-dialog-centered modal-lg text-white">
        <div class="modal-content bg-dark border-secondary p-3 shadow-2xl" style="border-radius:16px;">
            <div class="modal-header border-secondary border-opacity-10">
                <h5 class="modal-title fw-bold text-gradient" id="bookingModalLabel">Đặt Chỗ Đỗ Xe Trực Quan</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <!-- Left Column: Visual Map -->
                    <div class="col-md-7 border-end border-secondary border-opacity-15 pe-md-4">
                        <h6 class="fw-bold mb-1" id="modalLotName">Tên bãi đỗ</h6>
                        <p class="text-muted small mb-3" id="modalLotAddress"><i class="fa-solid fa-location-dot me-1"></i>Địa chỉ bãi</p>

                        <!-- Area selection tabs -->
                        <div class="mb-3">
                            <label class="auth-label mb-2">Khu Vực Bãi Xe (Lọc theo xe)</label>
                            <div class="d-flex flex-wrap gap-2" id="modalAreaContainer">
                                <!-- Area buttons will be loaded here -->
                            </div>
                        </div>

                        <!-- Grid map -->
                        <div class="mb-3">
                            <label class="auth-label mb-2">Sơ đồ vị trí đỗ (Chọn ô màu xanh lá)</label>
                            <div class="spot-grid-visual" id="modalSpotGrid">
                                <!-- Spots will load here -->
                            </div>
                            <div class="d-flex justify-content-center gap-3 mt-2 small text-muted">
                                <span><span class="status-dot" style="background: #10b981;"></span>Trống</span>
                                <span><span class="status-dot" style="background: #f59e0b;"></span>Đang đỗ</span>
                                <span><span class="status-dot" style="background: #3b82f6;"></span>Đã đặt</span>
                                <span><span class="status-dot" style="background: #ef4444;"></span>Bảo trì</span>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Booking Form -->
                    <div class="col-md-5 ps-md-4 mt-4 mt-md-0">
                        <form id="modalBookingForm">
                            <input type="hidden" id="modalLotId" />
                            <input type="hidden" id="modalSelectSpot" /> <!-- Selected spot ID -->

                            <!-- Select Vehicle -->
                            <div class="mb-3">
                                <label class="auth-label">Phương Tiện Đăng Ký</label>
                                <select class="form-select bg-dark text-white border-secondary" id="modalSelectVehicle" required style="border-radius:10px;">
                                    @if (vehicles.Count == 0)
                                    {
                                        <option value="">-- Bạn chưa đăng ký xe nào --</option>
                                    }
                                    else
                                    {
                                        foreach (var v in vehicles)
                                        {
                                            string typeStr = v.LoaiXe?.TenLoaiXe?.Contains("máy") == true ? "moto" : "car";
                                            <option value="@v.BienSoXe" data-type="@typeStr">@v.TenXe (@v.BienSoXe)</option>
                                        }
                                    }
                                </select>
                                @if (vehicles.Count == 0)
                                {
                                    <span class="small text-danger mt-1 d-block">Vui lòng <a href="/Customer/Home/Vehicles" class="text-warning text-decoration-none fw-bold">thêm xe</a> trước khi đặt.</span>
                                }
                            </div>

                            <!-- Rental Type Selection -->
                            <div class="mb-3">
                                <label class="auth-label">Hình Thức Thuê</label>
                                <select class="form-select bg-dark text-white border-secondary" id="modalRentalType" required style="border-radius:10px;">
                                    <option value="hour">Theo giờ</option>
                                    <option value="overnight">Qua đêm</option>
                                    <option value="month">Theo tháng (30 ngày)</option>
                                </select>
                            </div>

                            <!-- Selected Spot Info -->
                            <div class="mb-3">
                                <label class="auth-label">Vị Trí Đã Chọn</label>
                                <div class="p-2 bg-dark rounded border border-info text-info text-center fw-bold font-monospace" id="selectedSpotDisplay" style="font-size: 1.1rem;">
                                    -- Chưa Chọn Vị Trí --
                                </div>
                            </div>

                            <!-- Detailed pricing applied to slot -->
                            <div class="mb-3 d-none" id="pricingDetailsBox">
                                <label class="auth-label">Bảng Giá Áp Dụng Cho Vị Trí</label>
                                <div class="p-3 bg-dark rounded border border-secondary border-opacity-25" style="font-size: 0.9rem;">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted small"><i class="fa-solid fa-clock text-primary me-1"></i> Giá theo giờ:</span>
                                        <span class="fw-bold text-white" id="detailGiaTheoGio">0đ</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted small"><i class="fa-solid fa-moon text-warning me-1"></i> Giá qua đêm:</span>
                                        <span class="fw-bold text-white" id="detailGiaQuaDem">0đ</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted small"><i class="fa-solid fa-calendar-days text-success me-1"></i> Giá theo tháng:</span>
                                        <span class="fw-bold text-white" id="detailGiaTheoThang">0đ</span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted small"><i class="fa-solid fa-percent text-info me-1"></i> Tỷ lệ đặt cọc:</span>
                                        <span class="fw-bold text-white" id="detailGiaDatCho">0%</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Date time selection -->
                            <div class="mb-3">
                                <label class="auth-label">Thời Gian Bắt Đầu</label>
                                <input type="datetime-local" class="form-control bg-dark text-white border-secondary" id="modalStartTime" required style="border-radius:10px;" />
                            </div>

                            <div class="mb-3">
                                <label class="auth-label">Thời Gian Kết Thúc</label>
                                <input type="datetime-local" class="form-control bg-dark text-white border-secondary" id="modalEndTime" required style="border-radius:10px;" />
                            </div>

                            <!-- Payment Pricing calculation display -->
                            <div class="bg-dark rounded p-3 mb-4 border border-secondary border-opacity-10">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Đơn giá áp dụng:</span>
                                    <span class="fw-semibold text-white small" id="calcPricePerHour">0đ/giờ</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Thời lượng thuê:</span>
                                    <span class="fw-semibold text-white small" id="calcDuration">0 giờ</span>
                                </div>
                                <hr class="border-secondary opacity-25 my-2" />
                                <div class="d-flex justify-content-between">
                                    <strong class="text-white">Tổng tiền cần thanh toán:</strong>
                                    <strong class="text-secondary fs-5" id="calcTotalPayment">0đ</strong>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary-custom w-100 py-3" id="btnConfirmBooking" disabled>
                                XÁC NHẬN THANH TOÁN (VÍ) <i class="fa-solid fa-credit-card ms-1"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Lọc tại trang theo keyword & loại xe
            $('#searchForm').submit(function(e) {
                e.preventDefault();
                const keyword = $('#searchKeyword').val().trim().toLowerCase();
                const vtype = $('#searchVehicleType').val();

                $('.parking-card-item').each(function() {
                    const $card = $(this);
                    const name = $card.data('name') || '';
                    const address = $card.data('address') || '';
                    const cardType = $card.data('type') || '';

                    let show = true;
                    if (keyword && !name.includes(keyword) && !address.includes(keyword)) {
                        show = false;
                    }
                    if (vtype !== 'all') {
                        if (vtype === 'oto' && cardType === 'xemay') show = false;
                        if (vtype === 'xemay' && cardType === 'oto') show = false;
                    }

                    if (show) $card.removeClass('d-none');
                    else $card.addClass('d-none');
                });
            });

            // --- Quản lý Modal đặt chỗ & Tính toán tiền ---
            let activeLotCarPrice = 0;
            let activeLotMotoPrice = 0;
            let currentAreasData = [];
            let selectedAreaId = null;
            let currentPricing = null;

            // Set default date times helper
            function setDefaultDateTimes() {
                let offset = (new Date()).getTimezoneOffset() * 60000;
                let nowLocal = new Date(Date.now() - offset);
                let nowStr = nowLocal.toISOString().slice(0, 16);

                let endLocal = new Date(Date.now() - offset + (3 * 60 * 60 * 1000));
                let endStr = endLocal.toISOString().slice(0, 16);

                $('#modalStartTime').val(nowStr);
                $('#modalEndTime').val(endStr);
            }

            $('.btn-book-trigger').click(function() {
                const $btn = $(this);
                const lotId = $btn.data('id');
                const lotName = $btn.data('name');
                const lotAddress = $btn.data('address');
                activeLotCarPrice = parseInt($btn.data('car-price')) || 0;
                activeLotMotoPrice = parseInt($btn.data('moto-price')) || 0;

                $('#modalLotId').val(lotId);
                $('#modalLotName').text(lotName);
                $('#modalLotAddress').html(`<i class="fa-solid fa-location-dot me-1"></i>${lotAddress}`);
                
                // Reset spot selection
                $('#modalSelectSpot').val('');
                $('#selectedSpotDisplay').text('-- Chưa Chọn Vị Trí --').removeClass('text-success border-success').addClass('text-info border-info');
                $('#btnConfirmBooking').attr('disabled', true);

                setDefaultDateTimes();
                loadVisualLotDetails();

                const myModal = new bootstrap.Modal(document.getElementById('bookingModal'));
                myModal.show();
            });

            $('#modalSelectVehicle').change(function() {
                loadVisualLotDetails();
            });

            // Adjust end time dynamically if rental type changes
            $('#modalRentalType').change(function() {
                const type = $(this).val();
                if (type === 'month') {
                    const startVal = $('#modalStartTime').val();
                    if (startVal) {
                        const startDate = new Date(startVal);
                        const endDate = new Date(startDate.getTime() + (30 * 24 * 60 * 60 * 1000));
                        let offset = endDate.getTimezoneOffset() * 60000;
                        let endLocal = new Date(endDate.getTime() - offset);
                        $('#modalEndTime').val(endLocal.toISOString().slice(0, 16));
                    }
                    $('#modalEndTime').attr('readonly', true).css('opacity', '0.7');
                } else if (type === 'overnight') {
                    const startVal = $('#modalStartTime').val();
                    if (startVal) {
                        const startDate = new Date(startVal);
                        const endDate = new Date(startDate.getFullYear(), startDate.getMonth(), startDate.getDate() + 1, 8, 0, 0);
                        let offset = endDate.getTimezoneOffset() * 60000;
                        let endLocal = new Date(endDate.getTime() - offset);
                        $('#modalEndTime').val(endLocal.toISOString().slice(0, 16));
                    }
                    $('#modalEndTime').removeAttr('readonly').css('opacity', '1');
                } else {
                    $('#modalEndTime').removeAttr('readonly').css('opacity', '1');
                }
                recalculatePrice();
            });

            // Adjust end time if start time changes under monthly/overnight mode
            $('#modalStartTime').on('input change', function() {
                const type = $('#modalRentalType').val();
                if (type === 'month') {
                    const startVal = $(this).val();
                    if (startVal) {
                        const startDate = new Date(startVal);
                        const endDate = new Date(startDate.getTime() + (30 * 24 * 60 * 60 * 1000));
                        let offset = endDate.getTimezoneOffset() * 60000;
                        let endLocal = new Date(endDate.getTime() - offset);
                        $('#modalEndTime').val(endLocal.toISOString().slice(0, 16));
                    }
                } else if (type === 'overnight') {
                    const startVal = $(this).val();
                    if (startVal) {
                        const startDate = new Date(startVal);
                        const endDate = new Date(startDate.getFullYear(), startDate.getMonth(), startDate.getDate() + 1, 8, 0, 0);
                        let offset = endDate.getTimezoneOffset() * 60000;
                        let endLocal = new Date(endDate.getTime() - offset);
                        $('#modalEndTime').val(endLocal.toISOString().slice(0, 16));
                    }
                }
                recalculatePrice();
                loadVisualLotDetails();
            });

            $('#modalEndTime').on('input change', function() {
                recalculatePrice();
                loadVisualLotDetails();
            });

            function loadVisualLotDetails() {
                const lotId = $('#modalLotId').val();
                const bienSoXe = $('#modalSelectVehicle').val();
                const startTime = $('#modalStartTime').val();
                const endTime = $('#modalEndTime').val();
                const $areaContainer = $('#modalAreaContainer');
                const $spotGrid = $('#modalSpotGrid');

                $areaContainer.html('<span class="small text-muted">Đang tải khu vực...</span>');
                $spotGrid.html('<div class="text-center w-100 py-3 text-muted">Đang tải sơ đồ...</div>');

                if (lotId && bienSoXe) {
                    $.getJSON('/Customer/Home/GetLotDetails', { 
                        lotId: lotId, 
                        bienSoXe: bienSoXe,
                        startTime: startTime,
                        endTime: endTime
                    }, function(response) {
                        if (response.success && response.areas.length > 0) {
                            currentAreasData = response.areas;
                            currentPricing = response.pricing; // Store active pricing

                            $areaContainer.empty();
                            
                            response.areas.forEach(function(area, idx) {
                                let activeClass = idx === 0 ? 'btn-info' : 'btn-outline-secondary';
                                if (idx === 0) selectedAreaId = area.id;
                                
                                $areaContainer.append(`
                                    <button type="button" class="btn btn-sm ${activeClass} area-tab-btn" data-area-id="${area.id}">
                                        Khu ${area.name}
                                    </button>
                                `);
                            });

                            // Display pricing details
                            if (response.pricing) {
                                $('#detailGiaTheoGio').text(response.pricing.giaTheoGio.toLocaleString('vi-VN') + "đ/giờ");
                                $('#detailGiaQuaDem').text(response.pricing.giaQuaDem.toLocaleString('vi-VN') + "đ/đêm");
                                $('#detailGiaTheoThang').text(response.pricing.giaTheoThang.toLocaleString('vi-VN') + "đ/tháng");
                                $('#detailGiaDatCho').text(response.pricing.giaDatCho + "%");
                                $('#pricingDetailsBox').removeClass('d-none');
                            } else {
                                $('#pricingDetailsBox').addClass('d-none');
                            }

                            // Render spots for selected Area
                            renderVisualSpots();
                            recalculatePrice();
                        } else {
                            $areaContainer.html('<span class="small text-danger">Bãi xe không hỗ trợ loại phương tiện này!</span>');
                            $spotGrid.html('<div class="text-center w-100 py-3 text-danger">Không tìm thấy vị trí phù hợp.</div>');
                            currentAreasData = [];
                            currentPricing = null;
                            $('#pricingDetailsBox').addClass('d-none');
                            recalculatePrice();
                        }
                    });
                }
            }

            // Click area tab btn
            $(document).on('click', '.area-tab-btn', function() {
                $('.area-tab-btn').removeClass('btn-info').addClass('btn-outline-secondary');
                $(this).removeClass('btn-outline-secondary').addClass('btn-info');
                selectedAreaId = $(this).data('area-id');
                renderVisualSpots();
            });

            function renderVisualSpots() {
                const $spotGrid = $('#modalSpotGrid');
                $spotGrid.empty();

                if (!selectedAreaId) return;

                const area = currentAreasData.find(a => a.id == selectedAreaId);
                if (!area || !area.spots || area.spots.length === 0) {
                    $spotGrid.html('<div class="text-center w-100 py-3 text-muted">Khu vực này hiện tại chưa có chỗ đỗ.</div>');
                    return;
                }

                const currentSelectedSpotId = $('#modalSelectSpot').val();

                area.spots.forEach(function(spot) {
                    let stateClass = '';
                    let stateText = '';
                    let isClickable = false;

                    if (spot.status === 'Trống') {
                        stateClass = 'state-trong';
                        stateText = 'Trống';
                        isClickable = true;
                    } else if (spot.status === 'Đang đỗ') {
                        stateClass = 'state-dangdo';
                        stateText = 'Đang đỗ';
                    } else if (spot.status === 'Đã đặt') {
                        stateClass = 'state-dadat';
                        stateText = 'Đã đặt';
                    } else {
                        stateClass = 'state-baotri';
                        stateText = 'Bảo trì';
                    }

                    let selectedClass = (currentSelectedSpotId == spot.id) ? 'selected' : '';

                    let $card = $(`
                        <div class="spot-card-visual ${stateClass} ${selectedClass}" data-spot-id="${spot.id}" data-spot-name="${spot.name}" data-clickable="${isClickable}">
                            <i class="fa-solid fa-square-parking mb-1" style="font-size: 1.4rem;"></i>
                            <div class="small fw-bold font-monospace">${spot.name}</div>
                            <div style="font-size: 0.65rem;" class="opacity-75">${stateText}</div>
                        </div>
                    `);

                    $spotGrid.append($card);
                });
            }

            // Click spot card helper
            $(document).on('click', '.spot-card-visual', function() {
                const isClickable = $(this).data('clickable');
                if (!isClickable) return; // ignore occupied, booked or maintenance spots

                const spotId = $(this).data('spot-id');
                const spotName = $(this).data('spot-name');

                $('#modalSelectSpot').val(spotId);
                $('#selectedSpotDisplay').text(`Vị Trí: ${spotName}`).removeClass('text-info border-info').addClass('text-success border-success');

                // Re-render visual spots to apply selected border highlight
                renderVisualSpots();
                recalculatePrice();
            });

            function recalculatePrice() {
                const $selectedOpt = $('#modalSelectVehicle option:selected');
                const spotId = $('#modalSelectSpot').val();
                
                if (!$selectedOpt.length || !$selectedOpt.val()) {
                    $('#calcPricePerHour').text("Chưa chọn xe");
                    $('#calcDuration').text("0 giờ");
                    $('#calcTotalPayment').text("0đ");
                    $('#btnConfirmBooking').attr('disabled', true);
                    return;
                }

                const startTimeVal = $('#modalStartTime').val();
                const endTimeVal = $('#modalEndTime').val();

                if (!startTimeVal || !endTimeVal) {
                    $('#calcPricePerHour').text("0đ/giờ");
                    $('#calcDuration').text("0 giờ");
                    $('#calcTotalPayment').text("0đ");
                    $('#btnConfirmBooking').attr('disabled', true);
                    return;
                }

                const startDt = new Date(startTimeVal);
                const endDt = new Date(endTimeVal);
                
                const diffMs = endDt - startDt;
                const duration = diffMs / (1000 * 60 * 60); // duration in hours

                if (duration <= 0) {
                    $('#calcDuration').text("Thời gian không hợp lệ");
                    $('#calcTotalPayment').text("0đ");
                    $('#btnConfirmBooking').attr('disabled', true);
                    return;
                }

                // Format duration nicely (e.g. 2 ngày 5 giờ or 3.5 giờ)
                let durationText = "";
                if (duration >= 24) {
                    let days = Math.floor(duration / 24);
                    let hours = Math.round(duration % 24);
                    durationText = `${days} ngày ${hours} giờ`;
                } else {
                    durationText = `${duration.toFixed(1)} giờ`;
                }

                $('#calcDuration').text(durationText);

                if (!currentPricing) {
                    $('#calcPricePerHour').text("Không tìm thấy bảng giá");
                    $('#calcTotalPayment').text("0đ");
                    $('#btnConfirmBooking').attr('disabled', true);
                    return;
                }

                const hourlyRate = currentPricing.giaTheoGio;
                const totalRent = Math.ceil(hourlyRate * duration);

                $('#calcPricePerHour').text(hourlyRate.toLocaleString('vi-VN') + "đ/giờ");
                $('#calcTotalPayment').text(totalRent.toLocaleString('vi-VN') + "đ");

                // Enable confirm button only if spot selected and dates are valid
                if (spotId && duration > 0) {
                    $('#btnConfirmBooking').removeAttr('disabled');
                } else {
                    $('#btnConfirmBooking').attr('disabled', true);
                }
            }

            $('#modalBookingForm').submit(function(e) {
                e.preventDefault();
                const spotId = $('#modalSelectSpot').val();
                const bienSoXe = $('#modalSelectVehicle').val();
                const startTime = $('#modalStartTime').val();
                const endTime = $('#modalEndTime').val();
                const rentalType = $('#modalRentalType').val();
                const totalText = $('#calcTotalPayment').text();

                if (!spotId) {
                    alert('Vui lòng click chọn 1 chỗ đỗ trống (màu xanh lá) trên sơ đồ!');
                    return;
                }

                if (totalText === "0đ") {
                    alert('Lỗi tính toán tổng chi phí thuê.');
                    return;
                }

                $.ajax({
                    url: '/Customer/Home/BookSpot',
                    type: 'POST',
                    data: {
                        spotId: spotId,
                        bienSoXe: bienSoXe,
                        startTime: startTime,
                        endTime: endTime,
                        rentalType: rentalType
                    },
                    success: function(response) {
                        if (response.success) {
                            alert('Khởi tạo đơn đặt chỗ thành công! Hệ thống sẽ chuyển hướng bạn sang cổng thanh toán VNPAY Sandbox để thanh toán tiền cọc.');
                            bootstrap.Modal.getInstance(document.getElementById('bookingModal')).hide();
                            window.location.href = response.paymentUrl;
                        } else {
                            alert(response.message || 'Lỗi khi đặt chỗ.');
                        }
                    },
                    error: function() {
                        alert('Không thể kết nối đến máy chủ.');
                    }
                });
            });
        });
    </script>
}
