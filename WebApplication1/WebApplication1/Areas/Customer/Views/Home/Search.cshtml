@{
    Layout = "~/Areas/Customer/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "Tìm Kiếm & Đặt Chỗ Đỗ Xe";
}

<!-- Search Filter Box -->
<div class="glass-card mb-4">
    <h5 class="fw-bold mb-3"><i class="fa-solid fa-magnifying-glass text-secondary me-2"></i>Bộ Lọc Tìm Kiếm Bãi Xe</h5>
    <form id="searchForm">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="auth-label">Tỉnh / Thành phố</label>
                <select class="form-select bg-dark text-white border-secondary" id="searchProvince">
                    <option value="" selected>Tất cả</option>
                    <option value="HCM">TP. Hồ Chí Minh</option>
                    <option value="HN">TP. Hà Nội</option>
                    <option value="DN">TP. Đà Nẵng</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="auth-label">Quận / Huyện</label>
                <select class="form-select bg-dark text-white border-secondary" id="searchDistrict" disabled>
                    <option value="" selected>Tất cả</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="auth-label">Loại Xe Hỗ Trợ</label>
                <select class="form-select bg-dark text-white border-secondary" id="searchVehicleType">
                    <option value="all" selected>Tất cả phương tiện</option>
                    <option value="oto">Ô tô (Con/Bán tải)</option>
                    <option value="xemay">Xe máy / Mô tô</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary-custom w-100 py-2">
                    Lọc Kết Quả <i class="fa-solid fa-filter ms-1"></i>
                </button>
            </div>
        </div>
    </form>
</div>

<!-- Parking Lot Lists -->
<div class="row g-4" id="parkingLotContainer">
    <!-- Lot 1 -->
    <div class="col-md-6 col-xxl-4 parking-card-item" data-province="HCM" data-type="both">
        <div class="glass-card h-100 d-flex flex-column">
            <div class="position-relative mb-3">
                <span class="badge bg-success position-absolute top-0 start-0 m-2">Còn: 12 chỗ trống</span>
                <img src="https://images.unsplash.com/photo-1573348722427-f1d6819fdf98?auto=format&fit=crop&w=500&q=80" alt="Bãi xe Quang Trung" class="img-fluid rounded w-100" style="height: 180px; object-fit: cover; border: 1px solid var(--border-color);" />
            </div>

            <h5 class="fw-bold mb-1">Bãi đỗ Xe Công Nghệ Quang Trung</h5>
            <p class="text-muted small mb-2"><i class="fa-solid fa-location-dot me-1"></i>Tô Ký, P. Đông Hưng Thuận, Q.12, TP.HCM</p>
            
            <div class="d-flex gap-2 mb-3">
                <span class="badge bg-dark border border-secondary text-muted"><i class="fa-solid fa-car text-primary me-1"></i>35Kđ/h</span>
                <span class="badge bg-dark border border-secondary text-muted"><i class="fa-solid fa-motorcycle text-warning me-1"></i>15Kđ/h</span>
                <span class="ms-auto text-warning small"><i class="fa-solid fa-star me-1"></i>4.8 (120 đánh giá)</span>
            </div>

            <div class="mt-auto">
                <button class="btn btn-secondary-custom w-100 btn-book-trigger" 
                        data-id="1"
                        data-name="Bãi đỗ Xe Công Nghệ Quang Trung"
                        data-address="Tô Ký, Q.12, TP.HCM"
                        data-car-price="35000"
                        data-moto-price="15000">
                    Chi Tiết & Đặt Chỗ <i class="fa-solid fa-arrow-right ms-1"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Lot 2 -->
    <div class="col-md-6 col-xxl-4 parking-card-item" data-province="HCM" data-type="both">
        <div class="glass-card h-100 d-flex flex-column">
            <div class="position-relative mb-3">
                <span class="badge bg-danger position-absolute top-0 start-0 m-2">Còn: 2 chỗ trống</span>
                <img src="https://images.unsplash.com/photo-1590674899484-d5640e854abe?auto=format&fit=crop&w=500&q=80" alt="Bãi xe Q1" class="img-fluid rounded w-100" style="height: 180px; object-fit: cover; border: 1px solid var(--border-color);" />
            </div>

            <h5 class="fw-bold mb-1">Bãi đỗ Xe Thông Minh Quận 1</h5>
            <p class="text-muted small mb-2"><i class="fa-solid fa-location-dot me-1"></i>Lê Lợi, P. Bến Thành, Quận 1, TP.HCM</p>
            
            <div class="d-flex gap-2 mb-3">
                <span class="badge bg-dark border border-secondary text-muted"><i class="fa-solid fa-car text-primary me-1"></i>50Kđ/h</span>
                <span class="badge bg-dark border border-secondary text-muted"><i class="fa-solid fa-motorcycle text-warning me-1"></i>20Kđ/h</span>
                <span class="ms-auto text-warning small"><i class="fa-solid fa-star me-1"></i>4.9 (340 đánh giá)</span>
            </div>

            <div class="mt-auto">
                <button class="btn btn-secondary-custom w-100 btn-book-trigger" 
                        data-id="2"
                        data-name="Bãi đỗ Xe Thông Minh Quận 1"
                        data-address="Lê Lợi, Quận 1, TP.HCM"
                        data-car-price="50000"
                        data-moto-price="20000">
                    Chi Tiết & Đặt Chỗ <i class="fa-solid fa-arrow-right ms-1"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Lot 3 -->
    <div class="col-md-6 col-xxl-4 parking-card-item" data-province="HN" data-type="oto">
        <div class="glass-card h-100 d-flex flex-column">
            <div class="position-relative mb-3">
                <span class="badge bg-success position-absolute top-0 start-0 m-2">Còn: 45 chỗ trống</span>
                <img src="https://images.unsplash.com/photo-1506521788723-8681c63d278b?auto=format&fit=crop&w=500&q=80" alt="Bãi xe Cầu Giấy" class="img-fluid rounded w-100" style="height: 180px; object-fit: cover; border: 1px solid var(--border-color);" />
            </div>

            <h5 class="fw-bold mb-1">Bãi đỗ Ô Tô Cầu Giấy</h5>
            <p class="text-muted small mb-2"><i class="fa-solid fa-location-dot me-1"></i>Dịch Vọng Hậu, Cầu Giấy, Hà Nội</p>
            
            <div class="d-flex gap-2 mb-3">
                <span class="badge bg-dark border border-secondary text-muted"><i class="fa-solid fa-car text-primary me-1"></i>40Kđ/h</span>
                <span class="ms-auto text-warning small"><i class="fa-solid fa-star me-1"></i>4.7 (95 đánh giá)</span>
            </div>

            <div class="mt-auto">
                <button class="btn btn-secondary-custom w-100 btn-book-trigger" 
                        data-id="3"
                        data-name="Bãi đỗ Ô Tô Cầu Giấy"
                        data-address="Cầu Giấy, Hà Nội"
                        data-car-price="40000"
                        data-moto-price="0">
                    Chi Tiết & Đặt Chỗ <i class="fa-solid fa-arrow-right ms-1"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Booking Modal (Màn hình cấu hình và Đặt chỗ) -->
<div class="modal fade" id="bookingModal" tabindex="-1" aria-labelledby="bookingModalLabel" aria-hidden="true" style="backdrop-filter: blur(5px);">
    <div class="modal-dialog modal-dialog-centered text-white">
        <div class="modal-content bg-dark border-secondary p-3 shadow-2xl" style="border-radius:16px;">
            <div class="modal-header border-secondary border-opacity-10">
                <h5 class="modal-title fw-bold text-gradient" id="bookingModalLabel">Đặt Chỗ Đỗ Xe</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <h6 class="fw-bold mb-1" id="modalLotName">Tên bãi đỗ</h6>
                <p class="text-muted small mb-3" id="modalLotAddress"><i class="fa-solid fa-location-dot me-1"></i>Địa chỉ bãi</p>

                <form id="modalBookingForm">
                    <!-- Select Vehicle -->
                    <div class="mb-3">
                        <label class="auth-label">Phương Tiện Đăng Ký</label>
                        <select class="form-select bg-dark text-white border-secondary" id="modalSelectVehicle" required>
                            <option value="51F-999.99" data-type="car">Audi E-Tron GT (51F - 999.99)</option>
                            <option value="29A-123.45" data-type="moto">Honda SH 150i (29A - 123.45)</option>
                        </select>
                    </div>

                    <div class="row g-2 mb-3">
                        <!-- Start hour -->
                        <div class="col-6">
                            <label class="auth-label">Giờ Vào Dự Kiến</label>
                            <input type="time" class="form-control bg-dark text-white border-secondary" id="modalStartTime" required value="19:00" />
                        </div>
                        <!-- Duration selection -->
                        <div class="col-6">
                            <label class="auth-label">Thời Gian Đỗ (Giờ)</label>
                            <select class="form-select bg-dark text-white border-secondary" id="modalDuration" required>
                                <option value="1">1 giờ</option>
                                <option value="2">2 giờ</option>
                                <option value="3" selected>3 giờ</option>
                                <option value="4">4 giờ</option>
                                <option value="8">8 giờ</option>
                            </select>
                        </div>
                    </div>

                    <!-- Payment Pricing calculation display -->
                    <div class="bg-dark rounded p-3 mb-4 border border-secondary border-opacity-10">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Đơn giá chỗ đỗ:</span>
                            <span class="fw-semibold text-white small" id="calcPricePerHour">35,000đ/giờ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Thời lượng thuê:</span>
                            <span class="fw-semibold text-white small" id="calcDuration">3 giờ</span>
                        </div>
                        <hr class="border-secondary opacity-25 my-2" />
                        <div class="d-flex justify-content-between">
                            <strong class="text-white">Tổng cộng cần trả:</strong>
                            <strong class="text-secondary fs-5" id="calcTotalPayment">105,000đ</strong>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary-custom w-100 py-3">
                        XÁC NHẬN THANH TOÁN (VÍ CỦA BẠN) <i class="fa-solid fa-credit-card ms-1"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // --- 1. Lọc địa giới quận huyện mô phỏng ---
            const districts = {
                "HCM": [
                    { id: "Q1", name: "Quận 1" },
                    { id: "Q12", name: "Quận 12" },
                    { id: "BT", name: "Bình Thạnh" }
                ],
                "HN": [
                    { id: "CG", name: "Cầu Giấy" },
                    { id: "HK", name: "Hoàn Kiếm" }
                ],
                "DN": [
                    { id: "HC", name: "Hải Châu" }
                ]
            };

            $('#searchProvince').change(function() {
                const val = $(this).val();
                const $dist = $('#searchDistrict');
                $dist.empty().append('<option value="">Tất cả</option>');

                if (val && districts[val]) {
                    districts[val].forEach(function(item) {
                        $dist.append(`<option value="${item.id}">${item.name}</option>`);
                    });
                    $dist.removeAttr('disabled');
                } else {
                    $dist.attr('disabled', true);
                }
            });

            // Chặn submit search demo để lọc tại trang
            $('#searchForm').submit(function(e) {
                e.preventDefault();
                const prov = $('#searchProvince').val();
                const vtype = $('#searchVehicleType').val();

                $('.parking-card-item').each(function() {
                    const $card = $(this);
                    const cardProv = $card.data('province');
                    const cardType = $card.data('type');

                    let show = true;
                    if (prov && cardProv !== prov) show = false;
                    
                    if (vtype !== 'all') {
                        if (cardType !== 'both' && cardType !== vtype) show = false;
                    }

                    if (show) $card.removeClass('d-none');
                    else $card.addClass('d-none');
                });
            });


            // --- 2. Quản lý Modal đặt chỗ & Tính toán tiền ---
            let activeLotCarPrice = 0;
            let activeLotMotoPrice = 0;

            $('.btn-book-trigger').click(function() {
                const $btn = $(this);
                const lotName = $btn.data('name');
                const lotAddress = $btn.data('address');
                activeLotCarPrice = parseInt($btn.data('car-price'));
                activeLotMotoPrice = parseInt($btn.data('moto-price'));

                $('#modalLotName').text(lotName);
                $('#modalLotAddress').html(`<i class="fa-solid fa-location-dot me-1"></i>${lotAddress}`);
                
                recalculatePrice();

                const myModal = new bootstrap.Modal(document.getElementById('bookingModal'));
                myModal.show();
            });

            $('#modalSelectVehicle, #modalDuration').change(function() {
                recalculatePrice();
            });

            function recalculatePrice() {
                const selectedVehicleType = $('#modalSelectVehicle option:selected').data('type');
                const duration = parseInt($('#modalDuration').val());
                
                let rate = (selectedVehicleType === 'car') ? activeLotCarPrice : activeLotMotoPrice;
                
                if (rate === 0) {
                    $('#calcPricePerHour').text("Không hỗ trợ xe này");
                    $('#calcTotalPayment').text("0đ");
                    return;
                }

                const total = rate * duration;

                $('#calcPricePerHour').text(rate.toLocaleString('vi-VN') + "đ/giờ");
                $('#calcDuration').text(duration + " giờ");
                $('#calcTotalPayment').text(total.toLocaleString('vi-VN') + "đ");
            }

            $('#modalBookingForm').submit(function(e) {
                e.preventDefault();
                const totalText = $('#calcTotalPayment').text();
                if (totalText === "0đ") {
                    alert('Bãi xe này không hỗ trợ loại phương tiện được chọn!');
                    return;
                }

                alert(`Thanh toán thành công ${totalText} từ số dư tài khoản của bạn!\n\nĐã khởi tạo đặt chỗ đỗ xe. Vị trí và mã mở barie đã được tạo trong đơn đỗ xe của bạn.`);
                bootstrap.Modal.getInstance(document.getElementById('bookingModal')).hide();
            });
        });
    </script>
}
