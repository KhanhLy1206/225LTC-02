@model IEnumerable<WebApplication1.Models.Entities.BaiXe>
@{
    ViewData["Title"] = "Quản lý bãi xe";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="owner-page-title">Quản lý bãi xe</h1>
        <p class="owner-page-subtitle">Xem danh sách, kiểm tra trạng thái hoạt động và đăng ký bãi đỗ xe mới.</p>
    </div>
    <button class="btn btn-primary-custom d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#addBaiXeModal">
        <i class="fa-solid fa-plus"></i> Đăng ký bãi xe mới
    </button>
</div>
<!-- KPI Stats Row -->
<div class="row g-4 mb-4">
    <div class="col-xl-6 col-md-12">
        <div class="owner-kpi-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="owner-kpi-info">
                    <h6>Tổng số bãi xe</h6>
                </div>
                <div class="owner-kpi-icon-box primary">
                    <i class="fa-solid fa-square-parking"></i>
                </div>
            </div>
            <div class="owner-kpi-value mb-2">@ViewBag.TongSoBaiXe bãi xe</div>
            <div class="owner-kpi-footer text-muted small">
                @ViewBag.SoBaiHoatDong bãi đang hoạt động | @ViewBag.SoBaiChoDuyet bãi chờ duyệt
            </div>
        </div>
    </div>
    <div class="col-xl-6 col-md-12">
        <div class="owner-kpi-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="owner-kpi-info">
                    <h6>Tổng sức chứa</h6>
                </div>
                <div class="owner-kpi-icon-box success">
                    <i class="fa-solid fa-car-side"></i>
                </div>
            </div>
            <div class="owner-kpi-value mb-2">@ViewBag.TongSucChua chỗ đỗ</div>
            <div class="owner-kpi-footer text-muted small">
                Phân bổ bãi đỗ xe thuộc sở hữu của bạn
            </div>
        </div>
    </div>
</div>

<!-- Parking Lots Grid -->
<div class="row g-4 mb-5">
    @if (Model == null || !Model.Any())
    {
        <div class="col-12 text-center py-5">
            <div class="text-muted mb-3" style="font-size: 3.5rem;">
                <i class="fa-solid fa-square-parking opacity-25"></i>
            </div>
            <h5 class="fw-bold text-dark">Chưa có bãi đỗ xe nào được đăng ký</h5>
            <p class="text-muted small">Hãy nhấn vào nút "Đăng ký bãi xe mới" ở trên để gửi hồ sơ đăng ký.</p>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="col-xl-4 col-md-6">
                <div class="card h-100 owner-table-card border-0">
                    <div class="position-relative">
                        <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://images.unsplash.com/photo-1506521781263-d8422e82f27a?auto=format&fit=crop&w=600&q=80" : item.HinhAnh)" 
                             class="card-img-top" 
                             alt="@item.TenBai" 
                             style="height: 200px; object-fit: cover; border-top-left-radius: 16px; border-top-right-radius: 16px;">
                        
                        @if (item.TrangThai == "Hoạt động")
                        {
                            <span class="badge position-absolute top-0 end-0 m-3 bg-white text-success border border-success px-3 py-2" style="border-radius: 20px;">
                                <i class="fa-solid fa-circle-check me-1"></i> Hoạt động
                            </span>
                        }
                        else if (item.TrangThai == "Chờ duyệt")
                        {
                            <span class="badge position-absolute top-0 end-0 m-3 bg-white text-warning border border-warning px-3 py-2" style="border-radius: 20px;">
                                <i class="fa-solid fa-clock me-1"></i> Chờ duyệt
                            </span>
                        }
                        else
                        {
                            <span class="badge position-absolute top-0 end-0 m-3 bg-white text-danger border border-danger px-3 py-2" style="border-radius: 20px;">
                                <i class="fa-solid fa-circle-xmark me-1"></i> @item.TrangThai
                            </span>
                        }
                    </div>
                    <div class="card-body p-4 d-flex flex-column justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold text-dark mb-2">@item.TenBai</h5>
                            <p class="small text-muted mb-3">
                                <i class="fa-solid fa-location-dot me-1"></i> 
                                @item.DiaChiChiTiet@(item.XaPhuong != null ? $", {item.XaPhuong.TenXa}" : "")@(item.XaPhuong?.QuanHuyen != null ? $", {item.XaPhuong.QuanHuyen.TenHuyen}" : "")@(item.XaPhuong?.QuanHuyen?.TinhThanh != null ? $", {item.XaPhuong.QuanHuyen.TinhThanh.TenTinh}" : "")
                            </p>
                            
                            <hr class="my-3 opacity-50">
                            
                            <div class="row g-2 mb-3">
                                <div class="col-6 mb-2">
                                    <span class="d-block small text-muted">Sức chứa</span>
                                    <strong class="text-dark"><i class="fa-solid fa-square-parking me-1 text-primary"></i> @item.SucChua chỗ đỗ</strong>
                                </div>
                                <div class="col-6 mb-2">
                                    <span class="d-block small text-muted">Diện tích</span>
                                    <strong class="text-dark"><i class="fa-solid fa-ruler-combined me-1 text-primary"></i> @item.DienTich.ToString("N0") m²</strong>
                                </div>
                                <div class="col-6 mb-2">
                                    <span class="d-block small text-muted">Chiết khấu hệ thống</span>
                                    <strong class="text-dark"><i class="fa-solid fa-percent me-1 text-primary"></i> @item.PhanTramChietKhau%</strong>
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-flex gap-2 mt-3 pt-2 border-top border-light">
                            @if (item.TrangThai == "Hoạt động")
                            {
                                <a href="/Owner/SoDo?lotId=@item.ID" class="btn btn-sm btn-outline-primary flex-grow-1 py-2 rounded-3">Sơ đồ bãi đỗ</a>
                                <a href="/Owner/Gia?lotId=@item.ID" class="btn btn-sm btn-outline-secondary flex-grow-1 py-2 rounded-3">Cấu hình giá</a>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary flex-grow-1 py-2 rounded-3 disabled" disabled>Chờ phê duyệt hồ sơ</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Modal Đăng Ký Bãi Xe -->
<div class="modal fade" id="addBaiXeModal" tabindex="-1" aria-labelledby="addBaiXeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header px-4 py-3 border-bottom border-light">
                <h5 class="modal-title fw-bold text-dark" id="addBaiXeModalLabel"><i class="fa-solid fa-file-signature text-primary me-2"></i> Đăng ký bãi xe mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-area="Owner" asp-controller="BaiXe" asp-action="Create" method="post" enctype="multipart/form-data" id="addBaiXeForm">
                <div class="modal-body p-4">
                    <p class="small text-muted mb-4">Các thông tin sau sẽ được hệ thống chuyển tiếp đến bộ phận Quản trị viên (Admin) phê duyệt. Tài khoản bãi đỗ xe và các khu vực sẽ được khởi tạo khi được phê duyệt.</p>
                    
                    <div class="row g-3">
                        <!-- Tên bãi xe -->
                        <div class="col-md-12">
                            <label class="form-label small fw-bold text-dark" for="TenBai">Tên bãi xe <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" id="TenBai" name="TenBai" placeholder="Ví dụ: Bãi đỗ xe thông minh SPMS - Cống Quỳnh" required>
                        </div>
                        
                        <!-- Hotline & Giờ hoạt động -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-dark" for="SoDienThoai">Hotline bãi xe</label>
                            <input type="tel" class="form-control rounded-3" id="SoDienThoai" name="SoDienThoai" placeholder="Ví dụ: 0987654321" maxlength="15">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-dark" for="GioHoatDong">Giờ hoạt động</label>
                            <input type="text" class="form-control rounded-3" id="GioHoatDong" name="GioHoatDong" placeholder="Ví dụ: 24/7 hoặc 06:00 - 23:30" maxlength="100">
                        </div>
                        
                        <!-- Địa chỉ hành chính -->
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-dark" for="provinceSelect">Tỉnh / Thành phố <span class="text-danger">*</span></label>
                            <select class="form-select rounded-3" id="provinceSelect" name="MaTinh" required>
                                <option value="" selected disabled>Chọn Tỉnh / TP</option>
                                @if (ViewBag.Provinces != null)
                                {
                                    foreach (var p in (IEnumerable<WebApplication1.Models.Entities.TinhThanh>)ViewBag.Provinces)
                                    {
                                        <option value="@p.MaTinh">@p.TenTinh</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-dark" for="districtSelect">Quận / Huyện <span class="text-danger">*</span></label>
                            <select class="form-select rounded-3" id="districtSelect" name="MaHuyen" required disabled>
                                <option value="" selected disabled>Chọn Quận / Huyện</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-dark" for="wardSelect">Phường / Xã <span class="text-danger">*</span></label>
                            <select class="form-select rounded-3" id="wardSelect" name="MaXa" required disabled>
                                <option value="" selected disabled>Chọn Phường / Xã</option>
                            </select>
                        </div>

                        <!-- Địa chỉ chi tiết -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-dark" for="DiaChiChiTiet">Địa chỉ chi tiết (Số nhà, đường) <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" id="DiaChiChiTiet" name="DiaChiChiTiet" placeholder="Ví dụ: 189 Cống Quỳnh" required>
                        </div>
                        
                        <!-- Sức chứa -->
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-dark" for="SucChua">Sức chứa (Ô tô) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control rounded-3" id="SucChua" name="SucChua" min="10" placeholder="Ví dụ: 50" required>
                        </div>

                        <!-- Diện tích (m2) -->
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-dark" for="DienTich">Diện tích (m²) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control rounded-3" id="DienTich" name="DienTich" min="10" placeholder="Ví dụ: 500" required>
                        </div>

                        <!-- File Uploads -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-dark" for="GiayPhepKinhDoanhFile">Giấy phép kinh doanh bãi xe <span class="text-danger">*</span></label>
                            <input type="file" class="form-control rounded-3" id="GiayPhepKinhDoanhFile" name="GiayPhepKinhDoanhFile" accept=".pdf,image/*" required>
                            <span class="small text-muted" style="font-size: 0.75rem;">Định dạng PDF hoặc hình ảnh rõ nét.</span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-dark" for="HinhAnhFile">Hình ảnh bãi đỗ xe <span class="text-danger">*</span></label>
                            <input type="file" class="form-control rounded-3" id="HinhAnhFile" name="HinhAnhFile" accept="image/*" required>
                            <span class="small text-muted" style="font-size: 0.75rem;">Hình ảnh chụp thực tế bãi đỗ.</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer px-4 py-3 border-top border-light d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-outline-secondary rounded-3 px-4 py-2" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary-custom px-4 py-2">Gửi hồ sơ đăng ký</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('provinceSelect').addEventListener('change', function () {
            var provinceId = this.value;
            var districtSelect = document.getElementById('districtSelect');
            var wardSelect = document.getElementById('wardSelect');

            districtSelect.innerHTML = '<option value="" selected disabled>Chọn Quận / Huyện</option>';
            wardSelect.innerHTML = '<option value="" selected disabled>Chọn Phường / Xã</option>';
            districtSelect.disabled = true;
            wardSelect.disabled = true;

            if (provinceId) {
                fetch('/Owner/BaiXe/GetDistricts?provinceId=' + provinceId)
                    .then(response => response.json())
                    .then(data => {
                        data.forEach(item => {
                            var opt = document.createElement('option');
                            opt.value = item.id;
                            opt.textContent = item.name;
                            districtSelect.appendChild(opt);
                        });
                        districtSelect.disabled = false;
                    })
                    .catch(err => console.error('Error fetching districts:', err));
            }
        });

        document.getElementById('districtSelect').addEventListener('change', function () {
            var districtId = this.value;
            var wardSelect = document.getElementById('wardSelect');

            wardSelect.innerHTML = '<option value="" selected disabled>Chọn Phường / Xã</option>';
            wardSelect.disabled = true;

            if (districtId) {
                fetch('/Owner/BaiXe/GetWards?districtId=' + districtId)
                    .then(response => response.json())
                    .then(data => {
                        data.forEach(item => {
                            var opt = document.createElement('option');
                            opt.value = item.id;
                            opt.textContent = item.name;
                            wardSelect.appendChild(opt);
                        });
                        wardSelect.disabled = false;
                    })
                    .catch(err => console.error('Error fetching wards:', err));
            }
        });
    </script>
}


