@{
    ViewData["Title"] = "Quản lý bãi xe";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="owner-page-title">Quản lý bãi xe</h1>
        <p class="owner-page-subtitle">Xem danh sách, kiểm tra trạng thái hoạt động và đăng ký bãi đỗ xe mới.</p>
    </div>
    <button class="btn btn-primary-custom d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#addBaiXeModal">
        <i class="fa-solid fa-plus"></i> Đăng ký bãi xe mới
    </button>
</div>

<!-- KPI Stats Row -->
<div class="row g-4 mb-4">
    <div class="col-xl-4 col-md-6">
        <div class="owner-kpi-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="owner-kpi-info">
                    <h6>Tổng số bãi xe</h6>
                </div>
                <div class="owner-kpi-icon-box primary">
                    <i class="fa-solid fa-square-parking"></i>
                </div>
            </div>
            <div class="owner-kpi-value mb-2">3 bãi xe</div>
            <div class="owner-kpi-footer text-muted small">
                2 bãi đang hoạt động | 1 bãi chờ duyệt
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-6">
        <div class="owner-kpi-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="owner-kpi-info">
                    <h6>Tổng sức chứa</h6>
                </div>
                <div class="owner-kpi-icon-box success">
                    <i class="fa-solid fa-car-side"></i>
                </div>
            </div>
            <div class="owner-kpi-value mb-2">180 chỗ đỗ</div>
            <div class="owner-kpi-footer text-muted small">
                100% chỗ đỗ dành cho xe ô tô
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-12">
        <div class="owner-kpi-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="owner-kpi-info">
                    <h6>Doanh thu tích lũy</h6>
                </div>
                <div class="owner-kpi-icon-box info">
                    <i class="fa-solid fa-wallet"></i>
                </div>
            </div>
            <div class="owner-kpi-value mb-2">43,700,000đ</div>
            <div class="owner-kpi-footer text-muted small">
                Đã khấu trừ chiết khấu hệ thống
            </div>
        </div>
    </div>
</div>

<!-- Parking Lots Grid -->
<div class="row g-4 mb-5">
    <!-- Lot 1 -->
    <div class="col-xl-4 col-md-6">
        <div class="card h-100 owner-table-card border-0">
            <div class="position-relative">
                <img src="https://images.unsplash.com/photo-1506521781263-d8422e82f27a?auto=format&fit=crop&w=600&q=80" 
                     class="card-img-top" 
                     alt="Smart Parking Quận 1" 
                     style="height: 200px; object-fit: cover; border-top-left-radius: 16px; border-top-right-radius: 16px;">
                <span class="badge position-absolute top-0 end-0 m-3 bg-success-light text-success px-3 py-2" style="border-radius: 20px;">
                    <i class="fa-solid fa-circle-check me-1"></i> Hoạt động
                </span>
            </div>
            <div class="card-body p-4 d-flex flex-column justify-content-between">
                <div>
                    <h5 class="card-title fw-bold text-dark mb-2">SPMS Cống Quỳnh - Quận 1</h5>
                    <p class="small text-muted mb-3"><i class="fa-solid fa-location-dot me-1"></i> 189 Cống Quỳnh, P. Nguyễn Cư Trinh, Quận 1, TP. HCM</p>
                    
                    <hr class="my-3 opacity-50">
                    
                    <div class="row g-2 mb-3">
                        <div class="col-6 mb-2">
                            <span class="d-block small text-muted">Sức chứa</span>
                            <strong class="text-dark"><i class="fa-solid fa-square-parking me-1 text-primary"></i> 50 chỗ đỗ</strong>
                        </div>
                        <div class="col-6 mb-2">
                            <span class="d-block small text-muted">Giờ mở cửa</span>
                            <strong class="text-dark"><i class="fa-solid fa-clock me-1 text-primary"></i> 24/7</strong>
                        </div>
                        <div class="col-12">
                            <span class="d-block small text-muted">Diện tích mặt bằng</span>
                            <strong class="text-dark"><i class="fa-solid fa-vector-square me-1 text-primary"></i> 1,250 m²</strong>
                        </div>
                    </div>
                </div>
                
                <div class="d-flex gap-2 mt-3 pt-2 border-top border-light">
                    <a href="/Owner/SoDo" class="btn btn-sm btn-outline-primary flex-grow-1 py-2 rounded-3">Sơ đồ bãi đỗ</a>
                    <a href="/Owner/Gia" class="btn btn-sm btn-outline-secondary flex-grow-1 py-2 rounded-3">Cấu hình giá</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Lot 2 -->
    <div class="col-xl-4 col-md-6">
        <div class="card h-100 owner-table-card border-0">
            <div class="position-relative">
                <img src="https://images.unsplash.com/photo-1590674899484-d5640e854abe?auto=format&fit=crop&w=600&q=80" 
                     class="card-img-top" 
                     alt="Smart Parking Quận 7" 
                     style="height: 200px; object-fit: cover; border-top-left-radius: 16px; border-top-right-radius: 16px;">
                <span class="badge position-absolute top-0 end-0 m-3 bg-success-light text-success px-3 py-2" style="border-radius: 20px;">
                    <i class="fa-solid fa-circle-check me-1"></i> Hoạt động
                </span>
            </div>
            <div class="card-body p-4 d-flex flex-column justify-content-between">
                <div>
                    <h5 class="card-title fw-bold text-dark mb-2">SPMS Sunrise City - Quận 7</h5>
                    <p class="small text-muted mb-3"><i class="fa-solid fa-location-dot me-1"></i> 23 Nguyễn Hữu Thọ, P. Tân Hưng, Quận 7, TP. HCM</p>
                    
                    <hr class="my-3 opacity-50">
                    
                    <div class="row g-2 mb-3">
                        <div class="col-6 mb-2">
                            <span class="d-block small text-muted">Sức chứa</span>
                            <strong class="text-dark"><i class="fa-solid fa-square-parking me-1 text-primary"></i> 80 chỗ đỗ</strong>
                        </div>
                        <div class="col-6 mb-2">
                            <span class="d-block small text-muted">Giờ mở cửa</span>
                            <strong class="text-dark"><i class="fa-solid fa-clock me-1 text-primary"></i> 06:00 - 23:30</strong>
                        </div>
                        <div class="col-12">
                            <span class="d-block small text-muted">Diện tích mặt bằng</span>
                            <strong class="text-dark"><i class="fa-solid fa-vector-square me-1 text-primary"></i> 2,000 m²</strong>
                        </div>
                    </div>
                </div>
                
                <div class="d-flex gap-2 mt-3 pt-2 border-top border-light">
                    <a href="/Owner/SoDo" class="btn btn-sm btn-outline-primary flex-grow-1 py-2 rounded-3">Sơ đồ bãi đỗ</a>
                    <a href="/Owner/Gia" class="btn btn-sm btn-outline-secondary flex-grow-1 py-2 rounded-3">Cấu hình giá</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Lot 3 -->
    <div class="col-xl-4 col-md-6">
        <div class="card h-100 owner-table-card border-0">
            <div class="position-relative">
                <img src="https://images.unsplash.com/photo-1573348722427-f1d6819fdf98?auto=format&fit=crop&w=600&q=80" 
                     class="card-img-top" 
                     alt="Smart Parking Bình Thạnh" 
                     style="height: 200px; object-fit: cover; border-top-left-radius: 16px; border-top-right-radius: 16px;">
                <span class="badge position-absolute top-0 end-0 m-3 bg-warning-light text-warning px-3 py-2" style="border-radius: 20px;">
                    <i class="fa-solid fa-clock me-1"></i> Chờ duyệt
                </span>
            </div>
            <div class="card-body p-4 d-flex flex-column justify-content-between">
                <div>
                    <h5 class="card-title fw-bold text-dark mb-2">SPMS Landmark Plus - Bình Thạnh</h5>
                    <p class="small text-muted mb-3"><i class="fa-solid fa-location-dot me-1"></i> 720A Điện Biên Phủ, Phường 22, Bình Thạnh, TP. HCM</p>
                    
                    <hr class="my-3 opacity-50">
                    
                    <div class="row g-2 mb-3">
                        <div class="col-6 mb-2">
                            <span class="d-block small text-muted">Sức chứa</span>
                            <strong class="text-dark"><i class="fa-solid fa-square-parking me-1 text-primary"></i> 50 chỗ đỗ</strong>
                        </div>
                        <div class="col-6 mb-2">
                            <span class="d-block small text-muted">Giờ mở cửa</span>
                            <strong class="text-dark"><i class="fa-solid fa-clock me-1 text-primary"></i> 24/7</strong>
                        </div>
                        <div class="col-12">
                            <span class="d-block small text-muted">Diện tích mặt bằng</span>
                            <strong class="text-dark"><i class="fa-solid fa-vector-square me-1 text-primary"></i> 1,100 m²</strong>
                        </div>
                    </div>
                </div>
                
                <div class="d-flex gap-2 mt-3 pt-2 border-top border-light">
                    <button class="btn btn-sm btn-outline-secondary flex-grow-1 py-2 rounded-3 disabled" disabled>Chờ phê duyệt hồ sơ</button>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Modal Đăng Ký Bãi Xe -->
<div class="modal fade" id="addBaiXeModal" tabindex="-1" aria-labelledby="addBaiXeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header px-4 py-3 border-bottom border-light">
                <h5 class="modal-title fw-bold text-dark" id="addBaiXeModalLabel"><i class="fa-solid fa-file-signature text-primary me-2"></i> Đăng ký bãi xe mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="addBaiXeForm" method="post" enctype="multipart/form-data">
                <div class="modal-body p-4">
                    <p class="small text-muted mb-4">Các thông tin sau sẽ được hệ thống chuyển tiếp đến bộ phận Quản trị viên (Admin) phê duyệt. Tài khoản bãi đỗ xe và các khu vực sẽ được khởi tạo khi được phê duyệt.</p>
                    
                    <div class="row g-3">
                        <!-- Tên bãi xe -->
                        <div class="col-md-12">
                            <label class="form-label small fw-bold text-dark">Tên bãi xe <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" placeholder="Ví dụ: Bãi đỗ xe thông minh SPMS - Quận 1" required>
                        </div>
                        
                        <!-- Số điện thoại & Giờ hoạt động -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-dark">Số điện thoại liên hệ <span class="text-danger">*</span></label>
                            <input type="tel" class="form-control rounded-3" placeholder="Ví dụ: 0987654321" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-dark">Giờ hoạt động <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" placeholder="Ví dụ: 24/7 hoặc 06:00 - 23:30" required>
                        </div>
                        
                        <!-- Địa chỉ hành chính -->
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-dark">Tỉnh / Thành phố <span class="text-danger">*</span></label>
                            <select class="form-select rounded-3" required>
                                <option value="" selected disabled>Chọn Tỉnh / TP</option>
                                <option value="HCM">Thành phố Hồ Chí Minh</option>
                                <option value="HN">Thành phố Hà Nội</option>
                                <option value="DN">Thành phố Đà Nẵng</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-dark">Quận / Huyện <span class="text-danger">*</span></label>
                            <select class="form-select rounded-3" required>
                                <option value="" selected disabled>Chọn Quận / Huyện</option>
                                <option value="Q1">Quận 1</option>
                                <option value="Q7">Quận 7</option>
                                <option value="BT">Quận Bình Thạnh</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-dark">Phường / Xã <span class="text-danger">*</span></label>
                            <select class="form-select rounded-3" required>
                                <option value="" selected disabled>Chọn Phường / Xã</option>
                                <option value="1">Phường Bến Nghé</option>
                                <option value="2">Phường Tân Phong</option>
                                <option value="3">Phường 22</option>
                            </select>
                        </div>

                        <!-- Địa chỉ chi tiết -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-dark">Địa chỉ chi tiết (Số nhà, đường) <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" placeholder="Ví dụ: 189 Cống Quỳnh" required>
                        </div>
                        
                        <!-- Sức chứa -->
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-dark">Sức chứa (Ô tô) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control rounded-3" min="10" placeholder="Ví dụ: 50" required>
                        </div>

                        <!-- Diện tích (m2) -->
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-dark">Diện tích (m²) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control rounded-3" min="50" placeholder="Ví dụ: 500" required>
                        </div>

                        <!-- File Uploads -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-dark">Giấy phép kinh doanh bãi xe <span class="text-danger">*</span></label>
                            <input type="file" class="form-control rounded-3" accept=".pdf,image/*" required>
                            <span class="small text-muted" style="font-size: 0.75rem;">Định dạng PDF hoặc hình ảnh rõ nét.</span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-dark">Hình ảnh bãi đỗ xe <span class="text-danger">*</span></label>
                            <input type="file" class="form-control rounded-3" accept="image/*" required>
                            <span class="small text-muted" style="font-size: 0.75rem;">Hình ảnh chụp thực tế bãi đỗ.</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer px-4 py-3 border-top border-light d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-outline-secondary rounded-3 px-4 py-2" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary-custom px-4 py-2">Gửi hồ sơ đăng ký</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('addBaiXeForm').addEventListener('submit', function (e) {
            e.preventDefault();
            alert('Hồ sơ đăng ký bãi xe đã được gửi thành công và đang chờ Admin xét duyệt!');
            const modal = bootstrap.Modal.getInstance(document.getElementById('addBaiXeModal'));
            modal.hide();
        });
    </script>
}

