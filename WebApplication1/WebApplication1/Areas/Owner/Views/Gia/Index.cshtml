            { lotName: 'SPMS Landmark Plus - Bình Thạnh', areaLabel: 'Khu B', vehicleLabel: '🛻 Xe bán tải', time: '16:30 - 18/04/2026', user: 'Lê Văn Chủ', giaTheoGio: 35000, giaQuaDem: 140000, giaTheoThang: 2000000, giaDatCho: 30, status: 'Lịch sử', statusClass: 'bg-light text-muted border' },
            { lotName: 'SPMS Cống Quỳnh - Q1', areaLabel: 'Khu A', vehicleLabel: '🚗 Ô tô con', time: '09:00 - 10/04/2026', user: 'Lê Văn Chủ', giaTheoGio: 12000, giaQuaDem: 50000, giaTheoThang: 800000, giaDatCho: 30, status: 'Lịch sử', statusClass: 'bg-light text-muted border' },
            { lotName: 'SPMS Sunrise City - Q7', areaLabel: 'Khu A', vehicleLabel: '🚗 Ô tô con', time: '08:30 - 05/04/2026', user: 'Lê Văn Chủ', giaTheoGio: 10000, giaQuaDem: 40000, giaTheoThang: 700000, giaDatCho: 30, status: 'Lịch sử', statusClass: 'bg-light text-muted border' }
        ];

        const rowsPerPage = 6;
        let currentPage = 1;

        $(document).ready(function() {
            // Render initial audit logs
            renderAuditLogs();

            // Hide pricing form initially, show prompt
            $('#inlinePricingForm').hide();
            $('#selectPromptCard').show();

            // Handle Lot dropdown change
            $('#lotSelect').change(function() {
                const lotVal = $(this).val();
                if (!lotVal) {
                    resetSelection();
                    return;
                }
                
                currentActiveLot = parseInt(lotVal);
                currentActiveArea = null;
                currentActiveVehicleType = null;

                // Populate Area dropdown
                const areas = lotAreas[currentActiveLot] || [];
                const areaSelect = $('#areaSelect');
                areaSelect.empty().append('<option value="" disabled selected>-- Chọn khu vực --</option>');
                
                areas.forEach(area => {
                    areaSelect.append(`<option value="${area.value}">${area.label}</option>`);
                });

                areaSelect.prop('disabled', false);

                // Reset and disable Vehicle Type dropdown
                $('#vehicleTypeSelect').empty().append('<option value="" disabled selected>-- Chọn khu vực trước --</option>').prop('disabled', true);

                // Hide form, show prompt
                $('#inlinePricingForm').hide();
                $('#selectPromptCard').show();
            });

            // Handle Area dropdown change
            $('#areaSelect').change(function() {
                currentActiveArea = $(this).val();
                
                const areaConfig = lotAreas[currentActiveLot].find(a => a.value === currentActiveArea);
                const typeSelect = $('#vehicleTypeSelect');
                typeSelect.empty().append('<option value="" disabled>-- Chọn loại xe --</option>');

                if (areaConfig) {
                    // Populate all system vehicle types
                    vehicleTypes.forEach(vt => {
                        const selectedAttr = (vt.value === areaConfig.type) ? 'selected' : '';
                        typeSelect.append(`<option value="${vt.value}" ${selectedAttr}>${vt.label}</option>`);
                    });
                    
                    typeSelect.prop('disabled', false);
                    currentActiveVehicleType = areaConfig.type;

                    // Load pricing and reveal form
                    loadPricing();
                    $('#selectPromptCard').hide();
                    $('#inlinePricingForm').show().addClass('animated-fade-in');
                    setTimeout(() => {
                        $('#inlinePricingForm').removeClass('animated-fade-in');
                    }, 450);
                } else {
                    resetSelection();
                }
            });

            // Handle Vehicle Type dropdown change manually
            $('#vehicleTypeSelect').change(function() {
                currentActiveVehicleType = $(this).val();
                if (currentActiveLot && currentActiveVehicleType) {
                    loadPricing();
                }
            });

            // Handle Pricing Edit Form Submit
            $('#inlinePricingForm').submit(function(e) {
                e.preventDefault();

                const data = pricingData[currentActiveLot][currentActiveVehicleType];
                if (data) {
                    // Update mock pricing database directly from card inputs
                    data.giaTheoGio = parseInt($('#inputGiaTheoGio').val()) || 0;
                    data.giaQuaDem = parseInt($('#inputGiaQuaDem').val()) || 0;
                    data.giaTheoThang = parseInt($('#inputGiaTheoThang').val()) || 0;
                    data.giaDatCho = parseInt($('#inputGiaDatCho').val()) || 0;
                    data.trangThai = $('#switchStatus').is(':checked');

                    // Prepend a log item into Audit Log table
                    const now = new Date();
                    const formattedTime = `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')} - ${now.getDate().toString().padStart(2, '0')}/${(now.getMonth() + 1).toString().padStart(2, '0')}/${now.getFullYear()}`;
                    
                    const areaConfig = lotAreas[currentActiveLot].find(a => a.value === currentActiveArea);
                    const areaLabel = areaConfig ? areaConfig.label : '';

                    const vehicleConfig = vehicleTypes.find(v => v.value === currentActiveVehicleType);
                    const vehicleLabel = vehicleConfig ? vehicleConfig.label : '';

                    // Push to prepended list
                    auditLogs.unshift({
                        lotName: data.lotName,
                        areaLabel: areaLabel,
                        vehicleLabel: vehicleLabel,
                        time: formattedTime,
                        user: 'Lê Văn Chủ',
                        giaTheoGio: data.giaTheoGio,
                        giaQuaDem: data.giaQuaDem,
                        giaTheoThang: data.giaTheoThang,
                        giaDatCho: data.giaDatCho,
                        status: 'Vừa cập nhật',
                        statusClass: 'bg-success-light text-success'
                    });

                    // Reset to first page
                    currentPage = 1;
                    renderAuditLogs();

                    // Re-load UI cards to enforce clean visual state
                    loadPricing();

                    alert(`Đã áp dụng đơn giá mới thành công cho ${vehicleLabel} tại bãi ${data.lotName}!`);
                }
            });

            // Dynamic change opacity visual indicator for switch status changes on the fly
            $('#switchStatus').change(function() {
                const isActive = $(this).is(':checked');
                updateStatusBadge($('#status-day'), isActive);
                updateStatusBadge($('#status-night'), isActive);
                updateStatusBadge($('#status-monthly'), isActive);
                updateStatusBadge($('#status-booking'), isActive);

                if (!isActive) {
                    $('#pricingCardsContainer').css('opacity', '0.7');
                } else {
                    $('#pricingCardsContainer').css('opacity', '1');
                }
            });
        });

        // Dynamic rendering of audit logs table with client-side pagination
        function renderAuditLogs() {
            const tbody = $('#historyTableBody');
            tbody.empty();

            const startIndex = (currentPage - 1) * rowsPerPage;
            const endIndex = startIndex + rowsPerPage;
            const paginatedItems = auditLogs.slice(startIndex, endIndex);

            if (paginatedItems.length === 0) {
                tbody.html('<tr><td colspan="9" class="text-center text-muted py-4">Chưa có lịch sử điều chỉnh</td></tr>');
                $('#paginationInfo').text('Hiển thị 0 - 0 trong tổng số 0 nhật ký');
                $('#paginationControls').empty();
                return;
            }

            paginatedItems.forEach(log => {
                const row = `
                    <tr style="animation: tableRowFadeIn 0.4s ease-out;">
                        <td><strong>${log.lotName}</strong></td>
                        <td><span class="badge bg-light text-primary border">${log.areaLabel} - ${log.vehicleLabel}</span></td>
                        <td class="text-muted">${log.time}</td>
                        <td>${log.user}</td>
                        <td><span class="badge bg-light text-dark border history-badge">${log.giaTheoGio.toLocaleString()}đ</span></td>
                        <td><span class="badge bg-light text-dark border history-badge">${log.giaQuaDem.toLocaleString()}đ</span></td>
                        <td><span class="badge bg-light text-dark border history-badge">${log.giaTheoThang.toLocaleString()}đ</span></td>
                        <td><span class="badge bg-light text-dark border history-badge">${log.giaDatCho}%</span></td>
                        <td><span class="badge ${log.statusClass} px-2 py-1 rounded">${log.status}</span></td>
                    </tr>
                `;
                tbody.append(row);
            });

            // Update stats info text
            const totalRecords = auditLogs.length;
            const currentStart = startIndex + 1;
            const currentEnd = Math.min(endIndex, totalRecords);
            $('#paginationInfo').text(`Hiển thị ${currentStart} - ${currentEnd} trong tổng số ${totalRecords} nhật ký`);

            renderPaginationControls();
        }

        // Generate paginator elements
        function renderPaginationControls() {
            const paginationContainer = $('#paginationControls');
            paginationContainer.empty();

            const totalPages = Math.ceil(auditLogs.length / rowsPerPage);
            if (totalPages <= 1) return;

            let html = `<nav aria-label="Page navigation"><ul class="pagination pagination-sm m-0 justify-content-end gap-1">`;
            
            // Previous button
            html += `
                <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                    <a class="page-link rounded-3 border-light shadow-sm py-1.5 px-2.5" href="#" onclick="changePage(${currentPage - 1}); return false;" aria-label="Previous">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>
            `;

            for (let i = 1; i <= totalPages; i++) {
                html += `
                    <li class="page-item ${currentPage === i ? 'active' : ''}">
                        <a class="page-link rounded-3 border-light shadow-sm fw-bold py-1.5 px-3" href="#" onclick="changePage(${i}); return false;">${i}</a>
                    </li>
                `;
            }

            // Next button
            html += `
                <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                    <a class="page-link rounded-3 border-light shadow-sm py-1.5 px-2.5" href="#" onclick="changePage(${currentPage + 1}); return false;" aria-label="Next">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            `;

            html += `</ul></nav>`;
            paginationContainer.html(html);
        }

        // Navigate page helper
        window.changePage = function(page) {
            const totalPages = Math.ceil(auditLogs.length / rowsPerPage);
            if (page < 1 || page > totalPages) return;
            currentPage = page;
            renderAuditLogs();
        };

        function resetSelection() {
            currentActiveLot = null;
            currentActiveArea = null;
            currentActiveVehicleType = null;
            $('#areaSelect').empty().append('<option value="" disabled selected>-- Chọn bãi xe trước --</option>').prop('disabled', true);
            $('#vehicleTypeSelect').empty().append('<option value="" disabled selected>-- Chọn khu vực trước --</option>').prop('disabled', true);
            $('#inlinePricingForm').hide();
            $('#selectPromptCard').show();
        }

        // Load pricing database values directly into input fields
        function loadPricing() {
            const data = pricingData[currentActiveLot][currentActiveVehicleType];
            if (!data) return;

            // Load values to inputs embedded inside the cards
            $('#inputGiaTheoGio').val(data.giaTheoGio);
            $('#inputGiaQuaDem').val(data.giaQuaDem);
            $('#inputGiaTheoThang').val(data.giaTheoThang);
            $('#inputGiaDatCho').val(data.giaDatCho);
            $('#switchStatus').prop('checked', data.trangThai);

            // Set state badges
            updateStatusBadge($('#status-day'), data.trangThai);
            updateStatusBadge($('#status-night'), data.trangThai);
            updateStatusBadge($('#status-monthly'), data.trangThai);
            updateStatusBadge($('#status-booking'), data.trangThai);

            // Handle inactive state appearance visually
            if (!data.trangThai) {
                $('#pricingCardsContainer').css('opacity', '0.7');
            } else {
                $('#pricingCardsContainer').css('opacity', '1');
            }
        }

        // Toggle pricing active status indicators
        function updateStatusBadge(element, isActive) {
            element.removeClass('pricing-status active inactive bg-success-light text-success bg-danger-light text-danger');
            if (isActive) {
                element.addClass('pricing-status active').html('<i class="fa-solid fa-circle-check"></i> Đang áp dụng');
            } else {
                element.addClass('pricing-status inactive').html('<i class="fa-solid fa-circle-xmark"></i> Tạm ngưng');
            }
        }
    </script>
}
