@{
    ViewData["Title"] = "Quản lý giá";
}

<!-- Custom Styles for Embedded Inline Card inputs -->
<style>
    .pricing-card {
        background-color: var(--owner-card-bg);
        border: 1px solid var(--owner-border);
        border-radius: 20px;
        padding: 24px;
        position: relative;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: var(--owner-shadow-sm);
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .pricing-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 20px -8px rgba(79, 70, 229, 0.12);
        border-color: rgba(79, 70, 229, 0.25);
    }

    /* Gradients for pricing header background decorations */
    .pricing-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 6px;
    }

    .pricing-card.rate-day::before {
        background: linear-gradient(90deg, #f59e0b 0%, #d97706 100%);
    }

    .pricing-card.rate-night::before {
        background: linear-gradient(90deg, #4f46e5 0%, #312e81 100%);
    }

    .pricing-card.rate-monthly::before {
        background: linear-gradient(90deg, #10b981 0%, #059669 100%);
    }

    .pricing-card.rate-booking::before {
        background: linear-gradient(90deg, #06b6d4 0%, #0891b2 100%);
    }

    .pricing-icon-wrapper {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        margin-bottom: 16px;
        transition: transform 0.3s ease;
    }

    .pricing-card:hover .pricing-icon-wrapper {
        transform: scale(1.1) rotate(5deg);
    }

    .rate-day .pricing-icon-wrapper {
        background-color: var(--owner-warning-light);
        color: var(--owner-warning);
    }

    .rate-night .pricing-icon-wrapper {
        background-color: var(--owner-primary-light);
        color: var(--owner-primary);
    }

    .rate-monthly .pricing-icon-wrapper {
        background-color: var(--owner-success-light);
        color: var(--owner-success);
    }

    .rate-booking .pricing-icon-wrapper {
        background-color: var(--owner-info-light);
        color: var(--owner-info);
    }

    .pricing-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--owner-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 12px;
    }

    /* Embedded borderless inputs */
    .card-input-wrapper {
        background-color: #f1f5f9;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        transition: all 0.2s ease;
        margin-bottom: 12px;
        display: flex !important;
        flex-wrap: nowrap !important;
        align-items: center;
    }

    .card-input-wrapper:focus-within {
        background-color: #ffffff;
        border-color: var(--owner-primary);
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.12);
    }

    .card-input-field {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 800;
        font-size: 1.6rem;
        color: var(--owner-text-main);
        outline: none;
        border: none;
        background: transparent;
        box-shadow: none !important;
        padding: 6px 4px 6px 16px;
        flex: 1;
        min-width: 0;
        text-align: left;
    }

    .card-input-unit {
        font-weight: 750;
        font-size: 1.1rem;
        color: var(--owner-text-muted);
        background: transparent;
        border: none;
        padding-right: 16px;
        display: flex;
        align-items: center;
        flex-shrink: 0;
        white-space: nowrap;
    }

    .pricing-desc {
        font-size: 0.85rem;
        color: var(--owner-text-muted);
        line-height: 1.4;
    }

    .pricing-status {
        font-size: 0.72rem;
        font-weight: 750;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 3px 8px;
        border-radius: 20px;
        margin-top: 12px;
    }

    .pricing-status.active {
        background-color: var(--owner-success-light);
        color: var(--owner-success);
    }

    .pricing-status.inactive {
        background-color: var(--owner-danger-light);
        color: var(--owner-danger);
    }

    /* Interactive area filter buttons */
    .filter-btn {
        border-radius: 30px;
        padding: 6px 18px;
        font-weight: 600;
        font-size: 0.875rem;
        transition: var(--owner-transition);
        border: 1px solid var(--owner-border);
        background-color: #ffffff;
        color: var(--owner-text-muted);
    }

    .filter-btn:hover {
        background-color: #f1f5f9;
        color: var(--owner-text-main);
    }

    .filter-btn.active {
        background-color: var(--owner-primary);
        border-color: var(--owner-primary);
        color: #ffffff;
        box-shadow: 0 4px 10px rgba(79, 70, 229, 0.2);
    }

    .history-badge {
        font-family: 'Plus Jakarta Sans', monospace;
        font-weight: 650;
    }

    /* Animation for pricing form appearance */
    @@keyframes slideUpFade {
        from {
            opacity: 0;
            transform: translateY(15px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animated-fade-in {
        animation: slideUpFade 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>

<div class="d-flex flex-column mb-4">
    <h1 class="owner-page-title">Cấu hình bảng giá</h1>
    <p class="owner-page-subtitle">Chọn bãi đỗ xe, khu vực và loại xe để bắt đầu điều chỉnh đơn giá.</p>
</div>

<!-- Prerequisite Selection Card -->
<div class="card shadow-sm border-0 mb-4" style="border-radius: 16px; background-color: var(--owner-card-bg); border: 1px solid var(--owner-border);">
    <div class="card-body p-4">
        <div class="row align-items-center g-3">
            <!-- Bãi xe selection -->
            <div class="col-12 col-md-4">
                <div class="d-flex flex-column gap-1">
                    <label class="small fw-bold text-muted text-uppercase mb-1" for="lotSelect"><i class="fa-solid fa-warehouse text-primary me-1"></i> Bãi xe:</label>
                    <select class="form-select rounded-3 border-light shadow-sm py-2.5" id="lotSelect" style="border: 1px solid #cbd5e1 !important;">
                        <option value="" disabled selected>-- Chọn bãi xe --</option>
                        <option value="1">SPMS Cống Quỳnh - Quận 1</option>
                        <option value="2">SPMS Sunrise City - Quận 7</option>
                        <option value="3">SPMS Landmark Plus - Bình Thạnh (Chờ duyệt)</option>
                    </select>
                </div>
            </div>
            <!-- Khu vực selection -->
            <div class="col-12 col-md-4">
                <div class="d-flex flex-column gap-1">
                    <label class="small fw-bold text-muted text-uppercase mb-1" for="areaSelect"><i class="fa-solid fa-layer-group text-primary me-1"></i> Khu vực:</label>
                    <select class="form-select rounded-3 border-light shadow-sm py-2.5" id="areaSelect" disabled style="border: 1px solid #cbd5e1 !important;">
                        <option value="" disabled selected>-- Chọn bãi xe trước --</option>
                    </select>
                </div>
            </div>
            <!-- Loại xe selection -->
            <div class="col-12 col-md-4">
                <div class="d-flex flex-column gap-1">
                    <label class="small fw-bold text-muted text-uppercase mb-1" for="vehicleTypeSelect"><i class="fa-solid fa-car text-primary me-1"></i> Loại xe:</label>
                    <select class="form-select rounded-3 border-light shadow-sm py-2.5" id="vehicleTypeSelect" disabled style="border: 1px solid #cbd5e1 !important;">
                        <option value="" disabled selected>-- Chọn khu vực trước --</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Select Prompt Card -->
<div class="card text-center p-5 border-0 shadow-sm mb-4" id="selectPromptCard" style="border-radius: 20px; background-color: var(--owner-card-bg); border: 1px solid var(--owner-border) !important;">
    <div class="card-body py-5">
        <div class="bg-primary-light text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px; font-size: 2.2rem; background-color: rgba(79, 70, 229, 0.08);">
            <i class="fa-solid fa-square-parking"></i>
        </div>
        <h4 class="fw-bold text-dark mb-2">Yêu cầu chọn thông tin bãi đỗ</h4>
        <p class="text-muted mx-auto mb-0" style="max-width: 480px; font-size: 0.95rem;">Bạn cần chọn bãi đỗ xe, khu vực và loại xe tương ứng trước khi có thể cập nhật hoặc xem giá tiền của các vị trí đỗ.</p>
    </div>
</div>

<!-- Main One-Page Price Form -->
<form id="inlinePricingForm">
    
    <!-- Pricing Cards Grid -->
    <div class="row g-4 mb-4" id="pricingCardsContainer">
        <!-- Card 1: GiaTheoGio -->
        <div class="col-xl-3 col-md-6">
            <div class="pricing-card rate-day">
                <div>
                    <div class="pricing-icon-wrapper">
                        <i class="fa-solid fa-sun"></i>
                    </div>
                    <div class="pricing-title">Giá theo giờ (Ngày)</div>
                    
                    <!-- Embedded Input Group -->
                    <div class="input-group card-input-wrapper">
                        <input type="number" class="card-input-field" id="inputGiaTheoGio" min="0" step="1000" required>
                        <span class="card-input-unit">đ</span>
                    </div>

                    <p class="pricing-desc mb-0">Áp dụng cho mỗi giờ đỗ xe ô tô vào ban ngày (từ 06:00 đến 22:00 hàng ngày).</p>
                </div>
                <div>
                    <span class="pricing-status active" id="status-day">
                        <i class="fa-solid fa-circle-check"></i> Đang áp dụng
                    </span>
                </div>
            </div>
        </div>

        <!-- Card 2: GiaQuaDem -->
        <div class="col-xl-3 col-md-6">
            <div class="pricing-card rate-night">
                <div>
                    <div class="pricing-icon-wrapper">
                        <i class="fa-solid fa-moon"></i>
                    </div>
                    <div class="pricing-title">Giá qua đêm (Đêm)</div>
                    
                    <!-- Embedded Input Group -->
                    <div class="input-group card-input-wrapper">
                        <input type="number" class="card-input-field" id="inputGiaQuaDem" min="0" step="1000" required>
                        <span class="card-input-unit">đ</span>
                    </div>

                    <p class="pricing-desc mb-0">Áp dụng trọn gói cho lượt gửi xe qua đêm (từ 22:00 đến 06:00 sáng hôm sau).</p>
                </div>
                <div>
                    <span class="pricing-status active" id="status-night">
                        <i class="fa-solid fa-circle-check"></i> Đang áp dụng
                    </span>
                </div>
            </div>
        </div>

        <!-- Card 3: GiaTheoThang -->
        <div class="col-xl-3 col-md-6">
            <div class="pricing-card rate-monthly">
                <div>
                    <div class="pricing-icon-wrapper">
                        <i class="fa-solid fa-calendar-days"></i>
                    </div>
                    <div class="pricing-title">Giá vé theo tháng</div>
                    
                    <!-- Embedded Input Group -->
                    <div class="input-group card-input-wrapper">
                        <input type="number" class="card-input-field" id="inputGiaTheoThang" min="0" step="1000" required>
                        <span class="card-input-unit">đ</span>
                    </div>

                    <p class="pricing-desc mb-0">Áp dụng cho khách hàng đăng ký thuê bao đỗ cố định dài hạn theo chu kỳ 30 ngày.</p>
                </div>
                <div>
                    <span class="pricing-status active" id="status-monthly">
                        <i class="fa-solid fa-circle-check"></i> Đang áp dụng
                    </span>
                </div>
            </div>
        </div>

        <!-- Card 4: GiaDatCho -->
        <div class="col-xl-3 col-md-6">
            <div class="pricing-card rate-booking">
                <div>
                    <div class="pricing-icon-wrapper">
                        <i class="fa-solid fa-percent"></i>
                    </div>
                    <div class="pricing-title">Phí cọc</div>
                    
                    <!-- Embedded Input Group -->
                    <div class="input-group card-input-wrapper">
                        <input type="number" class="card-input-field" id="inputGiaDatCho" min="5" max="100" step="5" required>
                        <span class="card-input-unit">%</span>
                    </div>

                    <p class="pricing-desc mb-0">Tỷ lệ đặt cọc giữ chỗ trước trên ứng dụng (phần trăm trên tổng hóa đơn dự kiến).</p>
                </div>
                <div>
                    <span class="pricing-status active" id="status-booking">
                        <i class="fa-solid fa-circle-check"></i> Đang áp dụng
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Master Controls Row -->
    <div class="owner-table-card border-0 mb-4 p-3 bg-white">
        <button type="submit" class="btn btn-primary-custom px-5 py-2.5 rounded-3 d-flex align-items-center gap-2">
            <i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi bảng giá
        </button>
    </div>
</form>

<!-- History Log Section -->
<div class="owner-table-card border-0">
    <div class="owner-card-header bg-transparent border-0 px-4 pt-4">
        <h5 class="owner-card-title fs-5"><i class="fa-solid fa-history text-primary me-2"></i> Nhật ký điều chỉnh bảng giá</h5>
    </div>
    <div class="table-responsive p-4 pt-2">
        <table class="table owner-table border">
            <thead>
                <tr>
                    <th>Bãi Đỗ Xe</th>
                    <th>Loại Xe</th>
                    <th>Thời Gian Áp Dụng</th>
                    <th>Người Điều Chỉnh</th>
                    <th>Giá Theo Giờ</th>
                    <th>Giá Qua Đêm</th>
                    <th>Giá Theo Tháng</th>
                    <th>Tỷ Lệ Cọc</th>
                    <th>Trạng Thái</th>
                </tr>
            </thead>
            <tbody id="historyTableBody">
                <!-- Javascript populated -->
            </tbody>
        </table>
    </div>
    <!-- Pagination Footer -->
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-3 px-4 pb-4">
        <div class="text-muted small" id="paginationInfo">
            Hiển thị 0 - 0 trong tổng số 0 nhật ký
        </div>
        <div id="paginationControls">
            <!-- Dynamic pagination controls -->
        </div>
    </div>
</div>

