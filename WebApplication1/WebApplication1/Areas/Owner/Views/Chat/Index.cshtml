                { from: 'customer', text: 'Hỏi về chính sách hoàn tiền khi hủy đặt chỗ bạn?', time: '20:00' },
                { from: 'owner',    text: 'Dạ! Nếu hủy trước 2 tiếng thì hoàn 100%, trước 30 phút hoàn 50%, sau đó không hoàn nhé.', time: '20:05' },
                { from: 'customer', text: 'Vậy ổn rồi.', time: '20:10' },
                { from: 'customer', text: 'Ok bạn nhé, tôi sẽ đặt vào ngày mai.', time: '20:15' }
            ]
        },
        {
            id: 4,
            name: 'Phạm Minh Đức',
            initials: 'MD',
            phone: '0944 567 890',
            email: 'phammd@@gmail.com',
            status: 'offline',
            unread: 0,
            lastMsg: 'Vâng cảm ơn ạ.',
            lastTime: 'Hôm qua',
            totalBookings: 3,
            since: 'Tháng 4/2026',
            bookings: [],
            messages: [
                { from: 'customer', text: 'Làm thế nào để thay đổi biển số xe trong app?', time: 'Hôm qua 15:30' },
                { from: 'owner',    text: 'Bạn vào mục Tài khoản → Phương tiện → Chỉnh sửa nhé!', time: 'Hôm qua 15:32' },
                { from: 'customer', text: 'Vâng cảm ơn ạ.', time: 'Hôm qua 15:33' }
            ]
        }
    ];

    let currentConvId = null;
    let currentFilter = 'all';
    let searchQuery = '';

    // ===== RENDER CONVERSATION LIST =====
    function renderConvList() {
        const list = document.getElementById('conversationList');
        list.innerHTML = '';

        let data = conversations;

        // Apply filter
        if (currentFilter === 'unread') data = data.filter(c => c.unread > 0);
        if (currentFilter === 'active') data = data.filter(c => c.status === 'online');

        // Apply search
        if (searchQuery) {
            data = data.filter(c => c.name.toLowerCase().includes(searchQuery));
        }

        if (data.length === 0) {
            list.innerHTML = '<div style="padding:30px 18px; text-align:center; color:var(--owner-text-muted); font-size:0.85rem;">Không tìm thấy cuộc trò chuyện nào.</div>';
            return;
        }

        data.forEach(c => {
            const active = currentConvId === c.id ? 'active' : '';
            const unreadHTML = c.unread > 0
                ? `<span class="unread-count-badge">${c.unread}</span>`
                : (c.status === 'online' ? '' : '');
            const previewClass = c.unread > 0 ? 'unread' : '';
            list.innerHTML += `
                <div class="conv-item ${active}" onclick="openConversation(${c.id})">
                    <div class="conv-avatar ${c.status}">${c.initials}</div>
                    <div class="conv-info">
                        <div class="conv-name">${c.name}</div>
                        <div class="conv-preview ${previewClass}">${c.lastMsg}</div>
                    </div>
                    <div class="conv-meta">
                        <span class="conv-time">${c.lastTime}</span>
                        ${unreadHTML}
                    </div>
                </div>
            `;
        });
    }

    // ===== OPEN CONVERSATION =====
    function openConversation(id) {
        currentConvId = id;
        const conv = conversations.find(c => c.id === id);
        if (!conv) return;

        // Mark as read
        conv.unread = 0;
        updateUnreadTotal();

        // Show active chat area
        document.getElementById('chatEmptyState').style.display = 'none';
        const area = document.getElementById('chatActiveArea');
        area.style.display = 'flex';

        // Update header
        document.getElementById('chatHeaderAvatar').textContent = conv.initials;
        document.getElementById('chatHeaderName').textContent = conv.name;
        const statusEl = document.getElementById('chatHeaderStatus');
        if (conv.status === 'online') { statusEl.className = 'chat-header-status'; statusEl.textContent = '● Đang hoạt động'; }
        else if (conv.status === 'away') { statusEl.className = 'chat-header-status away'; statusEl.textContent = '● Vắng mặt'; }
        else { statusEl.className = 'chat-header-status offline'; statusEl.textContent = '○ Ngoại tuyến'; }

        // Render messages
        const messagesEl = document.getElementById('chatMessages');
        messagesEl.innerHTML = '';
        messagesEl.innerHTML += `<div class="chat-date-divider">Hôm nay, 24/05/2026</div>`;
        conv.messages.forEach(m => appendMessage(m.from, m.text, m.time, false));
        messagesEl.scrollTop = messagesEl.scrollHeight;

        // Update info panel
        document.getElementById('infoPanelEmpty').style.display = 'none';
        document.getElementById('infoPanelContent').style.display = 'block';
        document.getElementById('ip-name').textContent = conv.name;
        document.getElementById('ip-phone').textContent = conv.phone;
        document.getElementById('ip-email').textContent = conv.email;
        const statusText = conv.status === 'online' ? '🟢 Online' : conv.status === 'away' ? '🟡 Vắng' : '⚫ Offline';
        document.getElementById('ip-status').textContent = statusText;
        document.getElementById('ip-total').textContent = conv.totalBookings + ' lượt';
        document.getElementById('ip-since').textContent = conv.since;

        const bookingsEl = document.getElementById('ip-bookings');
        if (conv.bookings.length === 0) {
            bookingsEl.innerHTML = '<span style="font-size:0.8rem; color:var(--owner-text-muted);">Không có đặt chỗ hiện tại.</span>';
        } else {
            bookingsEl.innerHTML = conv.bookings.map(b => `
                <div class="booking-tag"><i class="fa-solid fa-square-parking"></i> ${b.spot} – ${b.lot}</div>
                <div style="font-size:0.78rem; color:var(--owner-text-muted); margin-bottom:4px;">${b.code} | ${b.date}</div>
            `).join('');
        }

        // Re-render list to update active state
        renderConvList();
    }

    // ===== APPEND MESSAGE TO CHAT =====
    function appendMessage(from, text, time, animate = true) {
        const el = document.getElementById('chatMessages');
        const rowClass = from === 'owner' ? 'from-owner' : 'from-customer';
        const initials = from === 'owner' ? 'CN' : (conversations.find(c => c.id === currentConvId)?.initials || 'KH');
        const avatarStyle = from === 'owner'
            ? 'background:linear-gradient(135deg,var(--owner-primary),#818cf8);'
            : 'background:linear-gradient(135deg,#e0e7ff,#c7d2fe); color:var(--owner-primary);';

        el.innerHTML += `
            <div class="msg-row ${rowClass}" style="${animate ? '' : ''}">
                <div class="msg-avatar-sm" style="${avatarStyle}">${initials}</div>
                <div>
                    <div class="msg-bubble">${text}<span class="msg-time">${time}</span></div>
                </div>
            </div>
        `;
        el.scrollTop = el.scrollHeight;
    }

    // ===== SEND MESSAGE =====
    function sendMessage() {
        const input = document.getElementById('chatInput');
        const text = input.value.trim();
        if (!text || !currentConvId) return;

        const now = new Date();
        const time = now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0');
        appendMessage('owner', text, time, true);

        // Update last message in conv list
        const conv = conversations.find(c => c.id === currentConvId);
        if (conv) {
            conv.messages.push({ from: 'owner', text, time });
            conv.lastMsg = text;
            conv.lastTime = time;
        }

        input.value = '';
        input.style.height = 'auto';
        renderConvList();

        // Simulate customer response after 2s
        if (conv && conv.status === 'online') {
            setTimeout(() => {
                const autoReplies = [
                    'Cảm ơn bạn đã phản hồi!',
                    'Vâng, tôi hiểu rồi ạ.',
                    'Ok được, cảm ơn bạn nhé 😊',
                    'Mình sẽ thử lại ngay!'
                ];
                const reply = autoReplies[Math.floor(Math.random() * autoReplies.length)];
                appendMessage('customer', reply, time, true);
                conv.messages.push({ from: 'customer', text: reply, time });
                conv.lastMsg = reply;
                conv.lastTime = time;
                renderConvList();
            }, 2000);
        }
    }

    // ===== QUICK REPLY =====
    function sendQuickReply(btn) {
        const input = document.getElementById('chatInput');
        input.value = btn.textContent;
        input.focus();
    }

    // ===== MARK RESOLVED =====
    function markResolved() {
        if (!currentConvId) return;
        const conv = conversations.find(c => c.id === currentConvId);
        if (!conv) return;
        const time = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
        const el = document.getElementById('chatMessages');
        el.innerHTML += `
            <div style="text-align:center; margin:10px 0;">
                <span style="background:var(--owner-success-light); color:var(--owner-success); font-size:0.75rem; font-weight:700; padding:4px 12px; border-radius:20px;">
                    <i class="fa-solid fa-circle-check"></i> Đã đánh dấu xử lý xong lúc ${time}
                </span>
            </div>
        `;
        el.scrollTop = el.scrollHeight;
    }

    // ===== FILTER TABS =====
    function filterConvs(filter, btn) {
        currentFilter = filter;
        document.querySelectorAll('.chat-filter-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        renderConvList();
    }

    // ===== UPDATE UNREAD BADGE =====
    function updateUnreadTotal() {
        const total = conversations.reduce((s, c) => s + c.unread, 0);
        const badge = document.getElementById('unreadTotalBadge');
        badge.textContent = total;
        badge.style.display = total > 0 ? '' : 'none';
    }

    // ===== SEARCH =====
    document.getElementById('convSearchInput').addEventListener('input', function () {
        searchQuery = this.value.toLowerCase().trim();
        renderConvList();
    });

    // ===== AUTO-GROW TEXTAREA =====
    document.getElementById('chatInput').addEventListener('input', function () {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });

    // ===== SEND ON ENTER (SHIFT+ENTER = new line) =====
    document.getElementById('chatInput').addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    // ===== INIT =====
    renderConvList();
    updateUnreadTotal();
</script>
}
