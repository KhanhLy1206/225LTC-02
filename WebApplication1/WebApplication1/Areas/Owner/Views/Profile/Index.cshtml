@using WebApplication1.Models.Entities
@{
    Layout = "~/Areas/Owner/Views/Shared/_OwnerLayout.cshtml";
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
    var owner = ViewBag.Owner as ChuBaiXe;
    var provinces = ViewBag.Provinces as List<TinhThanh> ?? new List<TinhThanh>();
    var districts = ViewBag.Districts as List<QuanHuyen> ?? new List<QuanHuyen>();
    var wards = ViewBag.Wards as List<XaPhuong> ?? new List<XaPhuong>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="owner-page-title">Hồ sơ cá nhân</h1>
        <p class="owner-page-subtitle">Xem thông tin chi tiết tài khoản của bạn, cập nhật thông tin liên hệ và thay đổi mật khẩu.</p>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Left Column: Personal details update form -->
    <div class="col-lg-8">
        <div class="owner-table-card border-0 mb-0">
            <div class="owner-card-header">
                <h5 class="owner-card-title"><i class="fa-solid fa-user-pen text-primary me-2"></i>Cập nhật thông tin cá nhân</h5>
            </div>
            
            <form id="updateOwnerProfileForm" class="p-4">
                <div class="row g-3">
                    <!-- Full Name -->
                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-dark" for="profileName">Họ và Tên</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-user"></i></span>
                            <input type="text" class="form-control rounded-end-3" id="profileName" value="@(owner?.TenChuBai ?? "")" required placeholder="Nhập họ và tên..." />
                        </div>
                    </div>

                    <!-- Phone Number -->
                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-dark" for="profilePhone">Số điện thoại</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-phone"></i></span>
                            <input type="tel" class="form-control rounded-end-3" id="profilePhone" value="@(owner?.SDT ?? "")" required placeholder="Nhập số điện thoại..." />
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-dark" for="profileEmail">Địa chỉ Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-envelope"></i></span>
                            <input type="email" class="form-control rounded-end-3" id="profileEmail" value="@(owner?.Email ?? "")" required placeholder="name@example.com" />
                        </div>
                    </div>

                    <!-- CCCD / Identity Card -->
                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-dark" for="profileCccd">Số CCCD / Hộ chiếu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-id-card"></i></span>
                            <input type="text" class="form-control rounded-end-3" id="profileCccd" value="@(owner?.CCCD ?? "")" required placeholder="Số căn cước công dân..." />
                        </div>
                    </div>

                    <!-- Cascading Address Selector -->
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-dark" for="provinceSelect">Tỉnh / Thành</label>
                        <select class="form-select rounded-3" id="provinceSelect" required>
                            <option value="">-- Chọn Tỉnh --</option>
                            @foreach (var p in provinces)
                            {
                                bool isSelected = (p.MaTinh == ViewBag.CurrentTinh);
                                <!option value="@p.MaTinh" @(isSelected ? "selected" : "")>@p.TenTinh</!option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-dark" for="districtSelect">Quận / Huyện</label>
                        <select class="form-select rounded-3" id="districtSelect" required @(districts.Count == 0 ? "disabled" : "")>
                            <option value="">-- Chọn Huyện --</option>
                            @foreach (var d in districts)
                            {
                                bool isSelected = (d.MaHuyen == ViewBag.CurrentHuyen);
                                <!option value="@d.MaHuyen" @(isSelected ? "selected" : "")>@d.TenHuyen</!option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-dark" for="wardSelect">Xã / Phường</label>
                        <select class="form-select rounded-3" id="wardSelect" required @(wards.Count == 0 ? "disabled" : "")>
                            <option value="">-- Chọn Xã --</option>
                            @foreach (var w in wards)
                            {
                                bool isSelected = (w.MaXa == ViewBag.CurrentXa);
                                <!option value="@w.MaXa" @(isSelected ? "selected" : "")>@w.TenXa</!option>
                            }
                        </select>
                    </div>

                    <!-- Detail Address -->
                    <div class="col-md-12">
                        <label class="form-label small fw-bold text-dark" for="profileStreet">Địa chỉ chi tiết (Số nhà, tên đường)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-house"></i></span>
                            <input type="text" class="form-control rounded-end-3" id="profileStreet" value="@(owner?.DiaChiChiTiet ?? "")" required placeholder="Nhập địa chỉ nhà cụ thể..." />
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-2 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary-custom px-4 py-2 d-flex align-items-center gap-2">
                        <i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Right Column: Card preview & Security password changes -->
    <div class="col-lg-4">
        <!-- Quick Preview card -->
        <div class="owner-table-card p-4 text-center mb-4">
            <div class="position-relative d-inline-block mx-auto mb-3">
                <img src="@(string.IsNullOrEmpty(owner?.TaiKhoan?.AnhDaiDien) ? "https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&q=80&w=100" : owner.TaiKhoan.AnhDaiDien)" 
                     id="ownerProfileAvatarPreview" 
                     class="owner-avatar border border-3 border-light shadow-sm" 
                     style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover;" 
                     alt="Avatar" />
                <label for="avatarUploadInput" class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center cursor-pointer shadow-sm" 
                       style="width: 36px; height: 36px; border: 2px solid #ffffff; transition: var(--owner-transition); margin: 0;">
                    <i class="fa-solid fa-camera small"></i>
                </label>
                <input type="file" id="avatarUploadInput" class="d-none" accept="image/*" />
            </div>
            <h5 class="fw-bold text-dark mb-1" id="previewDisplayName">@(owner?.TenChuBai ?? "")</h5>
            <span class="badge bg-primary-light text-primary px-3 py-1.5 rounded-pill mb-2">Chủ Bãi Đối Tác</span>
            <span class="text-muted small d-block mb-3">Mã Đối tác: #CBX-@owner?.ID</span>
            
            <div class="border-top border-light pt-3 text-start">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Tên đăng nhập:</span>
                    <span class="text-dark fw-semibold small">@owner?.TaiKhoan?.TenDangNhap</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Số điện thoại:</span>
                    <span class="text-dark fw-semibold small" id="previewPhone">@owner?.SDT</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted small">Email liên hệ:</span>
                    <span class="text-dark fw-semibold small" id="previewEmail">@owner?.Email</span>
                </div>
            </div>
        </div>

        <!-- Password Change Card -->
        <div class="owner-table-card border-0 mb-0">
            <div class="owner-card-header">
                <h5 class="owner-card-title"><i class="fa-solid fa-shield-halved text-primary me-2"></i>Đổi mật khẩu</h5>
            </div>
            
            <form id="changeOwnerPasswordForm" class="p-4">
                <div class="mb-3">
                    <label class="form-label small fw-bold text-dark" for="oldPassword">Mật khẩu hiện tại</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-lock"></i></span>
                        <input type="password" class="form-control rounded-end-3" id="oldPassword" placeholder="••••••••" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold text-dark" for="newPassword">Mật khẩu mới</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-key"></i></span>
                        <input type="password" class="form-control rounded-end-3" id="newPassword" placeholder="••••••••" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold text-dark" for="confirmNewPassword">Xác nhận mật khẩu mới</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-check-double"></i></span>
                        <input type="password" class="form-control rounded-end-3" id="confirmNewPassword" placeholder="••••••••" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-outline-primary w-100 py-2 rounded-3 mt-2 font-weight-bold">
                    <i class="fa-solid fa-rotate me-1"></i> Đổi mật khẩu
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Cascading address selections using AJAX
            $('#provinceSelect').change(function() {
                const val = $(this).val();
                const $dist = $('#districtSelect');
                const $ward = $('#wardSelect');

                $dist.empty().append('<option value="">-- Chọn Huyện --</option>');
                $ward.empty().append('<option value="">-- Chọn Xã --</option>').attr('disabled', true);

                if (val) {
                    $.getJSON('/Owner/Profile/GetDistricts', { provinceId: val }, function(data) {
                        data.forEach(function(item) {
                            $dist.append(`<option value="${item.id}">${item.name}</option>`);
                        });
                        $dist.removeAttr('disabled');
                    });
                } else {
                    $dist.attr('disabled', true);
                }
            });

            $('#districtSelect').change(function() {
                const val = $(this).val();
                const $ward = $('#wardSelect');

                $ward.empty().append('<option value="">-- Chọn Xã --</option>');

                if (val) {
                    $.getJSON('/Owner/Profile/GetWards', { districtId: val }, function(data) {
                        data.forEach(function(item) {
                            $ward.append(`<option value="${item.id}">${item.name}</option>`);
                        });
                        $ward.removeAttr('disabled');
                    });
                } else {
                    $ward.attr('disabled', true);
                }
            });

            // Update profile submit via AJAX
            $('#updateOwnerProfileForm').submit(function(e) {
                e.preventDefault();
                
                const model = {
                    TenChuBai: $('#profileName').val(),
                    SDT: $('#profilePhone').val(),
                    Email: $('#profileEmail').val(),
                    CCCD: $('#profileCccd').val(),
                    MaXa: $('#wardSelect').val(),
                    DiaChiChiTiet: $('#profileStreet').val()
                };

                $.ajax({
                    url: '/Owner/Profile/UpdateProfile',
                    type: 'POST',
                    data: model,
                    success: function(response) {
                        if (response.success) {
                            $('#previewDisplayName').text(model.TenChuBai);
                            $('#previewPhone').text(model.SDT);
                            $('#previewEmail').text(model.Email);
                            
                            // Update sidebar/topbar profile name dynamically
                            $('.owner-user-name').text(model.TenChuBai);
                            
                            alert('✅ Cập nhật thông tin cá nhân thành công!');
                        } else {
                            alert('❌ Lỗi: ' + (response.message || 'Lỗi không xác định khi cập nhật thông tin.'));
                        }
                    },
                    error: function() {
                        alert('❌ Không thể kết nối đến máy chủ.');
                    }
                });
            });

            // Change password submit via AJAX
            $('#changeOwnerPasswordForm').submit(function(e) {
                e.preventDefault();
                
                const model = {
                    OldPassword: $('#oldPassword').val(),
                    NewPassword: $('#newPassword').val(),
                    ConfirmNewPassword: $('#confirmNewPassword').val()
                };

                $.ajax({
                    url: '/Owner/Profile/ChangePassword',
                    type: 'POST',
                    data: model,
                    success: function(response) {
                        if (response.success) {
                            alert('✅ Đổi mật khẩu thành công!');
                            $('#changeOwnerPasswordForm')[0].reset();
                        } else {
                            alert('❌ Lỗi: ' + (response.message || 'Mật khẩu cũ không chính xác.'));
                        }
                    },
                    error: function() {
                        alert('❌ Không thể kết nối đến máy chủ.');
                    }
                });
            });

            // Instant Avatar Upload via AJAX
            $('#avatarUploadInput').change(function() {
                const fileInput = this;
                if (fileInput.files && fileInput.files[0]) {
                    const formData = new FormData();
                    formData.append('avatarFile', fileInput.files[0]);

                    $.ajax({
                        url: '/Owner/Profile/UploadAvatar',
                        type: 'POST',
                        data: formData,
                        processData: false,
                        contentType: false,
                        success: function(response) {
                            if (response.success) {
                                // Update preview image on page
                                $('#ownerProfileAvatarPreview').attr('src', response.avatarUrl);
                                // Update avatar image on topbar
                                $('.owner-avatar').attr('src', response.avatarUrl);
                                
                                alert('✅ Cập nhật ảnh đại diện thành công!');
                            } else {
                                alert('❌ Lỗi: ' + (response.message || 'Không thể tải lên ảnh đại diện.'));
                            }
                        },
                        error: function() {
                            alert('❌ Lỗi hệ thống khi tải lên ảnh đại diện.');
                        }
                    });
                }
            });
        });
    </script>
}
