                { id: 33, area: 'B', name: 'B-03', type: 'oto', lockCode: 'LOCK-QT-B03', lockState: 'Mở', battery: 68, signal: 4 },
                { id: 34, area: 'B', name: 'B-04', type: 'oto', lockCode: 'LOCK-QT-B04', lockState: 'Đóng', battery: 74, signal: 3 },
                { id: 35, area: 'B', name: 'B-05', type: 'oto', lockCode: 'LOCK-QT-B05', lockState: 'Đóng', battery: 81, signal: 4 },
                { id: 39, area: 'B', name: 'B-09', type: 'oto', lockCode: 'LOCK-QT-B09', lockState: 'Lỗi', battery: 8, signal: 1 }
            ],
            2: [
                { id: 1, area: 'A', name: 'A-01', type: 'oto', lockCode: 'LOCK-SR-A01', lockState: 'Đóng', battery: 96, signal: 4 },
                { id: 2, area: 'A', name: 'A-02', type: 'oto', lockCode: 'LOCK-SR-A02', lockState: 'Đóng', battery: 89, signal: 4 },
