                { id: 12, area: 'A', name: 'A-12', type: 'oto', lockCode: 'LOCK-QT-A12', lockState: 'Đóng', battery: 60, signal: 3 },
                { id: 13, area: 'A', name: 'A-13', type: 'oto', lockCode: 'LOCK-QT-A13', lockState: 'Đóng', battery: 52, signal: 2 },
                { id: 14, area: 'A', name: 'A-14', type: 'oto', lockCode: 'LOCK-QT-A14', lockState: 'Đóng', battery: 84, signal: 3 },
                { id: 15, area: 'A', name: 'A-15', type: 'oto', lockCode: 'LOCK-QT-A15', lockState: 'Đóng', battery: 79, signal: 4 },
                { id: 31, area: 'B', name: 'B-01', type: 'oto', lockCode: 'LOCK-QT-B01', lockState: 'Đóng', battery: 87, signal: 4 },
