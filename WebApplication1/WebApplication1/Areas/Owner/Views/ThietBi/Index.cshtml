            { id: 'CMD-1086', time: '2026-05-24 15:20:10', spotName: 'A-11', lockCode: 'LOCK-QT-A11', operator: 'khachhang01', action: 'Mở khóa', result: 'Thành công', note: 'Yêu cầu mở từ app di động của khách hàng.' }
        ];

        let currentActiveLot = 1;
        let selectedArea = 'all';
        let selectedSpot = 'all';
        let selectedStatus = 'all';

        // Logs pagination & filters
        let selectedSpotFilter = null; // Specific lock code filter
        let logSearchQuery = '';
        let currentLogsPage = 1;
        const logsPerPage = 6;

        $(document).ready(function() {
            // Load filters and refresh page elements
            populateAreaSelect();
            populateSpotSelect();
            refreshDeviceGrid();
            refreshLogsTable();

            // Listeners
            $('#lotSelect').change(function() {
                currentActiveLot = parseInt($(this).val());
                selectedArea = 'all';
                selectedSpot = 'all';
                selectedStatus = 'all';
                $('#statusFilter').val('all');
                
                populateAreaSelect();
                populateSpotSelect();
                refreshDeviceGrid();
            });

            $('#areaSelect').change(function() {
                selectedArea = $(this).val();
                selectedSpot = 'all';
                populateSpotSelect();
                refreshDeviceGrid();
            });

            $('#spotSelect').change(function() {
                selectedSpot = $(this).val();
                refreshDeviceGrid();
            });

            $('#statusFilter').change(function() {
                selectedStatus = $(this).val();
                refreshDeviceGrid();
            });

            $('#logSearchInput').on('input', function() {
                logSearchQuery = $(this).val().toLowerCase().trim();
                currentLogsPage = 1;
                refreshLogsTable();
            });
        });

        // Fill area select dropdown dynamically based on selected Lot
        function populateAreaSelect() {
            const select = $('#areaSelect');
            select.empty();
            select.append('<option value="all">Tất cả khu vực</option>');

            const list = spotsData[currentActiveLot] || [];
            const uniqueAreas = [];
            list.forEach(item => {
                if (!uniqueAreas.includes(item.area)) {
                    uniqueAreas.push(item.area);
                }
            });
            uniqueAreas.sort().forEach(area => {
                select.append(`<option value="${area}">Khu ${area}</option>`);
            });
        }

        // Fill spot select dropdown dynamically based on selected Lot and Area
        function populateSpotSelect() {
            const select = $('#spotSelect');
            select.empty();
            select.append('<option value="all">Tất cả chỗ đỗ</option>');

            if (selectedArea === 'all') {
                select.prop('disabled', true);
                return;
            }

            select.prop('disabled', false);
            const list = spotsData[currentActiveLot] || [];
            const areaSpots = list.filter(s => s.area === selectedArea);
            
            // Sort by spot name numerically/alphabetically (A-01, A-02)
            areaSpots.sort((a, b) => a.name.localeCompare(b.name, undefined, { numeric: true, sensitivity: 'base' }));

            areaSpots.forEach(spot => {
                select.append(`<option value="${spot.name}">${spot.name}</option>`);
            });
        }

        // Calculate metrics and update device card displays
        function refreshDeviceGrid() {
            const list = spotsData[currentActiveLot] || [];
            const container = $('#deviceGridContainer');
            container.empty();

            if (list.length === 0) {
                container.html('<div class="col-12 text-center p-5 text-muted"><i class="fa-solid fa-hourglass-empty fs-2 mb-3"></i><p>Không có thiết bị hoặc bãi đỗ xe chưa được kích hoạt.</p></div>');
                updateKPIs([]);
                return;
            }

            // Apply Filters
            let filteredList = list;
            if (selectedArea !== 'all') {
                filteredList = filteredList.filter(d => d.area === selectedArea);
            }
            if (selectedSpot !== 'all') {
                filteredList = filteredList.filter(d => d.name === selectedSpot);
            }
            if (selectedStatus !== 'all') {
                filteredList = filteredList.filter(d => d.lockState === selectedStatus);
            }

            // Render KPIs based on lot data (regardless of area/status filters for correct lot stats)
            updateKPIs(list);

            if (filteredList.length === 0) {
                container.html('<div class="col-12 text-center p-5 text-muted"><i class="fa-solid fa-magnifying-glass fs-2 mb-3"></i><p>Không tìm thấy thiết bị phù hợp với bộ lọc.</p></div>');
                return;
            }

            // Build Barrier Grid Cards
            filteredList.forEach(device => {
                let cardStateClass = '';
                let statusBadgeClass = '';
                let statusText = '';
                let isError = device.lockState === 'Lỗi';

                if (device.lockState === 'Mở') {
                    cardStateClass = 'state-open';
                    statusBadgeClass = 'status-open';
                    statusText = 'Đang mở (Hạ)';
                } else if (device.lockState === 'Đóng') {
                    cardStateClass = 'state-closed';
                    statusBadgeClass = 'status-closed';
                    statusText = 'Đang đóng (Khóa)';
                } else {
                    cardStateClass = 'state-error';
                    statusBadgeClass = 'status-error';
                    statusText = 'Lỗi kết nối';
                }

                // Battery design
                let batteryIcon = 'fa-battery-full text-success';
                if (device.battery <= 20) {
                    batteryIcon = 'fa-battery-quarter text-danger';
                } else if (device.battery <= 50) {
                    batteryIcon = 'fa-battery-half text-warning';
                }

                // Wifi Signal design
                let wifiIcon = 'fa-wifi text-success';
                let signalText = 'Tốt';
                if (device.signal === 0) {
                    wifiIcon = 'fa-wifi text-muted opacity-50';
                    signalText = 'Mất sóng';
                } else if (device.signal <= 2) {
                    wifiIcon = 'fa-wifi text-warning';
                    signalText = 'Yếu';
                }

                const vehicleIcon = vehicleTypeIcons[device.type] || 'fa-car';

                const cardHtml = `
                    <div class="device-card ${cardStateClass}" id="device-card-${device.id}">
                        <div class="device-card-header">
                            <div>
                                <span class="device-title">Barrier ${device.name}</span>
                                <span class="d-block device-code">${device.lockCode}</span>
                            </div>
                            <span class="device-status-badge ${statusBadgeClass}">${statusText}</span>
                        </div>
                        <div class="device-metrics">
                            <div class="metric-item" title="Dung lượng pin">
                                <i class="fa-solid ${batteryIcon}"></i>
                                <span>${device.battery}%</span>
                            </div>
                            <div class="metric-item" title="Tín hiệu sóng IoT">
                                <i class="fa-solid ${wifiIcon}"></i>
                                <span>Signal: ${signalText}</span>
                            </div>
                            <div class="metric-item ms-auto">
                                <i class="fa-solid ${vehicleIcon}"></i>
                            </div>
                        </div>
                        <div class="device-actions">
                                <i class="fa-solid fa-clock-rotate-left"></i> Log
                            </button>
                        </div>
                    </div>
                `;
                container.append(cardHtml);
            });
        }

        // Update top stats summary
        function updateKPIs(list) {
            const total = list.length;
            const open = list.filter(d => d.lockState === 'Mở').length;
            const closed = list.filter(d => d.lockState === 'Đóng').length;
            const error = list.filter(d => d.lockState === 'Lỗi').length;

            $('#stat-total').text(total + ' thiết bị');
            $('#stat-open').text(open + ' thiết bị');
            $('#stat-closed').text(closed + ' thiết bị');
            $('#stat-error').text(error + ' thiết bị');
        }

        // Action: Remote control (Open/Close) simulated IoT command
        function triggerBarrierAction(id) {
            const list = spotsData[currentActiveLot] || [];
            const device = list.find(d => d.id === id);
            if (!device) return;

            const nextState = device.lockState === 'Mở' ? 'Đóng' : 'Mở';
            const actionText = nextState === 'Mở' ? 'Mở khóa' : 'Khóa lại';
            const $btn = $(`#btn-toggle-${id}`);

            // Loading state
            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Gửi lệnh...');

            setTimeout(() => {
                device.lockState = nextState;
                $btn.prop('disabled', false);

                // Add audit log entry
                const logTime = new Date().toISOString().replace('T', ' ').substring(0, 19);
                const randomCmdId = 'CMD-' + Math.floor(1000 + Math.random() * 9000);
                
                const newLog = {
                    id: randomCmdId,
                    time: logTime,
                    spotName: device.name,
                    lockCode: device.lockCode,
                    operator: 'Chủ bãi xe (Web)',
                    action: actionText,
                    result: 'Thành công',
                    note: `Lệnh ${actionText} khẩn cấp được gửi từ Cổng quản trị web của Chủ bãi.`
                };
                barrierLogsData.unshift(newLog);

                // Re-render UI
                refreshDeviceGrid();
                currentLogsPage = 1;
                refreshLogsTable();

                alert(`Đã truyền lệnh điều khiển IoT đến [${device.lockCode}] thành công. Trạng thái hiện tại: ${nextState === 'Mở' ? 'Đang mở (Hạ)' : 'Đang đóng (Khóa)'}`);
            }, 1000);
        }

        // Action: Reset hardware simulated command
        function triggerBarrierReset(id) {
            const list = spotsData[currentActiveLot] || [];
            const device = list.find(d => d.id === id);
            if (!device) return;

            const $btn = $(`#btn-reset-${id}`);
            const originalHtml = $btn.html();
            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Reset...');

            setTimeout(() => {
                $btn.prop('disabled', false).html(originalHtml);
                
                // If it was error state, restore connection with random battery / signal
                let message = '';
                if (device.lockState === 'Lỗi') {
                    device.lockState = 'Đóng';
                    device.battery = 80;
                    device.signal = 3;
                    message = `Khôi phục thành công kết nối IoT trên thiết bị [${device.lockCode}]. Trạng thái thiết bị đặt về Đóng.`;
                } else {
                    message = `Reset thành công thiết bị [${device.lockCode}]. Trạng thái kết nối ổn định.`;
                }

                // Add audit log
                const logTime = new Date().toISOString().replace('T', ' ').substring(0, 19);
                const randomCmdId = 'CMD-' + Math.floor(1000 + Math.random() * 9000);
                
                const newLog = {
                    id: randomCmdId,
                    time: logTime,
                    spotName: device.name,
                    lockCode: device.lockCode,
                    operator: 'Chủ bãi xe (Web)',
                    action: 'Reset',
                    result: 'Thành công',
                    note: `Khởi động lại phần cứng và kết nối viễn thông trên bo mạch thiết bị.`
                };
                barrierLogsData.unshift(newLog);

                // Re-render UI
                refreshDeviceGrid();
                currentLogsPage = 1;
                refreshLogsTable();

                alert(message);
            }, 1200);
        }

        // Render Logs table with filter, search and page selection
        function refreshLogsTable() {
            const tbody = $('#logsTableBody');
            tbody.empty();

            let logs = barrierLogsData;

            // Apply Spot Filter (Log button clicked on card)
            if (selectedSpotFilter) {
                logs = logs.filter(l => l.lockCode === selectedSpotFilter);
                $('#activeSpotFilterLabel').text(selectedSpotFilter);
                $('#activeSpotFilterContainer').show();
            } else {
                $('#activeSpotFilterContainer').hide();
            }

            // Apply Search filter
            if (logSearchQuery !== '') {
                logs = logs.filter(l => {
                    return l.operator.toLowerCase().includes(logSearchQuery) || 
                           l.spotName.toLowerCase().includes(logSearchQuery) ||
                           l.lockCode.toLowerCase().includes(logSearchQuery) ||
                           l.note.toLowerCase().includes(logSearchQuery);
                });
            }

            const totalLogs = logs.length;

            if (totalLogs === 0) {
                tbody.html('<tr><td colspan="8" class="text-center p-4 text-muted">Không tìm thấy bản ghi nhật ký phù hợp.</td></tr>');
                $('#paginationInfo').text('Hiển thị 0 dòng');
                $('#logsPagination').empty();
                return;
            }

            // Calculate Pagination
            const totalPages = Math.ceil(totalLogs / logsPerPage);
            if (currentLogsPage > totalPages) {
                currentLogsPage = totalPages;
            }
            if (currentLogsPage < 1) {
                currentLogsPage = 1;
            }

            const startIndex = (currentLogsPage - 1) * logsPerPage;
            const endIndex = Math.min(startIndex + logsPerPage, totalLogs);
            const paginatedLogs = logs.slice(startIndex, endIndex);

            // Populate rows
            paginatedLogs.forEach(log => {
                let badgeClass = log.result === 'Thành công' ? 'log-badge-success' : 'log-badge-danger';
                let actionBadge = log.action === 'Mở khóa' ? 'text-success' : (log.action === 'Khóa lại' ? 'text-secondary' : 'text-primary');

                const rowHtml = `
                    <tr>
                        <td class="font-monospace fw-bold text-dark text-nowrap">${log.id}</td>
                        <td class="text-muted small text-nowrap">${log.time}</td>
                        <td class="text-nowrap"><span class="badge bg-light text-dark fw-bold border">${log.spotName}</span></td>
                        <td class="font-monospace text-primary small text-nowrap">${log.lockCode}</td>
                        <td class="text-nowrap"><i class="fa-solid fa-circle-user text-muted me-1"></i> ${log.operator}</td>
                        <td class="fw-bold text-nowrap ${actionBadge}">${log.action}</td>
                        <td class="text-nowrap"><span class="${badgeClass}">${log.result}</span></td>
                        <td class="text-muted small text-wrap" style="min-width: 250px;">${log.note}</td>
                    </tr>
                `;
                tbody.append(rowHtml);
            });

            // Update Pagination Info
            $('#paginationInfo').text(`Hiển thị ${startIndex + 1}-${endIndex} trong ${totalLogs} dòng`);

            // Build Pagination buttons
            buildPaginationButtons(totalPages);
        }

        function buildPaginationButtons(totalPages) {
            const paginationEl = $('#logsPagination');
            paginationEl.empty();

            if (totalPages <= 1) return;

            // Previous button
            paginationEl.append(`
                <li class="page-item ${currentLogsPage === 1 ? 'disabled' : ''}">
                    <a class="page-link" href="#" onclick="changeLogsPage(${currentLogsPage - 1}); return false;"><i class="fa-solid fa-angle-left"></i></a>
                </li>
            `);

            // Page numbers
            for (let i = 1; i <= totalPages; i++) {
                paginationEl.append(`
                    <li class="page-item ${currentLogsPage === i ? 'active' : ''}">
                        <a class="page-link" href="#" onclick="changeLogsPage(${i}); return false;">${i}</a>
                    </li>
                `);
            }

            // Next button
            paginationEl.append(`
                <li class="page-item ${currentLogsPage === totalPages ? 'disabled' : ''}">
                    <a class="page-link" href="#" onclick="changeLogsPage(${currentLogsPage + 1}); return false;"><i class="fa-solid fa-angle-right"></i></a>
                </li>
            `);
        }

        function changeLogsPage(page) {
            currentLogsPage = page;
            refreshLogsTable();
        }

        // Filter logs specifically when clicking "Log" on a device card
        function filterLogsBySpot(lockCode, spotName) {
            selectedSpotFilter = lockCode;
            currentLogsPage = 1;
            refreshLogsTable();
            
            // Scroll smoothly down to the logs table so owner can see it immediately
            $('html, body').animate({
                scrollTop: $(".log-table").offset().top - 100
            }, 300);
        }

        // Remove the lock code log filter
        function clearSpotLogFilter() {
            selectedSpotFilter = null;
            currentLogsPage = 1;
            refreshLogsTable();
        }
    </script>
}
