        let barrierLogsData = [
            { id: 'CMD-1092', time: '2026-05-24 21:05:12', spotName: 'A-01', lockCode: 'LOCK-QT-A01', operator: 'khachhang01', action: 'Mở khóa', result: 'Thành công', note: 'Khách hàng kích hoạt mở barie qua ứng dụng di động khi đến vị trí đỗ.' },
            { id: 'CMD-1091', time: '2026-05-24 20:30:15', spotName: 'B-01', lockCode: 'LOCK-QT-B01', operator: 'Chủ bãi xe (Web)', action: 'Khóa lại', result: 'Thành công', note: 'Chủ bãi đỗ thực hiện khóa cưỡng bức từ trung tâm điều khiển.' },
            { id: 'CMD-1090', time: '2026-05-24 19:15:45', spotName: 'A-03', lockCode: 'LOCK-QT-A03', operator: 'khachhang02', action: 'Mở khóa', result: 'Thành công', note: 'Mở khóa tự động khi xác nhận đặt chỗ thành công.' },
            { id: 'CMD-1089', time: '2026-05-24 18:40:02', spotName: 'A-06', lockCode: 'LOCK-QT-A06', operator: 'Hệ thống IoT', action: 'Mở khóa', result: 'Thất bại', note: 'Thiết bị không phản hồi. Lỗi kẹt cơ học hoặc mất nguồn cấp điện.' },
