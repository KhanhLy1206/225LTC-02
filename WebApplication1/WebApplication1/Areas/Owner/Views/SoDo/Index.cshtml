@{
    ViewData["Title"] = "Sơ đồ bãi đỗ";
}

<!-- Custom Styles for Interactive Spot Grid -->
<style>
    .spot-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 16px;
    }

    .spot-card {
        background-color: var(--owner-card-bg);
        border: 1px solid var(--owner-border);
        border-radius: 12px;
        padding: 16px;
        position: relative;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 150px;
        box-shadow: var(--owner-shadow-sm);
    }

    .spot-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--owner-shadow);
        border-color: var(--owner-primary);
    }

    /* Spot States Styling */
    .spot-card.state-trong {
        border-left: 5px solid var(--owner-success);
    }
    .spot-card.state-trong .spot-icon {
        color: var(--owner-success);
    }
    .spot-card.state-trong .spot-status-text {
        color: var(--owner-success);
        background-color: var(--owner-success-light);
    }

    .spot-card.state-dangdo {
        border-left: 5px solid var(--owner-warning);
    }
    .spot-card.state-dangdo .spot-icon {
        color: var(--owner-warning);
    }
    .spot-card.state-dangdo .spot-status-text {
        color: var(--owner-warning);
        background-color: var(--owner-warning-light);
    }

    .spot-card.state-dadat {
        border-left: 5px solid var(--owner-primary);
    }
    .spot-card.state-dadat .spot-icon {
        color: var(--owner-primary);
    }
    .spot-card.state-dadat .spot-status-text {
        color: var(--owner-primary);
        background-color: var(--owner-primary-light);
    }

    .spot-card.state-baotri {
        border-left: 5px solid var(--owner-danger);
        background-color: #fafafa;
    }
    .spot-card.state-baotri .spot-icon {
        color: var(--owner-danger);
    }
    .spot-card.state-baotri .spot-status-text {
        color: var(--owner-danger);
        background-color: var(--owner-danger-light);
    }

    .spot-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .spot-name {
        font-weight: 800;
        font-size: 1.1rem;
        color: var(--owner-text-main);
    }

    .spot-lock-badge {
        font-size: 0.85rem;
        padding: 2px 6px;
        border-radius: 4px;
    }

    .spot-body {
        text-align: center;
        margin-bottom: 12px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .spot-icon {
        font-size: 2rem;
        margin-bottom: 6px;
        transition: transform 0.2s ease;
    }

    .spot-card:hover .spot-icon {
        transform: scale(1.15);
    }

    .spot-plate {
        font-family: 'Plus Jakarta Sans', monospace;
        font-weight: 700;
        font-size: 0.85rem;
        color: var(--owner-text-main);
        background-color: #f1f5f9;
        padding: 2px 6px;
        border-radius: 4px;
        border: 1px dashed #cbd5e1;
    }

    .spot-status-text {
        font-size: 0.72rem;
        font-weight: 800;
        padding: 4px 8px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Interactive area filter buttons */
    .filter-btn {
        border-radius: 30px;
        padding: 6px 18px;
        font-weight: 600;
        font-size: 0.875rem;
        transition: var(--owner-transition);
        border: 1px solid var(--owner-border);
        background-color: #ffffff;
        color: var(--owner-text-muted);
    }

    .filter-btn:hover {
        background-color: #f1f5f9;
        color: var(--owner-text-main);
    }

    .filter-btn.active {
        background-color: var(--owner-primary);
        border-color: var(--owner-primary);
        color: #ffffff;
        box-shadow: 0 4px 10px rgba(79, 70, 229, 0.2);
    }

    /* Modal Styling */
    .modal-detail-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--owner-text-muted);
        letter-spacing: 0.5px;
        margin-bottom: 2px;
    }

    .modal-detail-val {
        font-size: 0.95rem;
        font-weight: 650;
        color: var(--owner-text-main);
        margin-bottom: 12px;
    }

    .barrier-ctrl-btn {
        transition: all 0.2s ease;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="owner-page-title">Sơ đồ bãi đỗ xe</h1>
        <p class="owner-page-subtitle">Giám sát vị trí đỗ, trạng thái khóa thông minh và xử lý khẩn cấp.</p>
    </div>
    <!-- Lot Selection -->
    <div style="min-width: 250px;">
        <select class="form-select rounded-3 border-light shadow-sm py-2" id="lotSelect">
            <option value="1" selected>SPMS Cống Quỳnh - Quận 1</option>
            <option value="2">SPMS Sunrise City - Quận 7</option>
            <option value="3">SPMS Landmark Plus - Bình Thạnh (Chờ duyệt)</option>
        </select>
    </div>
</div>

<!-- KPI Stats Summary Row -->
<div class="row g-4 mb-4">
    <!-- Spot Count -->
    <div class="col-xl-3 col-md-6">
        <div class="owner-kpi-card py-3 px-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-1 text-muted text-uppercase small font-weight-bold">Tổng chỗ đỗ</h6>
                    <div class="owner-kpi-value text-dark" id="stat-total" style="font-size: 1.5rem;">50 chỗ</div>
                </div>
                <div class="owner-kpi-icon-box primary" style="width: 40px; height: 40px; font-size: 1.1rem;">
                    <i class="fa-solid fa-square-parking"></i>
                </div>
            </div>
        </div>
    </div>
    <!-- Available -->
    <div class="col-xl-3 col-md-6">
        <div class="owner-kpi-card py-3 px-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-1 text-muted text-uppercase small font-weight-bold">Chỗ trống</h6>
                    <div class="owner-kpi-value text-success" id="stat-trong" style="font-size: 1.5rem;">18 chỗ</div>
                </div>
                <div class="owner-kpi-icon-box success" style="width: 40px; height: 40px; font-size: 1.1rem;">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
            </div>
        </div>
    </div>
    <!-- Occupied & Reserved -->
    <div class="col-xl-3 col-md-6">
        <div class="owner-kpi-card py-3 px-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-1 text-muted text-uppercase small font-weight-bold">Đang đỗ / Đã đặt</h6>
                    <div class="owner-kpi-value text-warning" id="stat-doing" style="font-size: 1.5rem;">22 / 8 chỗ</div>
                </div>
                <div class="owner-kpi-icon-box warning" style="width: 40px; height: 40px; font-size: 1.1rem;">
                    <i class="fa-solid fa-car-side"></i>
                </div>
            </div>
        </div>
    </div>
    <!-- Maintenance -->
    <div class="col-xl-3 col-md-6">
        <div class="owner-kpi-card py-3 px-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-1 text-muted text-uppercase small font-weight-bold">Bảo trì / Lỗi khóa</h6>
                    <div class="owner-kpi-value text-danger" id="stat-baotri" style="font-size: 1.5rem;">2 chỗ</div>
                </div>
                <div class="owner-kpi-icon-box danger" style="width: 40px; height: 40px; font-size: 1.1rem; background-color: var(--owner-danger-light); color: var(--owner-danger);">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filters & Search Toolbar -->
<div class="owner-table-card border-0 mb-4">
    <div class="p-3 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <!-- Area Filter Tabs -->
        <div class="d-flex flex-wrap gap-2" id="areaFilterContainer">
            <button class="filter-btn active" data-filter="all">Tất cả</button>
            <button class="filter-btn" data-filter="A">Khu A - Ô tô</button>
            <button class="filter-btn" data-filter="B">Khu B - Ô tô</button>
        </div>
        
        <!-- Search Input -->
        <div class="owner-search m-0" style="max-width: 350px;">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" class="owner-search-input" id="spotSearchInput" placeholder="Tìm tên chỗ đỗ hoặc biển số xe..." />
        </div>
    </div>
</div>

<!-- Interactive Spot Grid Section -->
<div class="owner-table-card border-0 p-4">
    <div class="spot-grid" id="spotGridContainer">
        <!-- Dynamic spots generated by JS -->
    </div>
</div>

<!-- Spot Detail Modal -->
<div class="modal fade" id="spotDetailModal" tabindex="-1" aria-labelledby="spotDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header px-4 py-3 border-bottom border-light">
                <h5 class="modal-title fw-bold text-dark" id="spotDetailModalLabel">
                    <i class="fa-solid fa-circle-info text-primary me-2"></i> Chi tiết chỗ đỗ: <span id="modalSpotName">A-01</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row">
                    <!-- Spot Properties -->
                    <div class="col-6">
                        <div class="modal-detail-label">Khu vực</div>
                        <div class="modal-detail-val" id="modalArea">Khu A - Ô tô</div>
                        
                        <div class="modal-detail-label">Kích thước</div>
                        <div class="modal-detail-val" id="modalSize">5 x 2.5 m</div>
                    </div>
                    <div class="col-6">
                        <div class="modal-detail-label">Mã số khóa</div>
                        <div class="modal-detail-val font-monospace text-primary" id="modalLockCode">LOCK-QT-A01</div>
                        
                        <div class="modal-detail-label">Trạng thái ô đỗ</div>
                        <div class="modal-detail-val" id="modalSpotState">Trống</div>
                    </div>

                    <hr class="my-3 opacity-25">

                    <!-- Customer / Rental Details -->
                    <div class="col-12" id="modalRentalInfo">
                        <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-circle-user text-muted me-2"></i> Thông tin đặt chỗ</h6>
                        <div class="row bg-light rounded-3 p-3 mb-3 border">
                            <div class="col-6 mb-2">
                                <div class="modal-detail-label">Khách hàng</div>
                                <div class="modal-detail-val mb-0" id="modalCustomerName">Nguyễn Văn A</div>
                            </div>
                            <div class="col-6 mb-2">
                                <div class="modal-detail-label">Số điện thoại</div>
                                <div class="modal-detail-val mb-0" id="modalCustomerPhone">0912345678</div>
                            </div>
                            <div class="col-6 mb-2">
                                <div class="modal-detail-label">Biển số đăng ký</div>
                                <div class="modal-detail-val mb-0" id="modalCustomerPlate">81A-123.45</div>
                            </div>
                            <div class="col-6 mb-2">
                                <div class="modal-detail-label">Mã đặt chỗ</div>
                                <div class="modal-detail-val mb-0 text-success" id="modalBookingCode">#DC1024</div>
                            </div>
                            <div class="col-12">
                                <div class="modal-detail-label">Thời gian đặt</div>
                                <div class="modal-detail-val mb-0 text-primary" id="modalRentalTime">14:00 - 18:00 (24/05/2026)</div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Physical Lock State -->
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center bg-light rounded-3 p-3 border">
                            <div>
                                <span class="d-block small text-muted modal-detail-label">Trạng thái khóa vật lý</span>
                                <strong class="text-dark fs-5" id="modalPhysicalLockStatus">
                                    <i class="fa-solid fa-lock text-danger me-1"></i> Đang đóng
                                </strong>
                            </div>
                            <div class="d-flex gap-2" id="modalLockControlActions">
                                <button class="btn btn-sm btn-outline-primary py-2 px-3 barrier-ctrl-btn" id="btnToggleLock">Mở khóa</button>
                                <button class="btn btn-sm btn-outline-danger py-2 px-3 barrier-ctrl-btn" id="btnReportError">Báo lỗi</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer px-4 py-3 border-top border-light d-flex justify-content-between">
                <div>
                    <button type="button" class="btn btn-sm btn-outline-warning" id="btnToggleMaintenance">Đưa vào bảo trì</button>
                </div>
                <button type="button" class="btn btn-sm btn-secondary rounded-3 px-3 py-2" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

