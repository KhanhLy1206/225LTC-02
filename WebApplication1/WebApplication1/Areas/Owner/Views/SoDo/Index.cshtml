                { id: 35, area: 'B', name: 'B-05', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B05', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 36, area: 'B', name: 'B-06', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B06', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 37, area: 'B', name: 'B-07', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B07', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 38, area: 'B', name: 'B-08', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B08', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 39, area: 'B', name: 'B-09', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B09', lockState: 'Lỗi', occupancyState: 'Bảo trì', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 40, area: 'B', name: 'B-10', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B10', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 41, area: 'B', name: 'B-11', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B11', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 42, area: 'B', name: 'B-12', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B12', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 43, area: 'B', name: 'B-13', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B13', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 44, area: 'B', name: 'B-14', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B14', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 45, area: 'B', name: 'B-15', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B15', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 46, area: 'B', name: 'B-16', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B16', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 47, area: 'B', name: 'B-17', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B17', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 48, area: 'B', name: 'B-18', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B18', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 49, area: 'B', name: 'B-19', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B19', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 50, area: 'B', name: 'B-20', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-QT-B20', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
            ],
            2: [
                { id: 1, area: 'A', name: 'A-01', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-SR-A01', lockState: 'Đóng', occupancyState: 'Đang đỗ', plate: '51F-123.45', bookingCode: '#DC2001', customerName: 'Hoàng Văn M', customerPhone: '0912111222', rentalTime: '10:00 - 15:00 (Hôm nay)' },
                { id: 2, area: 'A', name: 'A-02', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-SR-A02', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 3, area: 'A', name: 'A-03', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-SR-A03', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
                { id: 4, area: 'B', name: 'B-01', type: 'oto', size: '5x2.5m', lockCode: 'LOCK-SR-B01', lockState: 'Đóng', occupancyState: 'Trống', plate: '', bookingCode: '', customerName: '', customerPhone: '', rentalTime: '' },
            ],
            3: [] // Empty mock for lot awaiting approval
        };

        let currentActiveLot = 1;
        let selectedSpotId = null;
        let areaFilter = 'all';
        let searchQuery = '';

        // Initial setup on document ready
        $(document).ready(function() {
            renderSpots();
            updateStats();

            // Handle lot change
            $('#lotSelect').change(function() {
                currentActiveLot = parseInt($(this).val());
                renderSpots();
                updateStats();
            });

            // Handle area filter tab click
            $('#areaFilterContainer').on('click', '.filter-btn', function() {
                $('#areaFilterContainer .filter-btn').removeClass('active');
                $(this).addClass('active');
                areaFilter = $(this).data('filter');
                renderSpots();
            });

            // Handle live search
            $('#spotSearchInput').on('input', function() {
                searchQuery = $(this).val().toLowerCase().trim();
                renderSpots();
            });

            // Set up Modal action buttons listeners
            $('#btnToggleLock').click(function() {
                if (selectedSpotId !== null) {
                    const spot = spotsData[currentActiveLot].find(s => s.id === selectedSpotId);
                    if (spot) {
                        const newLockState = (spot.lockState === 'Mở') ? 'Đóng' : 'Mở';
                        
                        // Simulation delay for API request call
                        $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang truyền lệnh...');
                        
                        setTimeout(() => {
                            spot.lockState = newLockState;
                            
                            // Log inside control history simulator
                            console.log(`[IoT Command] ${spot.lockCode} changed physical state to: ${newLockState}`);
                            
                            // Re-enable and update modal UI
                            $(this).prop('disabled', false).text(newLockState === 'Mở' ? 'Đóng khóa' : 'Mở khóa');
                            
                            updateSpotCardUI(spot);
                            showPhysicalLockStatus(spot);
                            updateStats();
                            
                            alert(`Gửi lệnh điều khiển khóa ${spot.lockCode} sang trạng thái [${newLockState}] THÀNH CÔNG!`);
                        }, 800);
                    }
                }
            });

            $('#btnReportError').click(function() {
                if (selectedSpotId !== null) {
                    const spot = spotsData[currentActiveLot].find(s => s.id === selectedSpotId);
                    if (spot) {
                        const confirmReport = confirm(`Bạn có chắc muốn báo lỗi khóa cho chỗ đỗ ${spot.name}? Trạng thái khóa sẽ chuyển sang Lỗi.`);
                        if (confirmReport) {
                            spot.lockState = 'Lỗi';
                            spot.occupancyState = 'Bảo trì';
                            updateSpotCardUI(spot);
                            showPhysicalLockStatus(spot);
                            updateStats();
                            $('#spotDetailModal').modal('hide');
                            alert(`Đã báo lỗi chỗ đỗ ${spot.name}. Hệ thống sẽ ghi nhận và tạo lệnh bảo trì.`);
                        }
                    }
                }
            });

            $('#btnToggleMaintenance').click(function() {
                if (selectedSpotId !== null) {
                    const spot = spotsData[currentActiveLot].find(s => s.id === selectedSpotId);
                    if (spot) {
                        if (spot.occupancyState === 'Bảo trì') {
                            spot.occupancyState = 'Trống';
                            spot.lockState = 'Đóng';
                            alert(`Đã mở khóa chỗ đỗ ${spot.name} và đưa vào hoạt động bình thường.`);
                        } else {
                            const confirmMaint = confirm(`Chuyển chỗ đỗ ${spot.name} sang trạng thái bảo trì? Chỗ đỗ sẽ bị đóng băng và không thể đặt.`);
                            if (confirmMaint) {
                                spot.occupancyState = 'Bảo trì';
                                spot.lockState = 'Lỗi';
                                alert(`Đã chuyển chỗ đỗ ${spot.name} sang bảo trì.`);
                            }
                        }
                        updateSpotCardUI(spot);
                        updateStats();
                        $('#spotDetailModal').modal('hide');
                    }
                }
            });
        });

        // Calculate and update stats counter
        function updateStats() {
            const list = spotsData[currentActiveLot] || [];
            
            let total = list.length;
            let trong = list.filter(s => s.occupancyState === 'Trống').length;
            let dangdo = list.filter(s => s.occupancyState === 'Đang đỗ').length;
            let dadat = list.filter(s => s.occupancyState === 'Đã đặt').length;
            let baotri = list.filter(s => s.occupancyState === 'Bảo trì').length;

            $('#stat-total').text(total + ' chỗ');
            $('#stat-trong').text(trong + ' chỗ');
            $('#stat-doing').text(`${dangdo} / ${dadat} chỗ`);
            $('#stat-baotri').text(baotri + ' chỗ');
        }

        // Render Spot Cards Grid with current active filters
        function renderSpots() {
            const container = $('#spotGridContainer');
            container.empty();

            const list = spotsData[currentActiveLot] || [];

            if (list.length === 0) {
                container.html('<div class="col-12 text-center p-5 text-muted"><i class="fa-solid fa-hourglass-empty fs-2 mb-3"></i><p>Không có dữ liệu chỗ đỗ hoặc bãi xe chưa được phê duyệt.</p></div>');
                return;
            }

            // Apply Filters
            let filteredList = list;
            
            // Area tab filter
            if (areaFilter !== 'all') {
                filteredList = filteredList.filter(s => s.area === areaFilter);
            }

            // Search query filter
            if (searchQuery !== '') {
                filteredList = filteredList.filter(s => {
                    return s.name.toLowerCase().includes(searchQuery) || 
                           s.plate.toLowerCase().includes(searchQuery) ||
                           s.customerName.toLowerCase().includes(searchQuery);
                });
            }

            if (filteredList.length === 0) {
                container.html('<div class="col-12 text-center p-5 text-muted"><i class="fa-solid fa-magnifying-glass fs-2 mb-3"></i><p>Không tìm thấy chỗ đỗ phù hợp.</p></div>');
                return;
            }

            // Generate HTML elements
            filteredList.forEach(spot => {
                let stateClass = '';
                let statusText = '';
                let vehicleIcon = spot.type === 'oto' ? 'fa-car' : 'fa-motorcycle';
                
                switch (spot.occupancyState) {
                    case 'Trống':
                        stateClass = 'state-trong';
                        statusText = 'Trống';
                        break;
                    case 'Đang đỗ':
                        stateClass = 'state-dangdo';
                        statusText = 'Đang đỗ';
                        break;
                    case 'Đã đặt':
                        stateClass = 'state-dadat';
                        statusText = 'Đã đặt';
                        break;
                    case 'Bảo trì':
                        stateClass = 'state-baotri';
                        statusText = 'Bảo trì';
                        break;
                }

                // Show plate instead of state if occupied
                let centerContent = '';
                if (spot.occupancyState === 'Đang đỗ' && spot.plate) {
                    centerContent = `<span class="spot-plate">${spot.plate}</span>`;
                } else if (spot.occupancyState === 'Đã đặt' && spot.plate) {
                    centerContent = `<span class="spot-plate bg-light border-primary-subtle text-primary">${spot.plate}</span>`;
                } else {
                    centerContent = `<span class="spot-status-text">${statusText}</span>`;
                }

                let lockIcon = '';
                let lockBg = '';
                if (spot.lockState === 'Mở') {
                    lockIcon = 'fa-lock-open text-primary';
                    lockBg = 'bg-primary-light';
                } else if (spot.lockState === 'Đóng') {
                    lockIcon = 'fa-lock text-muted';
                    lockBg = 'bg-light';
                } else {
                    lockIcon = 'fa-circle-exclamation text-danger';
                    lockBg = 'bg-danger-light';
                }

                const cardHtml = `
                    <div class="spot-card ${stateClass}" id="spot-card-${spot.id}" onclick="openSpotDetail(${spot.id})">
                        <div class="spot-header">
                            <span class="spot-name">${spot.name}</span>
                            <span class="spot-lock-badge ${lockBg}">
                                <i class="fa-solid ${lockIcon}"></i>
                            </span>
                        </div>
                        <div class="spot-body">
                            <i class="fa-solid ${vehicleIcon} spot-icon"></i>
                            ${centerContent}
                        </div>
                    </div>
                `;
                container.append(cardHtml);
            });
        }

        // Single spot card DOM update to prevent redraw
        function updateSpotCardUI(spot) {
            const card = $(`#spot-card-${spot.id}`);
            if (card.length === 0) return;

            // Remove previous classes
            card.removeClass('state-trong state-dangdo state-dadat state-baotri');

            let stateClass = '';
            let statusText = '';
            switch (spot.occupancyState) {
                case 'Trống':
                    stateClass = 'state-trong';
                    statusText = 'Trống';
                    break;
                case 'Đang đỗ':
                    stateClass = 'state-dangdo';
                    statusText = 'Đang đỗ';
                    break;
                case 'Đã đặt':
                    stateClass = 'state-dadat';
                    statusText = 'Đã đặt';
                    break;
                case 'Bảo trì':
                    stateClass = 'state-baotri';
                    statusText = 'Bảo trì';
                    break;
            }
            card.addClass(stateClass);

            // Update body
            const body = card.find('.spot-body');
            let vehicleIcon = spot.type === 'oto' ? 'fa-car' : 'fa-motorcycle';
            
            let centerContent = '';
            if (spot.occupancyState === 'Đang đỗ' && spot.plate) {
                centerContent = `<span class="spot-plate">${spot.plate}</span>`;
            } else if (spot.occupancyState === 'Đã đặt' && spot.plate) {
                centerContent = `<span class="spot-plate bg-light border-primary-subtle text-primary">${spot.plate}</span>`;
            } else {
                centerContent = `<span class="spot-status-text">${statusText}</span>`;
            }
            body.html(`<i class="fa-solid ${vehicleIcon} spot-icon"></i> ${centerContent}`);

            // Update lock badge
            const badge = card.find('.spot-lock-badge');
            badge.removeClass('bg-primary-light bg-light bg-danger-light');
            
            let lockIcon = '';
            let lockBg = '';
            if (spot.lockState === 'Mở') {
                lockIcon = 'fa-lock-open text-primary';
                lockBg = 'bg-primary-light';
            } else if (spot.lockState === 'Đóng') {
                lockIcon = 'fa-lock text-muted';
                lockBg = 'bg-light';
            } else {
                lockIcon = 'fa-circle-exclamation text-danger';
                lockBg = 'bg-danger-light';
            }
            badge.addClass(lockBg).html(`<i class="fa-solid ${lockIcon}"></i>`);
        }

        // Open detailed info of clicked parking slot
        function openSpotDetail(id) {
            selectedSpotId = id;
            const spot = spotsData[currentActiveLot].find(s => s.id === id);
            if (!spot) return;

            $('#modalSpotName').text(spot.name);
            $('#modalArea').text(spot.area === 'A' ? 'Khu A - Ô tô' : 'Khu B - Ô tô');
            $('#modalSize').text(spot.size);
            $('#modalLockCode').text(spot.lockCode);
            $('#modalSpotState').text(spot.occupancyState);

            // Show or hide rental info based on state
            if (spot.occupancyState === 'Đang đỗ' || spot.occupancyState === 'Đã đặt') {
                $('#modalRentalInfo').show();
                $('#modalCustomerName').text(spot.customerName);
                $('#modalCustomerPhone').text(spot.customerPhone);
                $('#modalCustomerPlate').text(spot.plate);
                $('#modalBookingCode').text(spot.bookingCode);
                $('#modalRentalTime').text(spot.rentalTime);
            } else {
                $('#modalRentalInfo').hide();
            }

            showPhysicalLockStatus(spot);

            // Change maintenance button label based on current state
            if (spot.occupancyState === 'Bảo trì') {
                $('#btnToggleMaintenance').text('Khôi phục hoạt động').removeClass('btn-outline-warning').addClass('btn-success');
            } else {
                $('#btnToggleMaintenance').text('Đưa vào bảo trì').removeClass('btn-success').addClass('btn-outline-warning');
            }

            // Open Modal
            const myModal = new bootstrap.Modal(document.getElementById('spotDetailModal'));
            myModal.show();
        }

        // Show Physical Lock Status details inside modal
        function showPhysicalLockStatus(spot) {
            const statusEl = $('#modalPhysicalLockStatus');
            const toggleBtn = $('#btnToggleLock');
            
            if (spot.lockState === 'Mở') {
                statusEl.html('<i class="fa-solid fa-lock-open text-success me-1"></i> Đang mở (🔓)');
                toggleBtn.text('Đóng khóa').removeClass('btn-outline-primary').addClass('btn-outline-danger');
            } else if (spot.lockState === 'Đóng') {
                statusEl.html('<i class="fa-solid fa-lock text-danger me-1"></i> Đang đóng (🔒)');
                toggleBtn.text('Mở khóa').removeClass('btn-outline-danger').addClass('btn-outline-primary');
            } else {
                statusEl.html('<i class="fa-solid fa-circle-exclamation text-warning me-1"></i> Lỗi kết nối / Kẹt khóa (⚠️)');
                toggleBtn.text('Thử mở khóa').removeClass('btn-outline-danger').addClass('btn-outline-primary');
            }
        }
    </script>
}
