@{
    ViewData["Title"] = "Dashboard Overview";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="owner-page-title">Tổng quan bãi đỗ xe</h1>
        <p class="owner-page-subtitle">Chào mừng trở lại, Lê Văn Chủ! Dưới đây là hoạt động bãi đỗ của bạn hôm nay.</p>
    </div>
    <div>
        <button class="btn btn-primary-custom d-flex align-items-center gap-2">
            <i class="fa-solid fa-file-export"></i>
            <span>Xuất báo cáo</span>
        </button>       
    </div>
</div>

<!-- KPI Cards Row -->
<div class="row g-4 mb-4">
    <!-- Today's Revenue -->
    <div class="col-xl-3 col-md-6">
        <div class="owner-kpi-card h-100">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="owner-kpi-info">
                    <h6>Doanh thu hôm nay</h6>
                </div>
                <div class="owner-kpi-icon-box primary">
                    <i class="fa-solid fa-wallet"></i>
                </div>
            </div>
            <div class="owner-kpi-value mb-3">1,250,000đ</div>
            <div class="owner-kpi-footer">
                <span class="owner-kpi-trend up">
                    <i class="fa-solid fa-arrow-up"></i> +12.5% so với hôm qua
                </span>
            </div>
        </div>
    </div>

    <!-- Today's Bookings -->
    <div class="col-xl-3 col-md-6">
        <div class="owner-kpi-card h-100">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="owner-kpi-info">
                    <h6>Lượt đặt xe hôm nay</h6>
                </div>
                <div class="owner-kpi-icon-box success">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
            </div>
            <div class="owner-kpi-value mb-3">42 lượt</div>
            <div class="owner-kpi-footer">
                <span class="owner-kpi-trend up">
                    <i class="fa-solid fa-arrow-up"></i> +5.8% so với tuần trước
                </span>
            </div>
        </div>
    </div>

    <!-- Occupancy Rate -->
    <div class="col-xl-3 col-md-6">
        <div class="owner-kpi-card h-100">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="owner-kpi-info">
                    <h6>Hiệu suất chỗ đỗ</h6>
                </div>
                <div class="owner-kpi-icon-box warning">
                    <i class="fa-solid fa-car-side"></i>
                </div>
            </div>
            <div class="owner-kpi-value mb-2">84%</div>
            <div class="owner-kpi-footer">
                <div class="owner-kpi-progress mb-2">
                    <div class="owner-kpi-progress-bar" style="width: 84%"></div>
                </div>
                <div class="small text-muted">42/50 chỗ đỗ đang được sử dụng</div>
            </div>
        </div>
    </div>

    <!-- Device Status -->
    <div class="col-xl-3 col-md-6">
        <div class="owner-kpi-card h-100">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="owner-kpi-info">
                    <h6>Trạng thái thiết bị</h6>
                </div>
                <div class="owner-kpi-icon-box info">
                    <i class="fa-solid fa-microchip"></i>
                </div>
            </div>
            <div class="owner-kpi-value mb-3">19 / 20</div>
            <div class="owner-kpi-footer">
                <span class="owner-kpi-trend down">
                    <i class="fa-solid fa-circle-exclamation"></i> 1 khóa thông minh lỗi
                </span>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <!-- Revenue Chart -->
    <div class="col-lg-8">
        <div class="owner-table-card h-100">
            <div class="owner-card-header">
                <h5 class="owner-card-title">Doanh thu & Lượt đặt xe tuần này</h5>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        7 ngày qua
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">Tuần này</a></li>
                        <li><a class="dropdown-item" href="#">Tháng này</a></li>
                        <li><a class="dropdown-item" href="#">Năm nay</a></li>
                    </ul>
                </div>
            </div>
            <div class="card-body p-4">
                <div style="height: 320px;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Vehicle Type Pie Chart -->
    <div class="col-lg-4">
        <div class="owner-table-card h-100">
            <div class="owner-card-header">
                <h5 class="owner-card-title">Phân bổ loại xe</h5>
            </div>
            <div class="card-body p-4 d-flex flex-column align-items-center justify-content-center">
                <div style="height: 240px; width: 100%; position: relative;">
                    <canvas id="vehicleDistributionChart"></canvas>
                </div>
                <div class="mt-3 w-100 text-center">
                    <span class="badge bg-indigo" style="background-color: #4f46e5;">Ô tô (100%)</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Activities and Quick Device Control Row -->
<div class="row g-4">
    <!-- Recent Bookings Table -->
    <div class="col-xl-8">
        <div class="owner-table-card">
            <div class="owner-card-header">
                <h5 class="owner-card-title">Các lượt đặt chỗ gần đây</h5>
                <a href="#" class="btn btn-sm btn-link text-decoration-none">Xem tất cả</a>
            </div>
            <div class="table-responsive">
                <table class="table owner-table">
                    <thead>
                        <tr>
                            <th>Mã Đặt Chỗ</th>
                            <th>Biển Số Xe</th>
                            <th>Loại Xe</th>
                            <th>Vị Trí Đỗ</th>
                            <th>Thời Gian Đỗ</th>
                            <th>Doanh Thu</th>
                            <th>Trạng Thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong class="text-primary">#DC1024</strong></td>
                            <td>81A-123.45</td>
                            <td>Ô tô</td>
                            <td><span class="badge bg-secondary">A-03</span></td>
                            <td>14:00 - 18:00</td>
                            <td>90,000đ</td>
                            <td><span class="owner-badge owner-badge-info">Đã đặt</span></td>
                        </tr>
                        <tr>
                            <td><strong class="text-primary">#DC1023</strong></td>
                            <td>81B1-678.90</td>
                            <td>Xe máy</td>
                            <td><span class="badge bg-secondary">B-01</span></td>
                            <td>16:30 - 20:30</td>
                            <td>23,000đ</td>
                            <td><span class="owner-badge owner-badge-success">Đang đỗ</span></td>
                        </tr>
                        <tr>
                            <td><strong class="text-primary">#DC1022</strong></td>
                            <td>29A-999.99</td>
                            <td>Ô tô</td>
                            <td><span class="badge bg-secondary">A-01</span></td>
                            <td>10:00 - 12:00</td>
                            <td>50,000đ</td>
                            <td><span class="owner-badge owner-badge-success">Hoàn thành</span></td>
                        </tr>
                        <tr>
                            <td><strong class="text-primary">#DC1021</strong></td>
                            <td>43C-888.88</td>
                            <td>Ô tô</td>
                            <td><span class="badge bg-secondary">A-02</span></td>
                            <td>08:00 - 10:00</td>
                            <td>50,000đ</td>
                            <td><span class="owner-badge owner-badge-danger">Quá hạn</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Quick Device Controls -->
    <div class="col-xl-4">
        <div class="owner-table-card">
            <div class="owner-card-header">
                <h5 class="owner-card-title">Giám sát khóa thông minh</h5>
            </div>
            <div class="card-body p-4">
                <p class="small text-muted mb-4">Các barrier đang hoạt động tại các vị trí đỗ. Click để chuyển đổi đóng/mở thủ công.</p>
                
                <div class="d-flex flex-column gap-3">
                    <!-- Device 1 -->
                    <div class="d-flex justify-content-between align-items-center p-3 rounded bg-light border">
                        <div>
                            <span class="d-block fw-bold text-dark">Chỗ A-01 (Ô tô)</span>
                            <span class="small text-muted font-monospace">LOCK-QT-A01</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-success-light text-success me-2" id="status-A01">Đang đỗ</span>
                            <button class="btn btn-sm btn-outline-primary" onclick="toggleBarrier('A01')">Mở khóa</button>
                        </div>
                    </div>

                    <!-- Device 2 -->
                    <div class="d-flex justify-content-between align-items-center p-3 rounded bg-light border">
                        <div>
                            <span class="d-block fw-bold text-dark">Chỗ A-02 (Ô tô)</span>
                            <span class="small text-muted font-monospace">LOCK-QT-A02</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-light text-muted border me-2" id="status-A02">Trống (Đóng)</span>
                            <button class="btn btn-sm btn-outline-primary" onclick="toggleBarrier('A02')">Mở khóa</button>
                        </div>
                    </div>

                    <!-- Device 3 -->
                    <div class="d-flex justify-content-between align-items-center p-3 rounded bg-light border">
                        <div>
                            <span class="d-block fw-bold text-dark">Chỗ A-03 (Ô tô)</span>
                            <span class="small text-muted font-monospace">LOCK-QT-A03</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-primary-light text-primary me-2" id="status-A03">Đã đặt (Mở)</span>
                            <button class="btn btn-sm btn-outline-danger" onclick="toggleBarrier('A03')">Đóng khóa</button>
                        </div>
                    </div>

                    <!-- Device 4 (Error state) -->
                    <div class="d-flex justify-content-between align-items-center p-3 rounded bg-light border">
                        <div>
                            <span class="d-block fw-bold text-dark">Chỗ B-01 (Xe máy)</span>
                            <span class="small text-muted font-monospace">LOCK-QT-B01</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-danger-light text-danger me-2" id="status-B01">Lỗi Kết Nối</span>
                            <button class="btn btn-sm btn-warning" onclick="resetBarrier('B01')"><i class="fa-solid fa-arrows-rotate"></i> Reset</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Setup Weekly Revenue & Booking Chart using Chart.js
        const ctxRev = document.getElementById('revenueChart').getContext('2d');
        const revenueChart = new Chart(ctxRev, {
            type: 'bar',
            data: {
                labels: ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'],
                datasets: [{
                    label: 'Doanh Thu (VNĐ)',
                    data: [850000, 920000, 1100000, 980000, 1400000, 1750000, 1250000],
                    backgroundColor: 'rgba(79, 70, 229, 0.85)',
                    borderColor: 'rgba(79, 70, 229, 1)',
                    borderWidth: 1,
                    borderRadius: 6,
                    yAxisID: 'y'
                }, {
                    label: 'Số Lượt Đặt',
                    data: [28, 31, 38, 33, 48, 58, 42],
                    type: 'line',
                    borderColor: 'rgba(6, 182, 212, 1)',
                    backgroundColor: 'rgba(6, 182, 212, 0.1)',
                    borderWidth: 3,
                    tension: 0.3,
                    fill: false,
                    yAxisID: 'y1'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                        labels: {
                            font: {
                                family: 'Plus Jakarta Sans',
                                weight: '600'
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: {
                            display: false
                        }
                    },
                    y: {
                        type: 'linear',
                        display: true,
                        position: 'left',
                        grid: {
                            color: '#e2e8f0'
                        },
                        ticks: {
                            callback: function(value) {
                                return value.toLocaleString() + 'đ';
                            }
                        }
                    },
                    y1: {
                        type: 'linear',
                        display: true,
                        position: 'right',
                        grid: {
                            drawOnChartArea: false
                        }
                    }
                }
            }
        });

        // Setup Vehicle Distribution Doughnut Chart using Chart.js
        const ctxVeh = document.getElementById('vehicleDistributionChart').getContext('2d');
        const vehicleChart = new Chart(ctxVeh, {
            type: 'doughnut',
            data: {
                labels: ['Ô tô'],
                datasets: [{
                    data: [100],
                    backgroundColor: [
                        'rgba(79, 70, 229, 0.85)'
                    ],
                    borderWidth: 2,
                    borderColor: '#ffffff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                cutout: '70%'
            }
        });

        // Smart Barrier Simulation functions
        function toggleBarrier(id) {
            const statusBadge = document.getElementById('status-' + id);
            const button = event.target;
            
            if (statusBadge.innerText.includes('Đóng') || statusBadge.innerText.includes('Đang đỗ')) {
                // Open it
                statusBadge.innerText = 'Đã mở (Thủ công)';
                statusBadge.className = 'badge bg-primary-light text-primary me-2';
                button.innerText = 'Đóng khóa';
                button.className = 'btn btn-sm btn-outline-danger';
            } else {
                // Close it
                statusBadge.innerText = 'Trống (Đóng)';
                statusBadge.className = 'badge bg-light text-muted border me-2';
                button.innerText = 'Mở khóa';
                button.className = 'btn btn-sm btn-outline-primary';
            }
        }

        function resetBarrier(id) {
            const statusBadge = document.getElementById('status-' + id);
            const button = event.target;
            
            statusBadge.innerText = 'Đang kết nối...';
            statusBadge.className = 'badge bg-warning-light text-warning me-2';
            
            setTimeout(() => {
                statusBadge.innerText = 'Trống (Đóng)';
                statusBadge.className = 'badge bg-light text-muted border me-2';
                
                // Replace button
                const parent = button.parentElement;
                button.remove();
                
                const newBtn = document.createElement('button');
                newBtn.className = 'btn btn-sm btn-outline-primary';
                newBtn.innerText = 'Mở khóa';
                newBtn.onclick = function() { toggleBarrier(id); };
                parent.appendChild(newBtn);
            }, 1500);
        }
    </script>
}
